/* 全局容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* 背景渐变 */
.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #EAF6F4 0%, #f8f9fa 100%);
  z-index: -1;
}

/* 顶部栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-top: 10rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.date {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 4rpx;
}

.greeting {
  font-size: 24rpx;
  color: #666;
}

.student-picker {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.current-student {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-right: 10rpx;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.add-student-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.add-icon {
  font-size: 40rpx;
  color: #20756F;
  font-weight: 300;
  margin-top: -4rpx;
}

/* 通用卡片样式 */
.glass-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

/* 概览卡片 */
.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.stats-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.stats-rate {
  display: flex;
  align-items: baseline;
}

.rate-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #20756F;
  line-height: 1;
}

.rate-unit {
  font-size: 24rpx;
  color: #20756F;
  margin-left: 4rpx;
  font-weight: bold;
}

.rate-label {
  font-size: 22rpx;
  color: #999;
  margin-left: 10rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  gap: 6rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 0;
  padding: 12rpx 2rpx;
  border-radius: 16rpx;
}

.grid-item-pressed,
.grid-item.selected {
  background: #edf7f5;
}

.grid-item .num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.grid-item .label {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}

.grid-item.selected .num,
.grid-item.selected .label {
  color: #20756F;
}

/* 图表区域 */
.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-title-large {
  font-size: 34rpx;
  font-weight: 800;
  color: #333;
}

/* Update Time & Live Indicator */
.stats-title-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.update-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.total-task-link {
  align-self: flex-start;
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 10rpx;
  color: #20756F;
  font-size: 22rpx;
  font-weight: 700;
}

.total-task-arrow {
  font-size: 28rpx;
  line-height: 1;
}

.task-detail-panel {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf1f2;
}

.task-detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.task-detail-title {
  color: #25343b;
  font-size: 26rpx;
  font-weight: 800;
}

.task-detail-close {
  padding: 8rpx 4rpx 8rpx 20rpx;
  color: #20756F;
  font-size: 22rpx;
}

.parent-task-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f1f3f4;
}

.parent-task-row-pressed,
.feed-right-pressed {
  opacity: 0.72;
}

.parent-task-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.parent-task-name {
  color: #263238;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
}

.parent-task-meta {
  margin-top: 6rpx;
  color: #8b979d;
  font-size: 21rpx;
}

.parent-task-status {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #f2f4f5;
  color: #78858b;
  font-size: 21rpx;
  font-weight: 700;
}

.parent-task-status.in_progress {
  background: #eaf4ff;
  color: #2879be;
}

.parent-task-status.pending_review {
  background: #fff4de;
  color: #a86b00;
}

.parent-task-status.completed {
  background: #eaf7ef;
  color: #2f8150;
}

.parent-task-action {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.parent-task-view {
  color: #20756F;
  font-size: 20rpx;
  font-weight: 700;
}

.task-detail-empty {
  padding: 22rpx 0 8rpx;
  color: #9aa4a9;
  text-align: center;
  font-size: 23rpx;
}

.live-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.live-dot {
  width: 12rpx;
  height: 12rpx;
  background: #4CAF50;
  border-radius: 50%;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
}

.live-text {
  font-size: 20rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 柱状图 */
.bar-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
  padding-top: 20rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 12%;
}

.bar-column {
  width: 100%;
  height: 150rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.bar-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  border-radius: 8rpx;
  transition: height 0.5s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
}

/* 学科分布进度条 */
.subject-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.subject-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.subject-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.subject-count {
  font-size: 24rpx;
  color: #999;
}

.progress-track {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #20756F, #36A59D);
  border-radius: 6rpx;
}

/* 最近动态列表 (时间轴样式) */
.feed-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.feed-item {
  display: flex;
  margin-bottom: 0;
}

.feed-left {
  width: 40rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.feed-line {
  position: absolute;
  top: 20rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #e0e0e0;
  z-index: 0;
}

.feed-item:last-child .feed-line {
  display: none;
}

.feed-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  z-index: 1;
  margin-top: 10rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #e0e0e0;
}

.dot-green {
  background: #4CAF50;
  box-shadow: 0 0 0 2rpx #4CAF50;
}

.dot-blue {
  background: #2196F3;
  box-shadow: 0 0 0 2rpx #2196F3;
}

.feed-right {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.feed-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.feed-cat {
  font-size: 22rpx;
  color: #20756F;
  background: rgba(39, 124, 120, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.feed-date {
  font-size: 22rpx;
  color: #999;
}

.feed-content {
  margin-bottom: 16rpx;
}

.feed-detail {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.feed-footer {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  border-top: 1rpx solid #f9f9f9;
  padding-top: 16rpx;
}

.feed-score {
  font-size: 24rpx;
  color: #666;
}

.feed-result-summary {
  color: #526168;
  font-size: 23rpx;
  line-height: 1.5;
}

.feed-detail-link {
  align-self: flex-start;
  margin-top: 2rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eaf6f4;
  color: #20756F;
  font-size: 22rpx;
  font-weight: 700;
}

.highlight {
  color: #20756F;
  font-weight: bold;
  font-size: 28rpx;
}

.feed-teacher-note {
  font-size: 24rpx;
  color: #666;
  background: #fff9c4;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.note-icon {
  margin-right: 6rpx;
}

.empty-feed, .empty-state {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-link {
  font-size: 24rpx;
  color: #20756F;
}

.feedback-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feedback-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.feedback-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.feedback-course {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.feedback-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.feedback-time {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 4rpx;
}

.feedback-teacher {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.feedback-text {
  font-size: 26rpx;
  color: #0f172a;
  line-height: 1.6;
  white-space: pre-wrap;
}

.feedback-image {
  width: 100%;
  height: 260rpx;
  border-radius: 16rpx;
  margin-top: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.guest-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(32, 117, 111, 0.08);
  border: 1rpx solid rgba(32, 117, 111, 0.18);
  font-size: 24rpx;
  color: #20756F;
}

.guest-banner-btn {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  background: #20756F;
  color: #fff;
  font-size: 24rpx;
}
