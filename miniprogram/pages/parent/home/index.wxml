<view class="container">
  <!-- 顶部背景 -->
  <view class="bg-gradient"></view>

  <block wx:if="{{students.length > 0}}">
    <view class="guest-banner" wx:if="{{isGuest}}" bindtap="goLogin">
      <text>当前为演示数据，登录后查看孩子的真实学习情况</text>
      <text class="guest-banner-btn">去登录</text>
    </view>

    <!-- 顶部栏 -->
    <view class="header">
      <view class="header-left">
        <text class="date">{{todayDate}}</text>
        <text class="greeting">家长，您好</text>
      </view>
      <view class="header-right">
        <picker bindchange="switchStudent" value="{{currentStudentIndex}}" range="{{students}}" range-key="name">
          <view class="student-picker">
            <image class="picker-icon" src="/images/icons/student.png" wx:if="{{false}}"></image>
            <text class="current-student">{{students[currentStudentIndex].name}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
        <view class="add-student-btn" bindtap="navigateToAddStudent">
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>

    <!-- 概览卡片 -->
    <view class="stats-card glass-card">
      <view class="stats-header">
        <view class="stats-title-group">
          <text class="stats-title">今日概览</text>
          <view class="update-info">
            <text class="stats-subtitle" wx:if="{{lastUpdateTime}}">{{lastUpdateTime}} 更新</text>
            <view class="live-indicator" wx:if="{{stats.isStudying}}">
              <view class="live-dot"></view>
              <text class="live-text">实时学习中</text>
            </view>
          </view>
          <view class="total-task-link" data-filter="all" bindtap="showTodayTasks">
            <text>查看全部 {{stats.today.total}} 项</text>
            <text class="total-task-arrow">›</text>
          </view>
        </view>
        <view class="stats-rate">
          <text class="rate-num">{{stats.today.rate}}</text>
          <text class="rate-unit">%</text>
          <text class="rate-label">完成率</text>
        </view>
      </view>
      <view class="stats-grid">
        <view class="grid-item {{activeTaskFilter === 'not_started' ? 'selected' : ''}}" data-filter="not_started" bindtap="showTodayTasks" hover-class="grid-item-pressed">
          <text class="num">{{stats.today.not_started || 0}}</text>
          <text class="label">待完成 ›</text>
        </view>
        <view class="grid-item {{activeTaskFilter === 'in_progress' ? 'selected' : ''}}" data-filter="in_progress" bindtap="showTodayTasks" hover-class="grid-item-pressed">
          <text class="num">{{stats.today.in_progress}}</text>
          <text class="label">进行中 ›</text>
        </view>
        <view class="grid-item {{activeTaskFilter === 'pending_review' ? 'selected' : ''}}" data-filter="pending_review" bindtap="showTodayTasks" hover-class="grid-item-pressed">
          <text class="num">{{stats.today.pending_review || stats.today.pending || 0}}</text>
          <text class="label">待审核 ›</text>
        </view>
        <view class="grid-item {{activeTaskFilter === 'completed' ? 'selected' : ''}}" data-filter="completed" bindtap="showTodayTasks" hover-class="grid-item-pressed">
          <text class="num">{{stats.today.completed}}</text>
          <text class="label">已完成 ›</text>
        </view>
      </view>

      <view class="task-detail-panel" wx:if="{{showTaskDetails}}">
        <view class="task-detail-head">
          <text class="task-detail-title">{{activeTaskTitle}}（{{filteredTodayTasks.length}}）</text>
          <text class="task-detail-close" bindtap="hideTodayTasks">收起</text>
        </view>
        <block wx:if="{{filteredTodayTasks.length > 0}}">
          <view class="parent-task-row" wx:for="{{filteredTodayTasks}}" wx:key="id" data-task-id="{{item.id}}" bindtap="viewTaskDetail" hover-class="parent-task-row-pressed">
            <view class="parent-task-main">
              <text class="parent-task-name">{{item.task_name}}</text>
              <text class="parent-task-meta">{{item.category}}{{item.planned_minutes ? (' · ' + item.planned_minutes + '分钟') : ''}}</text>
            </view>
            <view class="parent-task-action">
              <text class="parent-task-status {{item.state}}">{{item.state_label}}</text>
              <text class="parent-task-view">查看详情</text>
            </view>
          </view>
        </block>
        <view class="task-detail-empty" wx:else>当前没有{{activeTaskTitle}}</view>
      </view>
    </view>

    <!-- 数据图表区域 -->
    <view class="charts-row">
      <!-- 本周趋势 (柱状图) -->
      <view class="chart-card glass-card">
        <view class="section-header">
          <text class="section-title">本周趋势</text>
        </view>
        <view class="bar-chart">
          <view class="bar-item" wx:for="{{stats.weekly}}" wx:key="date">
            <view class="bar-column">
              <view class="bar-fill" style="height: {{item.rate}}%; background: {{item.rate >= 80 ? '#4CAF50' : (item.rate >= 50 ? '#FFC107' : '#FF5252')}}"></view>
            </view>
            <text class="bar-label">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 学科分布 (进度条) -->
    <view class="chart-card glass-card" wx:if="{{stats.subjects && stats.subjects.length > 0}}">
      <view class="section-header">
        <text class="section-title">学科分布 (近30天)</text>
      </view>
      <view class="subject-list">
        <view class="subject-item" wx:for="{{stats.subjects}}" wx:key="subject">
          <view class="subject-info">
            <text class="subject-name">{{item.subject}}</text>
            <text class="subject-count">{{item.count}}次</text>
          </view>
          <view class="progress-track">
            <view class="progress-bar" style="width: {{item.percent}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 课堂反馈 -->
    <view class="section-header mt-40 feedback-header">
      <text class="section-title-large">课堂反馈</text>
      <text
        class="section-link"
        wx:if="{{stats.feedback_total > (stats.feedback ? stats.feedback.length : 0)}}"
        bindtap="viewAllFeedback"
      >
        查看全部
      </text>
    </view>
    <view class="feedback-list">
      <block wx:if="{{stats.feedback && stats.feedback.length > 0}}">
        <view class="feedback-card" wx:for="{{stats.feedback}}" wx:key="id">
          <view class="feedback-head">
            <text class="feedback-course">{{item.course_name || '课堂反馈'}}</text>
            <text class="feedback-date">{{item.schedule_date || ''}}</text>
          </view>
          <text class="feedback-time">{{item.start_time || ''}}{{item.end_time ? (' - ' + item.end_time) : ''}}</text>
          <text class="feedback-teacher">老师 {{item.teacher_name || '—'}}</text>
          <text class="feedback-text">{{item.feedback_text}}</text>
          <image
            wx:if="{{item.feedback_image}}"
            class="feedback-image"
            src="{{baseUrl}}{{item.feedback_image}}"
            mode="aspectFill"
          ></image>
        </view>
      </block>
      <view wx:else class="empty-feed">
        暂无课堂反馈
      </view>
    </view>

    <!-- 最近动态 -->
    <view class="section-header mt-40">
      <text class="section-title-large">最近动态</text>
    </view>
    <view class="feed-list">
      <block wx:if="{{stats.recent.length > 0}}">
        <view class="feed-item" wx:for="{{stats.recent}}" wx:key="id">
          <view class="feed-left">
            <view class="feed-line"></view>
            <view class="feed-dot {{item.status === 'done' ? 'dot-green' : 'dot-blue'}}"></view>
          </view>
          <view class="feed-right" data-task-id="{{item.id}}" bindtap="viewTaskDetail" hover-class="feed-right-pressed">
            <view class="feed-header">
              <text class="feed-cat">{{item.category}}</text>
              <text class="feed-date">{{item.date}}</text>
            </view>
            <view class="feed-content">
              <text class="feed-detail">{{item.detail}}</text>
            </view>
            <view class="feed-footer">
              <view class="feed-result-summary" wx:if="{{item.result_summary}}">{{item.result_summary}}</view>
              <view class="feed-score" wx:if="{{item.accuracy !== null}}">
                正确率 <text class="highlight">{{item.accuracy}}%</text>
              </view>
              <view class="feed-score" wx:elif="{{item.completion_rate !== null}}">
                完成率 <text class="highlight">{{item.completion_rate}}%</text>
              </view>
              <view class="feed-teacher-note" wx:if="{{item.teacher_note}}">
                <text class="note-icon">👩‍🏫</text> {{item.teacher_note}}
              </view>
              <view class="feed-detail-link">查看题目与批改</view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-feed">
        暂无最近动态
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <image class="empty-img" src="/images/empty.png" mode="widthFix" wx:if="{{false}}"></image>
      <text>未绑定任何学生，请联系管理员。</text>
    </view>
  </block>
</view>
