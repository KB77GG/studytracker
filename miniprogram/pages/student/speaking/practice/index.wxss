.practice-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 30rpx;
  box-sizing: border-box;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.book-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  max-width: 55%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-info {
  font-size: 28rpx;
  font-weight: bold;
  color: #20756F;
  background: rgba(54, 165, 157, 0.12);
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.timer-pill {
  padding: 6rpx 16rpx;
  background: #EAF6F4;
  color: #20756F;
  border-radius: 30rpx;
  font-weight: 600;
  font-size: 24rpx;
}

/* Card */
.word-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
}

.word-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #36A59D, #20756F);
}

/* Play Button */
.play-btn {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #36A59D 0%, #20756F 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(32, 117, 111, 0.3);
  transition: all 0.2s ease;
}

.play-btn:active {
  transform: scale(0.95);
}

.play-btn.loading {
  opacity: 0.6;
}

.play-icon {
  width: 0;
  height: 0;
  border-top: 25rpx solid transparent;
  border-bottom: 25rpx solid transparent;
  border-left: 45rpx solid #fff;
  margin-left: 10rpx;
}

.play-hint {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 30rpx;
}

/* Translation */
.translation-area {
  width: 100%;
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.translation-text {
  font-size: 30rpx;
  color: #606266;
  line-height: 1.6;
}

/* Revealed phrase */
.reveal-area {
  width: 100%;
  text-align: center;
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #EAF6F4;
  border-radius: 16rpx;
  border: 2rpx solid #c8e8e3;
  animation: fadeIn 0.3s ease;
}

.phrase-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1.6;
  letter-spacing: 1rpx;
}

/* Reveal button */
.reveal-btn {
  background: #EAF6F4 !important;
  color: #20756F !important;
  border: 2rpx dashed #20756F !important;
  border-radius: 16rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

/* Recording */
.record-controls {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
  justify-content: center;
}

.record-btn {
  background: #fff !important;
  border: 2rpx solid #dcdfe6 !important;
  color: #606266 !important;
  border-radius: 999rpx;
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.record-btn.recording {
  background: #FEF0F0 !important;
  border-color: #F56C6C !important;
  color: #F56C6C !important;
}

.playback-btn {
  background: #EAF6F4 !important;
  border: 2rpx solid #20756F !important;
  color: #20756F !important;
  border-radius: 999rpx;
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

/* Navigation */
.nav-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.nav-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff !important;
  border: 2rpx solid #dcdfe6 !important;
  color: #606266 !important;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.nav-btn.primary {
  background: linear-gradient(135deg, #36A59D 0%, #20756F 100%) !important;
  border: none !important;
  color: #fff !important;
  box-shadow: 0 8rpx 20rpx rgba(32, 117, 111, 0.18);
}

.nav-btn[disabled] {
  opacity: 0.4;
}

/* Summary */
.summary-panel {
  margin-top: 60rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.summary-icon {
  font-size: 80rpx;
  color: #67C23A;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.summary-row {
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 10rpx;
}

.submit-btn {
  width: 70%;
  height: 88rpx;
  background: linear-gradient(135deg, #36A59D 0%, #20756F 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(32, 117, 111, 0.18);
  margin: 0 auto;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
