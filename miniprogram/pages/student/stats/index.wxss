.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx calc(60px + 72rpx + constant(safe-area-inset-bottom));
  padding: 28rpx 28rpx calc(60px + 72rpx + env(safe-area-inset-bottom));
  background: #f7f8f6;
  color: #1c1c1c;
}

.guest-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #d9ece9;
  border-radius: 24rpx;
  background: #fff;
}

.guest-text {
  flex: 1;
  color: #555;
  font-size: 24rpx;
  line-height: 1.5;
}

.guest-login-btn {
  flex-shrink: 0;
  padding: 9rpx 28rpx;
  border-radius: 999rpx;
  background: #237069;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 10rpx 12rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #2e8b87;
  color: #fff;
  font-size: 48rpx;
  font-weight: 900;
}

.profile-main {
  min-width: 0;
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.username {
  max-width: 380rpx;
  overflow: hidden;
  color: #1c1c1c;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level {
  flex-shrink: 0;
  padding: 5rpx 18rpx;
  border-radius: 999rpx;
  background: #e6f2f1;
  color: #237069;
  font-size: 22rpx;
  font-weight: 800;
}

.profile-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #888;
  font-size: 25rpx;
  line-height: 1.5;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin: 32rpx 0;
}

.stat-card {
  min-width: 0;
  padding: 26rpx 8rpx;
  border-radius: 28rpx;
  text-align: center;
}

.stat-card.streak {
  background: #fbf4e8;
}

.stat-card.practice {
  background: #e6f2f1;
}

.stat-card.accuracy {
  background: #f2f3f1;
}

.value {
  color: #1c1c1c;
  font-family: "DIN Alternate", "Avenir Next", sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-card.streak .value {
  color: #e0892b;
}

.stat-card.practice .value {
  color: #237069;
}

.value.small {
  font-size: 42rpx;
}

.label {
  margin-top: 10rpx;
  color: #999;
  font-size: 21rpx;
  line-height: 1.25;
}

.stat-card.streak .label {
  color: #9a7b3e;
}

.stat-card.practice .label {
  color: #3a7b6e;
}

.section {
  padding: 30rpx 34rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid #efefed;
  border-radius: 32rpx;
  background: #fff;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  color: #1c1c1c;
  font-size: 28rpx;
  font-weight: 900;
}

.section-unit {
  flex-shrink: 0;
  color: #999;
  font-size: 23rpx;
}

.chart-container {
  height: 192rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 28rpx;
}

.bar-group {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  height: 100%;
}

.bar-wrapper {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 100%;
  min-height: 18rpx;
  border-radius: 10rpx;
  background: #bfe0dd;
  transition: height 0.35s ease;
}

.bar.active {
  background: #2e8b87;
}

.day-label {
  color: #aaa;
  font-size: 20rpx;
  line-height: 1;
}

.day-label.active {
  color: #237069;
  font-weight: 800;
}

.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 28rpx;
}

.badge-item {
  min-width: 0;
  text-align: center;
}

.badge-icon {
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  border-radius: 32rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.badge-item.unlocked .badge-icon {
  background: #e6f2f1;
  color: #237069;
}

.badge-item.locked {
  opacity: 0.46;
}

.badge-item.locked .badge-icon {
  background: #f2f3f1;
  color: #9aa0a6;
}

.badge-name {
  display: block;
  margin-top: 12rpx;
  color: #1c1c1c;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.35;
}

.badge-item.locked .badge-name {
  color: #999;
  font-weight: 600;
}

.unlock-tip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 28rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: #fbf4e8;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 3rpx solid #e0892b;
  color: #e0892b;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.tip-text {
  color: #9a7b3e;
  font-size: 24rpx;
  line-height: 1.45;
}

.logout-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 44rpx;
  padding: 0 10rpx;
}

.btn-unbind,
.btn-logout {
  border-radius: 999rpx;
  background: #fff;
  font-size: 28rpx;
}

.btn-unbind::after,
.btn-logout::after {
  border: none;
}

.btn-unbind {
  border: 1rpx solid #e0892b;
  color: #e0892b;
}

.btn-logout {
  border: 1rpx solid #ff4d4f;
  color: #ff4d4f;
}

@media (max-width: 340px) {
  .username {
    max-width: 300rpx;
    font-size: 34rpx;
  }

  .value {
    font-size: 42rpx;
  }
}
