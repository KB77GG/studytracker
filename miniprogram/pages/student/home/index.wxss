page {
  background: #f4f8f8;
}

.container {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
  color: #0b1830;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(8, 127, 119, 0.18), transparent 360rpx),
    linear-gradient(135deg, #e5f5f2 0%, #fbfffd 62%, #fff4dc 100%);
  z-index: 0;
}

.guest-banner {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 24rpx 0;
  padding: 18rpx 22rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #d9ece9;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(8, 127, 119, 0.08);
}

.guest-text {
  flex: 1;
  color: #52637a;
  font-size: 24rpx;
  line-height: 1.5;
}

.guest-login-btn {
  min-width: 96rpx;
  min-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #087f77;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
  padding: 54rpx 24rpx 156rpx;
}

.header-section {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.greeting {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.date {
  color: #64748b;
  font-size: 25rpx;
  margin-bottom: 8rpx;
}

.hello {
  color: #0b1830;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.2;
  word-break: break-word;
}

.header-actions {
  flex-shrink: 0;
}

.sub-btn {
  min-width: 132rpx;
  height: 64rpx;
  line-height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d6e9e6;
  background: rgba(255, 255, 255, 0.88);
  color: #087f77;
  font-size: 23rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(8, 127, 119, 0.08);
}

.sub-btn::after {
  border: none;
}

.progress-card {
  padding: 30rpx;
  margin-bottom: 22rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #e4edf0;
  box-shadow: 0 18rpx 44rpx rgba(20, 44, 58, 0.08);
}

.progress-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 20rpx;
}

.progress-label {
  display: block;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.progress-value {
  display: block;
  color: #0b1830;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
}

.streak-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: #d97706;
  background: #fff2dd;
  flex-shrink: 0;
}

.streak-num {
  font-size: 40rpx;
  font-weight: 900;
}

.streak-label {
  font-size: 22rpx;
  font-weight: 800;
}

.progress-bar-bg {
  height: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9eff2;
  margin-bottom: 14rpx;
}

.progress-bar-fill {
  height: 100%;
  min-width: 0;
  border-radius: inherit;
  background: linear-gradient(90deg, #087f77, #58c7bb);
  transition: width 0.3s ease;
}

.progress-tips {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.55;
}

.review-entry {
  min-height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 28rpx;
  border-radius: 32rpx;
  color: #fff;
  background:
    radial-gradient(circle at right top, rgba(255, 255, 255, 0.18), transparent 42%),
    linear-gradient(135deg, #083f42, #007c75);
  box-shadow: 0 18rpx 36rpx rgba(0, 105, 98, 0.22);
}

.review-title {
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.review-desc {
  color: #c5ece8;
  font-size: 23rpx;
}

.review-stats {
  display: flex;
  align-items: center;
  gap: 22rpx;
  flex-shrink: 0;
}

.review-num {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.review-label {
  display: block;
  margin-top: 6rpx;
  color: #c5ece8;
  font-size: 21rpx;
}

.review-arrow {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #087f77;
  background: rgba(255, 255, 255, 0.92);
  font-size: 38rpx;
  font-weight: 800;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 4rpx 18rpx;
}

.section-title {
  color: #0b1830;
  font-size: 32rpx;
  font-weight: 900;
}

.section-link {
  min-height: 44rpx;
  display: flex;
  align-items: center;
  color: #087f77;
  font-size: 24rpx;
  font-weight: 800;
}

.date-strip {
  white-space: nowrap;
  margin-bottom: 18rpx;
  padding-bottom: 8rpx;
}

.date-chip {
  width: 122rpx;
  height: 92rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  border-radius: 24rpx;
  border: 1rpx solid #e4edf0;
  background: rgba(255, 255, 255, 0.94);
  color: #52637a;
  box-shadow: 0 8rpx 20rpx rgba(20, 44, 58, 0.04);
}

.date-chip.active {
  color: #fff;
  background: linear-gradient(180deg, #16aa9e, #007d76);
  border-color: transparent;
  box-shadow: 0 12rpx 26rpx rgba(8, 127, 119, 0.24);
}

.date-main {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.1;
}

.date-sub {
  margin-top: 8rpx;
  font-size: 21rpx;
  font-weight: 750;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #e5edf0;
  box-shadow: 0 10rpx 26rpx rgba(20, 44, 58, 0.06);
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.task-card:active {
  transform: scale(0.985);
}

.task-card.done {
  opacity: 0.82;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.card-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
}

.task-icon {
  width: 78rpx;
  height: 78rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #087f77;
  background: #e8f7f4;
  font-size: 28rpx;
  font-weight: 900;
}

.task-icon.listening,
.task-icon.speaking {
  color: #087f77;
  background: #e8f7f4;
}

.task-icon.reading {
  color: #1d7fe5;
  background: #eaf4ff;
}

.task-icon.writing,
.task-icon.vocab {
  color: #d97706;
  background: #fff2dd;
}

.task-content {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.task-name {
  color: #0b1830;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-time {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
}

.card-right {
  flex-shrink: 0;
}

.status-badge {
  min-height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
  white-space: nowrap;
}

.status-badge.pending {
  color: #b46100;
  background: #fff2dd;
}

.status-badge.in_progress {
  color: #1669b8;
  background: #eaf4ff;
}

.status-badge.submitted {
  color: #a16207;
  background: #fef3c7;
}

.status-badge.completed,
.status-badge.approved {
  color: #087a47;
  background: #e8f8ef;
}

.status-badge.rejected {
  color: #b91c1c;
  background: #fee2e2;
}

.timer-section {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f4;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.timer-display {
  flex-shrink: 0;
}

.timer-text {
  color: #087f77;
  font-size: 24rpx;
  font-weight: 850;
  font-family: "SF Mono", Menlo, Consolas, monospace;
}

.timer-text.overtime {
  color: #d97706;
}

.timer-controls {
  flex: 1;
  display: flex;
  gap: 12rpx;
  position: relative;
  z-index: 3;
}

.timer-btn {
  flex: 1;
  min-width: 92rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 850;
}

.timer-btn.start,
.timer-btn.resume {
  color: #fff;
  background: linear-gradient(135deg, #18a99e, #007d76);
}

.timer-btn.pause {
  color: #087f77;
  background: #e8f7f4;
}

.timer-btn.stop {
  color: #b91c1c;
  background: #fee2e2;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 0 120rpx;
}

.empty-text {
  color: #0b1830;
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.empty-sub {
  color: #64748b;
  font-size: 25rpx;
}

@media (max-width: 340px) {
  .hello {
    font-size: 38rpx;
  }

  .progress-value {
    font-size: 34rpx;
  }

  .timer-section {
    align-items: stretch;
    flex-direction: column;
  }
}
