<view class="container">
  <view class="page-bg"></view>

  <view class="guest-banner" wx:if="{{isGuest}}">
    <text class="guest-text">访客模式浏览中 · 登录解锁全部功能</text>
    <view class="guest-login-btn" bindtap="goLogin">登录</view>
  </view>

  <scroll-view scroll-y class="page-scroll" enhanced="true" show-scrollbar="false">
    <view class="header-section">
      <view class="greeting">
        <text class="date">{{dateStr}} 星期{{weekdayText}}</text>
        <text class="hello">{{greeting}}，{{userInfo.nickName}}</text>
      </view>
      <view class="header-actions">
        <button class="sub-btn" size="mini" bindtap="requestSubscribe">{{subscribeButtonText}}</button>
      </view>
    </view>

    <view class="progress-card">
      <view class="progress-top">
        <view>
          <text class="progress-label">今日完成度</text>
          <text class="progress-value">{{progress.completed}} / {{progress.total}} 项任务</text>
        </view>
        <view class="streak-box">
          <text class="streak-num">{{progress.percent || 0}}</text>
          <text class="streak-label">%</text>
        </view>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{progress.percent}}%"></view>
      </view>
      <text class="progress-tips" wx:if="{{progress.percent === 100}}">今日任务已完成，记得回顾错词和老师反馈。</text>
      <text class="progress-tips" wx:elif="{{progress.percent > 0}}">保持这个节奏，完成剩余任务即可收尾。</text>
      <text class="progress-tips" wx:else>先从一个任务开始，进入学习状态。</text>
    </view>

    <view class="review-entry" bindtap="goNotebook">
      <view>
        <view class="review-title">复习中心</view>
        <view class="review-desc">错题错词，集中攻克</view>
      </view>
      <view class="review-stats">
        <view>
          <text class="review-num">{{notebookCount}}</text>
          <text class="review-label">错词</text>
        </view>
        <view>
          <text class="review-num">{{reviewTaskCount}}</text>
          <text class="review-label">待复盘</text>
        </view>
        <text class="review-arrow">›</text>
      </view>
    </view>

    <view class="section-title-row">
      <text class="section-title">我的任务</text>
      <picker mode="date" value="{{currentDate}}" bindchange="handleDateChange">
        <view class="section-link">切换日期</view>
      </picker>
    </view>

    <scroll-view scroll-x class="date-strip" enhanced="true" show-scrollbar="false">
      <view
        class="date-chip {{item.date === currentDate ? 'active' : ''}}"
        wx:for="{{quickDates}}"
        wx:key="date"
        data-date="{{item.date}}"
        bindtap="selectQuickDate"
      >
        <text class="date-main">{{item.label}}</text>
        <text class="date-sub">{{item.sub}}</text>
      </view>
    </scroll-view>

    <view class="task-list" wx:if="{{tasks.length > 0}}">
      <view class="task-card {{item.isDone ? 'done' : ''}}" wx:for="{{tasks}}" wx:key="id">
        <view class="card-main" bindtap="goToTaskDetail" data-id="{{item.id}}">
          <view class="card-left">
            <view class="task-icon {{item.iconClass}}">{{item.iconText}}</view>
            <view class="task-content">
              <text class="task-name">{{item.task_name}}</text>
              <text class="task-time">预计 {{item.planned_minutes}} 分钟</text>
            </view>
          </view>
          <view class="card-right">
            <view class="status-badge {{item.status}}">{{item.statusText}}</view>
          </view>
        </view>

        <view class="timer-section" wx:if="{{!item.isDone}}">
          <view class="timer-display {{item.timerStatus}}">
            <text class="timer-text {{item.isOvertime ? 'overtime' : ''}}">{{item.displayTime}} / {{item.plannedTime}}</text>
          </view>
          <view class="timer-controls">
            <view wx:if="{{item.timerStatus === 'idle'}}" class="timer-btn start" catchtap="startTimer" data-id="{{item.id}}">开始</view>
            <view wx:if="{{item.timerStatus === 'running'}}" class="timer-btn pause" catchtap="pauseTimer" data-id="{{item.id}}">暂停</view>
            <view wx:if="{{item.timerStatus === 'paused'}}" class="timer-btn resume" catchtap="resumeTimer" data-id="{{item.id}}">继续</view>
            <view wx:if="{{item.timerStatus === 'running' || item.timerStatus === 'paused'}}" class="timer-btn stop" catchtap="stopTimer" data-id="{{item.id}}">结束</view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-text">今天没有任务</text>
      <text class="empty-sub">好好休息，明天继续保持。</text>
    </view>
  </scroll-view>
</view>
