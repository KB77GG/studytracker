<view class="page">
  <view class="page-header">
    <view class="title">未完成作业</view>
    <view class="subtitle">仅展示过去 {{windowDays}} 天还没完成的作业，更早的不再提醒</view>
  </view>

  <view class="task-list" wx:if="{{tasks.length > 0}}">
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="date-header" wx:if="{{item.showDateHeader}}">
        <text class="date-title">{{item.dateHeaderLabel}}</text>
      </view>
      <view class="task-card" bindtap="goTask" data-date="{{item.date}}">
        <view class="task-icon">{{item.iconText}}</view>
        <view class="task-body">
          <text class="task-name">{{item.task_name}}</text>
          <view class="task-sub">
            <text class="assigner-tag assistant" wx:if="{{item.assignedByLabel}}">{{item.assignedByLabel}}</text>
            <text class="task-time">预计 {{item.planned_minutes}} 分钟</text>
          </view>
        </view>
        <view class="task-right">
          <view class="status-badge">{{item.statusText}}</view>
          <text class="go-arrow">去完成 ›</text>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-state" wx:elif="{{!loading}}">
    <text class="empty-text" wx:if="{{isGuest}}">演示模式暂不展示个人未完成作业</text>
    <text class="empty-text" wx:else>太棒了，最近没有遗留的未完成作业</text>
    <text class="empty-sub" wx:if="{{!isGuest}}">保持节奏，继续完成今天的任务吧。</text>
  </view>
</view>
