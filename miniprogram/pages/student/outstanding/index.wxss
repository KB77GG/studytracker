.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 60rpx;
  background: #f3f7f8;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 18rpx;
}

.title {
  color: #0b1830;
  font-size: 38rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-header {
  margin: 16rpx 4rpx 2rpx;
}

.date-header:first-child {
  margin-top: 0;
}

.date-title {
  color: #334155;
  font-size: 25rpx;
  font-weight: 850;
}

.task-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #e5edf0;
  box-shadow: 0 10rpx 26rpx rgba(20, 44, 58, 0.06);
}

.task-card:active {
  transform: scale(0.985);
}

.task-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #087f77;
  background: #e8f7f4;
  font-size: 28rpx;
  font-weight: 900;
}

.task-body {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.task-name {
  color: #0b1830;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-sub {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-time {
  color: #64748b;
  font-size: 23rpx;
}

.assigner-tag {
  flex-shrink: 0;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 750;
  line-height: 1.6;
}

.assigner-tag.assistant {
  color: #1d6fe0;
  background: #e7f0ff;
}

.task-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #fdecd5;
  color: #b46100;
  font-size: 22rpx;
  font-weight: 750;
}

.go-arrow {
  color: #087f77;
  font-size: 22rpx;
  font-weight: 800;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 0;
}

.empty-text {
  color: #0b1830;
  font-size: 30rpx;
  font-weight: 850;
  margin-bottom: 10rpx;
}

.empty-sub {
  color: #64748b;
  font-size: 24rpx;
}
