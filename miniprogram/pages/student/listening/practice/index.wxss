/* ─────────────────────────────────────────
   全局 & 页面
───────────────────────────────────────── */
page {
  background: #f3eee6;
}

.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 0 0, rgba(47, 142, 135, 0.12), transparent 520rpx),
    linear-gradient(160deg, #f7f1e8 0%, #f3eee6 58%, #ece5da 100%);
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
  color: #25211c;
}

/* ─────────────────────────────────────────
   加载状态
───────────────────────────────────────── */
.loading-state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
}

.loading-ring {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 6rpx solid #e3d9cb;
  border-top-color: #2f8e87;
}

.loading-text {
  font-size: 28rpx;
  color: #746b60;
}

/* ─────────────────────────────────────────
   任务概览卡片
───────────────────────────────────────── */
.summary-card {
  background: #fffdf8;
  border: 2rpx solid rgba(207, 194, 177, 0.74);
  border-radius: 24rpx;
  padding: 32rpx 28rpx 24rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 18rpx 44rpx rgba(62, 50, 34, 0.08);
}

.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.summary-info {
  flex: 1;
  min-width: 0;
}

.summary-label {
  font-size: 22rpx;
  color: #8b8278;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 0;
  font-weight: 600;
}

.summary-title {
  font-size: 33rpx;
  font-weight: 750;
  color: #25211c;
  line-height: 1.35;
  display: block;
}

.status-badge {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-badge.progress {
  color: #267873;
  background: #e1f3ef;
}

.status-badge.done {
  color: #2f8a5f;
  background: #e6f4eb;
}

/* 进度条 */
.progress-track {
  height: 16rpx;
  background:
    repeating-linear-gradient(90deg, rgba(91, 110, 225, 0.12) 0 4rpx, transparent 4rpx 16rpx),
    #f6f0e7;
  border: 2rpx solid #e3d9cb;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  position: relative;
  overflow: visible;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f8e87 0%, #5b6ee1 100%);
  min-width: 0;
  transition: width 0.4s ease;
}

.progress-label {
  font-size: 20rpx;
  color: #746b60;
  font-weight: 700;
  display: block;
  text-align: right;
  margin-bottom: 18rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 44rpx;
  background: #e3d9cb;
}

.stat-val {
  font-size: 30rpx;
  font-weight: 750;
  color: #25211c;
  line-height: 1;
}

.stat-total,
.stat-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #8b8278;
}

.stat-key {
  font-size: 20rpx;
  color: #8b8278;
}

/* ─────────────────────────────────────────
   句子选择条
───────────────────────────────────────── */
.segment-strip {
  white-space: nowrap;
  margin-bottom: 22rpx;
  padding: 6rpx 0 10rpx;
}

.seg-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 82rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 248, 0.88);
  color: #746b60;
  border: 2rpx solid rgba(227, 217, 203, 0.88);
  box-shadow: 0 4rpx 14rpx rgba(62, 50, 34, 0.05);
  transition: all 0.2s;
}

.seg-chip.seg-active {
  background: linear-gradient(135deg, rgba(47, 142, 135, 0.16), rgba(91, 110, 225, 0.14));
  border-color: rgba(47, 142, 135, 0.6);
  color: #25211c;
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.6), 0 6rpx 20rpx rgba(47, 142, 135, 0.16);
  transform: translateY(-3rpx);
}

.seg-chip.seg-done {
  background: #e6f4eb;
  color: #2f8a5f;
  border-color: #cfe6d7;
}

.seg-chip.seg-done.seg-active {
  border-color: #2f8a5f;
  box-shadow: 0 6rpx 20rpx rgba(47, 138, 95, 0.18);
}

.seg-num {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.seg-sub {
  font-size: 18rpx;
  margin-top: 6rpx;
  line-height: 1;
  opacity: 0.76;
}

/* ─────────────────────────────────────────
   播放器主卡片
───────────────────────────────────────── */
.player-card {
  background: #fffdf8;
  border: 2rpx solid rgba(207, 194, 177, 0.74);
  border-radius: 24rpx;
  padding: 30rpx 24rpx 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(62, 50, 34, 0.08);
}

/* 顶部信息行 */
.player-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sentence-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.part-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fbf3df;
  color: #7b5519;
  font-size: 22rpx;
  font-weight: 700;
}

.sentence-pos {
  font-size: 26rpx;
  color: #746b60;
  font-weight: 600;
}

.speed-pill {
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  background: #f6f0e7;
  color: #25211c;
  border: 2rpx solid #e3d9cb;
  font-size: 24rpx;
  font-weight: 700;
}

/* 模式标签 */
.mode-tabs {
  display: flex;
  background: #f6f0e7;
  border: 2rpx solid #e3d9cb;
  border-radius: 999rpx;
  padding: 6rpx;
  gap: 0;
  margin-bottom: 28rpx;
}

.mode-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 10rpx;
  border-radius: 999rpx;
  gap: 0;
  transition: all 0.2s;
}

.mode-tab.mode-active {
  background: #fffdf8;
  box-shadow: 0 2rpx 8rpx rgba(35, 29, 22, 0.08);
}

.mode-label {
  font-size: 23rpx;
  color: #746b60;
  font-weight: 650;
}

.mode-tab.mode-active .mode-label {
  color: #267873;
  font-weight: 750;
}

/* 音频控制 */
.audio-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.ctrl-play {
  width: 112rpx;
  height: 82rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2f8e87 0%, #5b6ee1 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(91, 110, 225, 0.24);
  flex-shrink: 0;
}

.ctrl-play::after {
  border: none;
}

.play-icon {
  font-size: 36rpx;
  line-height: 1;
}

.ctrl-ghost {
  flex: 1;
  max-width: 160rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #fffaf2;
  color: #342d25;
  font-size: 24rpx;
  padding: 0;
  border: 2rpx solid #e3d9cb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  box-shadow: 0 2rpx 6rpx rgba(35, 29, 22, 0.06);
}

.ctrl-ghost::after {
  border: none;
}

.time-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 26rpx;
}

.time-text {
  font-size: 23rpx;
  color: #746b60;
  font-weight: 650;
  font-feature-settings: 'tnum';
}

/* ─────────────────────────────────────────
   模式内容区
───────────────────────────────────────── */
.mode-content {
  border-top: 2rpx solid #e3d9cb;
  padding-top: 28rpx;
}

/* 开关行 */
.toggle-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.toggle-btn {
  padding: 13rpx 22rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #746b60;
  background: #fffaf2;
  border: 2rpx solid #e3d9cb;
  font-weight: 650;
}

.toggle-btn.tog-active {
  background: #e1f3ef;
  color: #267873;
  border-color: rgba(47, 142, 135, 0.38);
}

/* 文本展示卡 */
.text-card {
  background: #fffaf2;
  border: 2rpx solid #e3d9cb;
  border-radius: 20rpx;
  padding: 28rpx 26rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #8b8278;
  line-height: 1.8;
}

.original-text {
  display: block;
  font-size: 31rpx;
  color: #2c261f;
  line-height: 1.85;
  font-weight: 500;
}

.translation-text {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #746b60;
  line-height: 1.75;
}

/* ─ 听写模式 ─ */
.difficulty-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.section-label {
  font-size: 24rpx;
  color: #746b60;
  font-weight: 700;
  flex-shrink: 0;
}

.pill-group {
  display: flex;
  gap: 12rpx;
}

.option-pill {
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #746b60;
  background: #fffaf2;
  border: 2rpx solid #e3d9cb;
  font-weight: 650;
}

.option-pill.pill-active {
  background: #e1f3ef;
  color: #267873;
  border-color: rgba(47, 142, 135, 0.38);
  font-weight: 750;
}

.dictation-box {
  background: #fffaf2;
  border: 2rpx solid #e3d9cb;
  border-radius: 20rpx;
  padding: 34rpx 24rpx 32rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: 14rpx 10rpx;
  margin-bottom: 18rpx;
  min-height: 148rpx;
}

.plain-word {
  font-size: 30rpx;
  color: #2c261f;
  line-height: 1.8;
}

.blank-wrap {
  display: inline-flex;
  align-items: flex-end;
  gap: 4rpx;
}

.blank-input {
  min-height: 60rpx;
  padding: 0 10rpx 4rpx;
  border-radius: 0;
  background: linear-gradient(180deg, transparent 62%, rgba(91, 110, 225, 0.08) 0);
  border: none;
  border-bottom: 4rpx solid #cfc2b1;
  font-size: 28rpx;
  color: #5b6ee1;
  text-align: center;
  font-weight: 700;
}

.blank-input.correct {
  border-bottom-color: #2f8a5f;
  background: linear-gradient(180deg, transparent 62%, rgba(47, 138, 95, 0.1) 0);
  color: #2f8a5f;
}

.blank-input.wrong {
  border-bottom-color: #c34a3e;
  background: linear-gradient(180deg, transparent 62%, rgba(195, 74, 62, 0.1) 0);
  color: #c34a3e;
}

.blank-suffix {
  font-size: 28rpx;
  color: #746b60;
}

.side-translation {
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

/* 结果横幅 */
.result-banner {
  background: linear-gradient(135deg, #e1f3ef 0%, #e7e9fb 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(47, 142, 135, 0.18);
}

.result-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.result-score {
  font-size: 56rpx;
  font-weight: 800;
  color: #267873;
  line-height: 1;
  flex-shrink: 0;
}

.result-unit {
  font-size: 28rpx;
  font-weight: 600;
}

.result-detail {
  flex: 1;
}

.result-main {
  display: block;
  font-size: 26rpx;
  color: #25211c;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.result-sub {
  display: block;
  font-size: 22rpx;
  color: #746b60;
}

/* 操作行 */
.action-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 4rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

.action-btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #2f8e87 0%, #5b6ee1 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(91, 110, 225, 0.22);
}

.btn-ghost {
  background: #fffaf2;
  color: #342d25;
  border: 2rpx solid #e3d9cb;
}

/* ─ 跟读模式 ─ */
.repeat-text-card {
  background: #fffaf2;
  border: 2rpx solid #e3d9cb;
  border-radius: 20rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.threshold-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 4rpx;
}

.threshold-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #267873;
  background: #e1f3ef;
  font-weight: 600;
}

.repeat-hint {
  font-size: 22rpx;
  color: #8b8278;
}

/* 录音区 */
.record-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.record-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #fffaf2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0;
  border: 6rpx solid #e3d9cb;
  box-shadow: 0 8rpx 28rpx rgba(62, 50, 34, 0.10);
  transition: all 0.2s;
}

.record-btn::after {
  border: none;
}

.record-btn.recording {
  background: #fff0ed;
  border-color: #c34a3e;
  box-shadow: 0 8rpx 30rpx rgba(195, 74, 62, 0.22);
}

.record-btn.recorded {
  background: #e6f4eb;
  border-color: #2f8a5f;
  box-shadow: 0 8rpx 28rpx rgba(47, 138, 95, 0.18);
}

.record-icon {
  font-size: 52rpx;
  line-height: 1;
  color: #746b60;
}

.recording .record-icon {
  color: #c34a3e;
}

.recorded .record-icon {
  color: #2f8a5f;
}

.record-label {
  font-size: 22rpx;
  color: #746b60;
  font-weight: 600;
}

.recording .record-label {
  color: #c34a3e;
}

.recorded .record-label {
  color: #2f8a5f;
}

.record-actions {
  display: flex;
  gap: 16rpx;
}

.ready-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: center;
  margin-bottom: 20rpx;
}

.ready-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #2f8a5f;
  display: block;
}

.ready-text {
  font-size: 24rpx;
  color: #2f8a5f;
  font-weight: 500;
}

/* 跟读结果 */
.repeat-result {
  margin-top: 24rpx;
  background: #fffaf2;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #e3d9cb;
}

.repeat-verdict {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.repeat-verdict.pass {
  color: #2f8a5f;
}

.repeat-verdict.fail {
  color: #c34a3e;
}

.verdict-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.pass .verdict-icon {
  background: #e6f4eb;
  color: #2f8a5f;
}

.fail .verdict-icon {
  background: #fff0ed;
  color: #c34a3e;
}

.verdict-text {
  font-size: 30rpx;
  font-weight: 700;
}

.score-grid {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.score-cell {
  flex: 1;
  background: #fffdf8;
  border: 2rpx solid rgba(227, 217, 203, 0.82);
  border-radius: 18rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(62, 50, 34, 0.04);
}

.score-big {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #25211c;
  line-height: 1;
  margin-bottom: 8rpx;
}

.score-key {
  font-size: 20rpx;
  color: #8b8278;
}

.issue-section {
  border-top: 2rpx solid #e3d9cb;
  padding-top: 16rpx;
}

.issue-label {
  font-size: 22rpx;
  color: #8b8278;
  display: block;
  margin-bottom: 12rpx;
}

.issue-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.issue-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fbf3df;
  color: #7b5519;
  font-size: 22rpx;
  font-weight: 600;
}

/* ─────────────────────────────────────────
   Final mobile training direction override
   Keeps existing WXML/JS behavior; tightens proportions for the final UI.
───────────────────────────────────────── */
page {
  background: #f4f8f8;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 70rpx;
  color: #0b1830;
  background:
    radial-gradient(circle at 10% 0%, rgba(8, 127, 119, 0.15), transparent 420rpx),
    linear-gradient(135deg, #e8f7f4 0%, #fbfffd 48%, #fff6df 100%);
  box-sizing: border-box;
}

.summary-card,
.player-card,
.text-card,
.dictation-box,
.repeat-text-card,
.repeat-result {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #e5edf0;
  border-radius: 30rpx;
  box-shadow: 0 16rpx 40rpx rgba(20, 44, 58, 0.08);
}

.summary-card {
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 20rpx;
}

.summary-label,
.stat-key,
.progress-label,
.sentence-pos,
.time-text,
.section-label,
.hint-text,
.translation-text,
.repeat-hint,
.score-key,
.issue-label {
  color: #64748b;
}

.summary-title,
.stat-val,
.original-text,
.plain-word,
.result-main,
.score-big,
.verdict-text {
  color: #0b1830;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 900;
}

.status-badge.progress {
  color: #1669b8;
  background: #eaf4ff;
}

.status-badge.done {
  color: #087a47;
  background: #e8f8ef;
}

.progress-track {
  height: 14rpx;
  border: 0;
  background: #e9eff2;
  overflow: hidden;
}

.progress-fill {
  background: linear-gradient(90deg, #087f77, #58c7bb);
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0;
}

.stat-divider {
  display: none;
}

.stat-cell {
  min-width: 0;
  min-height: 96rpx;
  justify-content: center;
  border-right: 1rpx solid #e5edf0;
}

.stat-cell:last-child {
  border-right: 0;
}

.stat-val {
  font-size: 32rpx;
  font-weight: 900;
}

.stat-key {
  font-size: 20rpx;
  text-align: center;
  line-height: 1.35;
}

.segment-strip {
  white-space: nowrap;
  margin-bottom: 18rpx;
  padding: 8rpx 0 12rpx;
}

.seg-chip {
  width: 84rpx;
  height: 78rpx;
  margin-right: 12rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e5edf0;
  background: rgba(255, 255, 255, 0.96);
  color: #52637a;
  box-shadow: 0 8rpx 18rpx rgba(20, 44, 58, 0.05);
}

.seg-chip.seg-active {
  color: #fff;
  background: linear-gradient(180deg, #16aa9e, #007d76);
  border-color: transparent;
  box-shadow: 0 12rpx 26rpx rgba(8, 127, 119, 0.26);
  transform: none;
}

.seg-chip.seg-done {
  color: #087a47;
  background: #e8f8ef;
  border-color: #cdeede;
}

.seg-chip.seg-done.seg-active {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(180deg, #16aa9e, #007d76);
}

.seg-num {
  font-size: 28rpx;
  font-weight: 900;
}

.player-card {
  padding: 26rpx 22rpx 28rpx;
}

.part-tag,
.threshold-chip,
.toggle-btn.tog-active,
.option-pill.pill-active {
  color: #087f77;
  background: #e8f7f4;
  border-color: #cfe9e5;
}

.speed-pill,
.toggle-btn,
.option-pill,
.ctrl-ghost,
.btn-ghost {
  color: #52637a;
  background: #f6faf9;
  border: 1rpx solid #e5edf0;
  border-radius: 18rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 6rpx;
  padding: 8rpx;
  border: 0;
  border-radius: 24rpx;
  background: #edf4f3;
}

.mode-tab {
  min-height: 64rpx;
  padding: 0 8rpx;
  border-radius: 20rpx;
  justify-content: center;
}

.mode-tab.mode-active {
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(20, 44, 58, 0.08);
}

.mode-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 850;
}

.mode-tab.mode-active .mode-label {
  color: #087f77;
}

.audio-controls {
  display: grid;
  grid-template-columns: 1fr 112rpx 1fr 1fr;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.ctrl-play {
  width: 112rpx;
  height: 88rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #18a99e, #007d76);
  box-shadow: 0 14rpx 28rpx rgba(8, 127, 119, 0.28);
}

.ctrl-ghost {
  max-width: none;
  height: 72rpx;
  font-size: 23rpx;
  font-weight: 850;
}

.mode-content {
  border-top: 1rpx solid #e5edf0;
}

.dictation-box {
  min-height: 170rpx;
  padding: 28rpx 22rpx;
  align-items: center;
  gap: 12rpx 8rpx;
}

.plain-word {
  font-size: 30rpx;
  line-height: 1.9;
}

.blank-input {
  min-height: 58rpx;
  padding: 0 10rpx;
  border-radius: 14rpx;
  border: 1rpx dashed #b9d8d4;
  background: #f4fbfa;
  color: #087f77;
  font-size: 28rpx;
  font-weight: 850;
}

.blank-input.correct {
  color: #087a47;
  border-color: #9be6b8;
  background: #e8f8ef;
}

.blank-input.wrong {
  color: #b91c1c;
  border-color: #fecaca;
  background: #fee2e2;
}

.result-banner {
  background: #e8f8ef;
  border: 1rpx solid #cdeede;
}

.result-score {
  color: #087f77;
}

.action-btn {
  min-height: 84rpx;
  height: auto;
  border-radius: 22rpx;
  font-weight: 850;
}

.btn-primary {
  background: linear-gradient(145deg, #18a99e, #007d76);
  box-shadow: 0 10rpx 24rpx rgba(8, 127, 119, 0.22);
}

.record-btn {
  background: #fff;
  border-color: #d7e6e4;
}

.record-btn.recording {
  background: #fee2e2;
  border-color: #fca5a5;
}

.record-btn.recorded {
  background: #e8f8ef;
  border-color: #9be6b8;
}

@media (max-width: 340px) {
  .audio-controls {
    grid-template-columns: 1fr 100rpx 1fr;
  }

  .audio-controls .ctrl-ghost:last-child {
    grid-column: 1 / -1;
    max-width: none;
  }

  .stats-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-cell:nth-child(2) {
    border-right: 0;
  }
}
