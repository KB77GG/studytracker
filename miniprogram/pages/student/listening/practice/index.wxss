/* ─────────────────────────────────────────
   全局 & 页面
───────────────────────────────────────── */
page {
  background: #f0faf9;
}

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #e8f8f6 0%, #f0f4ff 60%, #f8f0ff 100%);
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ─────────────────────────────────────────
   加载状态
───────────────────────────────────────── */
.loading-state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
}

.loading-ring {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 6rpx solid #c8ede9;
  border-top-color: #1d9a8a;
}

.loading-text {
  font-size: 28rpx;
  color: #6b8593;
}

/* ─────────────────────────────────────────
   任务概览卡片
───────────────────────────────────────── */
.summary-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(29, 154, 138, 0.10);
}

.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.summary-info {
  flex: 1;
  min-width: 0;
}

.summary-label {
  font-size: 22rpx;
  color: #8aa0ae;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f2030;
  line-height: 1.35;
  display: block;
}

.status-badge {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.progress {
  color: #0f766e;
  background: #ccfbf1;
}

.status-badge.done {
  color: #15803d;
  background: #dcfce7;
}

/* 进度条 */
.progress-track {
  height: 12rpx;
  background: #e8f0f5;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  position: relative;
  overflow: visible;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1d9a8a 0%, #34d399 100%);
  min-width: 0;
  transition: width 0.4s ease;
}

.progress-label {
  font-size: 20rpx;
  color: #1d9a8a;
  font-weight: 600;
  display: block;
  text-align: right;
  margin-bottom: 18rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 44rpx;
  background: #e8f0f5;
}

.stat-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f2030;
  line-height: 1;
}

.stat-total,
.stat-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #8aa0ae;
}

.stat-key {
  font-size: 20rpx;
  color: #8aa0ae;
}

/* ─────────────────────────────────────────
   句子选择条
───────────────────────────────────────── */
.segment-strip {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 4rpx 0;
}

.seg-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin-right: 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #6b8593;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.seg-chip.seg-active {
  background: #fff;
  border-color: #1d9a8a;
  color: #0f766e;
  box-shadow: 0 4rpx 20rpx rgba(29, 154, 138, 0.22);
  transform: translateY(-3rpx);
}

.seg-chip.seg-done {
  background: #d1fae5;
  color: #065f46;
  border-color: transparent;
}

.seg-chip.seg-done.seg-active {
  border-color: #10b981;
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.25);
}

.seg-num {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.seg-sub {
  font-size: 18rpx;
  margin-top: 6rpx;
  line-height: 1;
}

/* ─────────────────────────────────────────
   播放器主卡片
───────────────────────────────────────── */
.player-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(29, 154, 138, 0.10);
}

/* 顶部信息行 */
.player-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sentence-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.part-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f0fdf4;
  color: #15803d;
  font-size: 22rpx;
  font-weight: 600;
}

.sentence-pos {
  font-size: 26rpx;
  color: #6b8593;
}

.speed-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
}

/* 模式标签 */
.mode-tabs {
  display: flex;
  background: #f1f5f9;
  border-radius: 24rpx;
  padding: 6rpx;
  gap: 0;
  margin-bottom: 28rpx;
}

.mode-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  border-radius: 18rpx;
  gap: 6rpx;
  transition: all 0.2s;
}

.mode-tab.mode-active {
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.mode-icon {
  font-size: 36rpx;
  line-height: 1;
}

.mode-label {
  font-size: 22rpx;
  color: #6b8593;
  font-weight: 500;
}

.mode-tab.mode-active .mode-label {
  color: #1d9a8a;
  font-weight: 700;
}

/* 音频控制 */
.audio-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ctrl-play {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1d9a8a 0%, #0f766e 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(29, 154, 138, 0.38);
  flex-shrink: 0;
}

.ctrl-play::after {
  border: none;
}

.play-icon {
  font-size: 42rpx;
  line-height: 1;
}

.ctrl-ghost {
  flex: 1;
  max-width: 160rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  color: #344e60;
  font-size: 24rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-ghost::after {
  border: none;
}

.time-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.time-text {
  font-size: 24rpx;
  color: #8aa0ae;
  font-weight: 500;
  font-feature-settings: 'tnum';
}

/* ─────────────────────────────────────────
   模式内容区
───────────────────────────────────────── */
.mode-content {
  border-top: 2rpx solid #f1f5f9;
  padding-top: 24rpx;
}

/* 开关行 */
.toggle-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.toggle-btn {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #6b8593;
  background: #f1f5f9;
  font-weight: 500;
}

.toggle-btn.tog-active {
  background: #ccfbf1;
  color: #0f766e;
}

/* 文本展示卡 */
.text-card {
  background: #f8fcfb;
  border-radius: 24rpx;
  padding: 24rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #94a3b8;
  line-height: 1.8;
}

.original-text {
  display: block;
  font-size: 30rpx;
  color: #0f2030;
  line-height: 1.85;
  font-weight: 500;
}

.translation-text {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #4e6a7e;
  line-height: 1.75;
}

/* ─ 听写模式 ─ */
.difficulty-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: #6b8593;
  font-weight: 500;
  flex-shrink: 0;
}

.pill-group {
  display: flex;
  gap: 12rpx;
}

.option-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #6b8593;
  background: #f1f5f9;
  font-weight: 500;
}

.option-pill.pill-active {
  background: #ccfbf1;
  color: #0f766e;
  font-weight: 700;
}

.dictation-box {
  background: #f8fcfb;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx 8rpx;
  margin-bottom: 16rpx;
  min-height: 96rpx;
}

.plain-word {
  font-size: 30rpx;
  color: #0f2030;
  line-height: 1.8;
}

.blank-wrap {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.blank-input {
  min-height: 68rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #cbd5e1;
  font-size: 28rpx;
  color: #0f2030;
  text-align: center;
}

.blank-input.correct {
  border-color: #10b981;
  background: #f0fdf4;
  color: #065f46;
}

.blank-input.wrong {
  border-color: #f87171;
  background: #fef2f2;
  color: #b91c1c;
}

.blank-suffix {
  font-size: 28rpx;
  color: #4e6a7e;
}

.side-translation {
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

/* 结果横幅 */
.result-banner {
  background: linear-gradient(135deg, #f0fdf4 0%, #f0f9ff 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #a7f3d0;
}

.result-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.result-score {
  font-size: 56rpx;
  font-weight: 800;
  color: #1d9a8a;
  line-height: 1;
  flex-shrink: 0;
}

.result-unit {
  font-size: 28rpx;
  font-weight: 600;
}

.result-detail {
  flex: 1;
}

.result-main {
  display: block;
  font-size: 26rpx;
  color: #0f2030;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.result-sub {
  display: block;
  font-size: 22rpx;
  color: #6b8593;
}

/* 操作行 */
.action-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 4rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

.action-btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #1d9a8a 0%, #0f766e 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(29, 154, 138, 0.30);
}

.btn-ghost {
  background: #f1f5f9;
  color: #344e60;
}

/* ─ 跟读模式 ─ */
.repeat-text-card {
  background: #f8fcfb;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.threshold-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 4rpx;
}

.threshold-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #0f766e;
  background: #ccfbf1;
  font-weight: 600;
}

.repeat-hint {
  font-size: 22rpx;
  color: #8aa0ae;
}

/* 录音区 */
.record-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.record-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0;
  border: 6rpx solid #e2e8f0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.record-btn::after {
  border: none;
}

.record-btn.recording {
  background: #fef2f2;
  border-color: #f87171;
  box-shadow: 0 8rpx 32rpx rgba(248, 113, 113, 0.30);
}

.record-btn.recorded {
  background: #f0fdf4;
  border-color: #34d399;
  box-shadow: 0 8rpx 32rpx rgba(52, 211, 153, 0.20);
}

.record-icon {
  font-size: 52rpx;
  line-height: 1;
  color: #6b8593;
}

.recording .record-icon {
  color: #ef4444;
}

.recorded .record-icon {
  color: #10b981;
}

.record-label {
  font-size: 22rpx;
  color: #6b8593;
  font-weight: 600;
}

.recording .record-label {
  color: #ef4444;
}

.recorded .record-label {
  color: #10b981;
}

.record-actions {
  display: flex;
  gap: 16rpx;
}

.ready-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: center;
  margin-bottom: 20rpx;
}

.ready-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #10b981;
  display: block;
}

.ready-text {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 500;
}

/* 跟读结果 */
.repeat-result {
  margin-top: 24rpx;
  background: #f8fcfb;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #a7f3d0;
}

.repeat-verdict {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.repeat-verdict.pass {
  color: #059669;
}

.repeat-verdict.fail {
  color: #dc2626;
}

.verdict-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.pass .verdict-icon {
  background: #d1fae5;
  color: #059669;
}

.fail .verdict-icon {
  background: #fee2e2;
  color: #dc2626;
}

.verdict-text {
  font-size: 30rpx;
  font-weight: 700;
}

.score-grid {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.score-cell {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.score-big {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #0f2030;
  line-height: 1;
  margin-bottom: 8rpx;
}

.score-key {
  font-size: 20rpx;
  color: #8aa0ae;
}

.issue-section {
  border-top: 2rpx solid #e8f5f3;
  padding-top: 16rpx;
}

.issue-label {
  font-size: 22rpx;
  color: #8aa0ae;
  display: block;
  margin-bottom: 12rpx;
}

.issue-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.issue-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 22rpx;
  font-weight: 600;
}
