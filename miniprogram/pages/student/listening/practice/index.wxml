<view class="page">
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">正在加载精听内容...</text>
  </view>

  <view wx:else>
    <view class="summary-card">
      <view class="summary-top">
        <view>
          <view class="summary-label">精听任务</view>
          <view class="summary-title">{{exercise.title || task.task_name || '精听练习'}}</view>
        </view>
        <view class="summary-badge {{allCompleted ? 'done' : 'progress'}}">
          {{allCompleted ? '已完成' : '进行中'}}
        </view>
      </view>
      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-value">{{summary.completedCount}}/{{summary.totalCount}}</text>
          <text class="summary-key">完成句数</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{summary.completionRate}}%</text>
          <text class="summary-key">完成率</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{summary.accuracy}}%</text>
          <text class="summary-key">正确率</text>
        </view>
      </view>
    </view>

    <scroll-view scroll-x class="segment-strip" enable-flex>
      <view
        class="segment-chip {{index === currentIndex ? 'active' : ''}} {{item.isCompleted ? 'done' : ''}}"
        wx:for="{{segments}}"
        wx:key="globalIndex"
        data-index="{{index}}"
        bindtap="onSelectSegment"
      >
        <text class="chip-main">{{index + 1}}</text>
        <text class="chip-sub">{{item.isCompleted ? '✓' : item.partShort}}</text>
      </view>
    </scroll-view>

    <view class="player-card" wx:if="{{currentSegment}}">
      <view class="player-head">
        <view>
          <view class="sentence-title">{{currentSegment.partName}} · 第{{currentIndex + 1}}句</view>
          <view class="sentence-sub">{{currentTimeText}} / {{segmentDurationText}}</view>
        </view>
        <picker range="{{speedOptions}}" range-key="label" value="{{speedIndex}}" bindchange="onSpeedChange">
          <view class="speed-pill">{{speedOptions[speedIndex].label}}</view>
        </picker>
      </view>

      <view class="control-row">
        <button class="control-btn ghost" bindtap="prevSegment">上一句</button>
        <button class="control-btn primary" bindtap="togglePlay">
          {{audioPlaying ? '暂停' : '播放'}}
        </button>
        <button class="control-btn ghost" bindtap="repeatSegment">重播</button>
        <button class="control-btn ghost" bindtap="nextSegment">下一句</button>
      </view>

      <view class="mode-switch">
        <view class="mode-pill {{mode === 'listen' ? 'active' : ''}}" data-mode="listen" bindtap="switchMode">句子精听</view>
        <view class="mode-pill {{mode === 'dictation' ? 'active' : ''}}" data-mode="dictation" bindtap="switchMode">听写模式</view>
      </view>

      <view class="toggle-row">
        <view class="toggle-btn {{showOriginal ? 'active' : ''}}" bindtap="toggleOriginal">
          {{showOriginal ? '隐藏原文' : '显示原文'}}
        </view>
        <view class="toggle-btn {{showTranslation ? 'active' : ''}}" bindtap="toggleTranslation">
          {{showTranslation ? '隐藏译文' : '显示译文'}}
        </view>
      </view>

      <view class="listen-card" wx:if="{{mode === 'listen'}}">
        <text class="placeholder" wx:if="{{!showOriginal}}">先听一遍，再决定是否查看原文。</text>
        <text class="original-text" wx:if="{{showOriginal}}">{{currentSegment.text}}</text>
        <text class="translation-text" wx:if="{{showTranslation && currentSegment.translation}}">{{currentSegment.translation}}</text>
      </view>

      <view wx:if="{{mode === 'dictation'}}">
        <view class="difficulty-row">
          <text class="difficulty-label">难度</text>
          <view class="difficulty-pills">
            <view
              class="difficulty-pill {{difficultyIndex === index ? 'active' : ''}}"
              wx:for="{{difficultyOptions}}"
              wx:key="label"
              data-index="{{index}}"
              bindtap="changeDifficulty"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="dictation-box">
          <block wx:for="{{renderTokens}}" wx:key="tokenKey">
            <text wx:if="{{item.kind === 'text'}}" class="plain-token">{{item.text}}</text>
            <view wx:else class="blank-wrap {{item.status}}">
              <input
                class="blank-input {{item.status}}"
                type="text"
                adjust-position="false"
                disabled="{{dictationLocked}}"
                value="{{blankAnswers[item.blankIndex] || item.value || ''}}"
                data-blank-index="{{item.blankIndex}}"
                bindinput="onBlankInput"
                placeholder="..."
                style="width: {{item.width}}px;"
              />
              <text wx:if="{{item.suffix}}" class="blank-suffix">{{item.suffix}}</text>
            </view>
          </block>
        </view>

        <view class="listen-card" wx:if="{{showTranslation && currentSegment.translation}}">
          <text class="translation-text">{{currentSegment.translation}}</text>
        </view>

        <view class="result-card" wx:if="{{currentResult}}">
          <view class="result-main">本句正确 {{currentResult.correctWords}} / {{currentResult.totalWords}}</view>
          <view class="result-sub">正确率 {{currentResult.accuracy}}%</view>
        </view>

        <view class="control-row">
          <button class="control-btn primary" wx:if="{{!dictationLocked}}" bindtap="submitCurrentSegment">提交本句</button>
          <button class="control-btn ghost" wx:else bindtap="redoCurrentSegment">重做本句</button>
          <button class="control-btn ghost" bindtap="nextSegment">{{currentIndex + 1 >= segments.length ? '返回末句' : '下一句'}}</button>
        </view>
      </view>
    </view>
  </view>
</view>
