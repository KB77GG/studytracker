page {
  background: #f4f1ea;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 150rpx;
  box-sizing: border-box;
  color: #18243a;
}

.loading-state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-ring {
  width: 68rpx;
  height: 68rpx;
  border: 6rpx solid #d7e5e1;
  border-top-color: #0f9f8f;
  border-radius: 50%;
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}

.summary-card,
.passage-card,
.group-card,
.result-card {
  background: #fffefa;
  border: 2rpx solid rgba(206, 199, 186, 0.72);
  border-radius: 22rpx;
  box-shadow: 0 14rpx 34rpx rgba(44, 50, 65, 0.08);
}

.summary-card {
  padding: 30rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.summary-info {
  flex: 1;
  min-width: 0;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #667085;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.summary-title {
  display: block;
  font-size: 34rpx;
  font-weight: 750;
  line-height: 1.34;
  color: #14213d;
}

.status-badge {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-badge.progress {
  color: #087f73;
  background: #dff4ef;
}

.status-badge.done {
  color: #266f4e;
  background: #e5f5ea;
}

.progress-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: #edf1f3;
  overflow: hidden;
  margin: 24rpx 0 22rpx;
}

.progress-fill {
  height: 100%;
  background: #0f9f8f;
  border-radius: 999rpx;
}

.stats-row {
  display: flex;
  align-items: center;
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7rpx;
}

.stat-divider {
  width: 2rpx;
  height: 46rpx;
  background: #e3e8ee;
}

.stat-val {
  font-size: 30rpx;
  font-weight: 750;
  color: #14213d;
}

.stat-total,
.stat-unit,
.stat-key {
  font-size: 21rpx;
  color: #667085;
  font-weight: 500;
}

.passage-strip {
  white-space: nowrap;
  margin: 4rpx 0 20rpx;
}

.passage-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 76rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: #fffefa;
  border: 2rpx solid #e1e7ec;
  color: #526070;
  font-size: 26rpx;
  font-weight: 750;
}

.passage-chip.active {
  background: #0f9f8f;
  color: #fff;
  border-color: #0f9f8f;
}

.result-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.result-score {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.result-main {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f766e;
}

.result-sub,
.result-band,
.wrong-list {
  display: block;
  font-size: 25rpx;
  color: #526070;
  line-height: 1.55;
}

.back-btn {
  height: 68rpx;
  border-radius: 18rpx;
  background: #eef7f5;
  color: #0f766e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 760;
  margin-top: 18rpx;
}

.result-actions {
  margin-top: 18rpx;
}

.redo-btn {
  height: 68rpx;
  border-radius: 18rpx;
  background: #0f9f8f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 780;
  box-shadow: 0 10rpx 24rpx rgba(15, 159, 143, 0.2);
}

.passage-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.passage-label {
  display: block;
  color: #0f9f8f;
  font-size: 23rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.passage-title {
  display: block;
  color: #14213d;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
  margin-bottom: 14rpx;
}

.passage-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e7f7f4;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 750;
}

.paragraph {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.paragraph-label {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #efe6d6;
  color: #14213d;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paragraph-text {
  flex: 1;
  min-width: 0;
  font-size: 29rpx;
  line-height: 1.74;
  color: #263242;
}

.group-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.group-title {
  display: block;
  font-size: 31rpx;
  font-weight: 800;
  color: #14213d;
  margin-bottom: 14rpx;
}

.group-desc,
.question-title {
  display: block;
  font-size: 25rpx;
  color: #526070;
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.question-image {
  width: 100%;
  margin: 8rpx 0 18rpx;
  border-radius: 12rpx;
}

.collect-box {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f7faf9;
  border: 2rpx solid #e0e9e7;
  color: #18243a;
  font-size: 28rpx;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.chunk-text {
  display: inline;
}

.option-bank {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fbf7ef;
  border: 2rpx solid #efe2cf;
  margin-bottom: 20rpx;
}

.option-line {
  font-size: 25rpx;
  color: #475467;
  line-height: 1.55;
  margin-bottom: 8rpx;
}

.option-line:last-child {
  margin-bottom: 0;
}

.table-scroll {
  width: 100%;
  margin: 12rpx 0 22rpx;
}

.practice-table {
  min-width: 680rpx;
  border-left: 2rpx solid #dfe7ea;
  border-top: 2rpx solid #dfe7ea;
}

.table-row {
  display: flex;
}

.table-cell {
  min-width: 168rpx;
  flex: 1;
  padding: 16rpx;
  border-right: 2rpx solid #dfe7ea;
  border-bottom: 2rpx solid #dfe7ea;
  font-size: 24rpx;
  line-height: 1.55;
  color: #263242;
  background: #fff;
}

.question-block {
  padding: 22rpx 0;
  border-top: 2rpx solid #edf1f3;
}

.question-block:first-of-type {
  border-top: none;
}

.q-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.q-number {
  flex-shrink: 0;
  min-width: 72rpx;
  padding: 6rpx 12rpx;
  border-radius: 14rpx;
  background: #e7f7f4;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.q-title {
  flex: 1;
  min-width: 0;
  font-size: 29rpx;
  color: #18243a;
  line-height: 1.7;
}

.answer-input,
.answer-picker {
  min-height: 74rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  border: 2rpx solid #d9e4e7;
  background: #fbfefe;
  padding: 0 20rpx;
  font-size: 27rpx;
  color: #14213d;
}

.answer-input {
  line-height: 74rpx;
}

.answer-picker {
  display: flex;
  align-items: center;
  color: #526070;
}

.inline-input,
.inline-picker {
  display: inline-flex;
  vertical-align: middle;
  width: 190rpx;
  height: 62rpx;
  min-height: 62rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  border: 2rpx solid #cfe4e1;
  background: #f7fffd;
  padding: 0 14rpx;
  margin: 0 8rpx;
  font-size: 25rpx;
  color: #14213d;
  align-items: center;
}

.inline-picker {
  color: #526070;
}

.answer-input.correct,
.answer-picker.correct,
.inline-input.correct,
.inline-picker.correct {
  border-color: rgba(22, 163, 74, 0.62);
  background: #f0fdf4;
}

.answer-input.wrong,
.answer-picker.wrong,
.inline-input.wrong,
.inline-picker.wrong {
  border-color: rgba(220, 38, 38, 0.72);
  background: #fff1f2;
}

.answer-tip {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  background: #f6f8f8;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.45;
}

.answer-tip.correct {
  color: #15803d;
  background: #f0fdf4;
}

.answer-tip.wrong {
  color: #b91c1c;
  background: #fff1f2;
}

.inline-answer-tip {
  display: inline-flex;
  vertical-align: middle;
  margin: 0 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  line-height: 1.35;
  color: #475467;
  background: #f2f5f7;
}

.inline-answer-tip.correct {
  color: #15803d;
  background: #f0fdf4;
}

.inline-answer-tip.wrong {
  color: #b91c1c;
  background: #fff1f2;
}

.choice-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.choice-list.wrong {
  padding: 10rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(220, 38, 38, 0.72);
  background: #fff8f8;
}

.choice-list.correct {
  padding: 10rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(22, 163, 74, 0.46);
  background: #f7fef9;
}

.choice-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  min-height: 56rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafb;
  border: 2rpx solid #e3eaee;
}

.choice-row.correct {
  border-color: rgba(22, 163, 74, 0.62);
  background: #f0fdf4;
}

.choice-row.wrong {
  border-color: rgba(220, 38, 38, 0.72);
  background: #fff1f2;
}

.choice-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #263242;
  line-height: 1.45;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 254, 250, 0.96);
  border-top: 2rpx solid #e3e9ed;
  display: grid;
  grid-template-columns: 170rpx 1fr;
  gap: 18rpx;
  box-sizing: border-box;
}

.submit-info {
  height: 76rpx;
  border-radius: 18rpx;
  background: #f2f6f7;
  color: #526070;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 760;
}

.submit-btn {
  height: 76rpx;
  border-radius: 18rpx;
  background: #0f9f8f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 780;
  box-shadow: 0 12rpx 26rpx rgba(15, 159, 143, 0.24);
}

.submit-btn.disabled {
  opacity: 0.55;
}
