.container {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.question-card,
.submit-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(20, 41, 82, 0.06);
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #53627c;
}

.desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.progress-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #4b5563;
}

.question-no {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #3853d8;
  font-size: 22rpx;
  font-weight: 600;
}

.question-word {
  display: block;
  margin-top: 24rpx;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #111827;
}

.options {
  margin-top: 24rpx;
}

.uncertain-toggle {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.uncertain-text {
  font-size: 24rpx;
  color: #92400e;
}

.option-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 20rpx;
  border: 2rpx solid #dbe3f0;
  border-radius: 18rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.option-item.selected {
  border-color: #2f7cf6;
  background: #eef5ff;
}

.option-key {
  min-width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #edf2f7;
  color: #334155;
  font-size: 22rpx;
  font-weight: 700;
}

.option-item.selected .option-key {
  background: #2f7cf6;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1f2937;
}

.nav-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.nav-btn,
.submit-btn {
  flex: 1;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.nav-btn.secondary {
  background: #ffffff;
  color: #334155;
  border: 2rpx solid #dbe3f0;
}

.submit-btn {
  background: linear-gradient(135deg, #2676f2, #1f5ed6);
  color: #fff;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
  margin-bottom: 18rpx;
}

.loading-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 28rpx;
}

/* Mode pill */
.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.mode-pill {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.mode-pill.review {
  background: #ecfdf5;
  color: #047857;
}

.mode-pill.redo_wrong {
  background: #fff7ed;
  color: #c2410c;
}

.mode-pill.redo_all {
  background: #eef2ff;
  color: #3730a3;
}

/* Review: correct / wrong option highlighting */
.option-item.correct {
  border-color: #10b981;
  background: #ecfdf5;
}

.option-item.correct .option-key {
  background: #10b981;
  color: #fff;
}

.option-item.wrong {
  border-color: #ef4444;
  background: #fef2f2;
}

.option-item.wrong .option-key {
  background: #ef4444;
  color: #fff;
}

.option-badge {
  margin-left: auto;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.correct-badge {
  background: #10b981;
  color: #fff;
}

.wrong-badge {
  background: #fee2e2;
  color: #b91c1c;
}

.hint-box {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  background: #f8fafc;
  border-left: 6rpx solid #2f7cf6;
  border-radius: 12rpx;
}

.hint-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.hint-text {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  line-height: 1.5;
}

.hint-mark {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b45309;
  font-weight: 600;
}

.result-box {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.result-box.correct {
  background: #ecfdf5;
  border: 2rpx solid #a7f3d0;
}

.result-box.wrong {
  background: #fef2f2;
  border: 2rpx solid #fecaca;
}

.result-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.result-line {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #475569;
}

.uncertain-line {
  color: #b45309;
  font-weight: 600;
}

/* Review summary & actions */
.review-summary {
  padding: 18rpx 0;
  text-align: center;
  border-bottom: 2rpx dashed #e5e7eb;
  margin-bottom: 20rpx;
}

.review-accuracy {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.review-detail {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b45309;
}

.review-detail.good {
  color: #047857;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.nav-btn.ghost {
  background: transparent;
  color: #6b7280;
  border: none;
  font-size: 26rpx;
  margin-top: 4rpx;
}

/* 改写/翻译输入题样式 */
.writing-area {
  margin-top: 20rpx;
}

.writing-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #cbd5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
  box-sizing: border-box;
}

.writing-input[disabled] {
  background: #eef2f7;
  color: #4b5563;
}

.writing-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
}
