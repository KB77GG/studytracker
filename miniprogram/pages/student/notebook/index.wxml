<view class="page">
  <view class="page-header">
    <view>
      <view class="title">复习中心</view>
      <view class="header-subtitle">练习记录、错题与生词统一回顾</view>
    </view>
    <view class="count" wx:if="{{activeTab === 'history'}}">共 {{historyList.length}} 条</view>
    <view class="count" wx:elif="{{activeTab === 'dictation'}}">共 {{list.length}} 词</view>
    <view class="count" wx:elif="{{activeTab === 'reading'}}">共 {{readingList.length}} 词</view>
    <view class="count" wx:else>共 {{vocabList.length}} 词</view>
  </view>

  <view class="history-summary">
    <view class="summary-item">
      <text class="summary-value">{{historySummary.completed || 0}}</text>
      <text class="summary-label">完成练习</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{historySummary.total_minutes || 0}}</text>
      <text class="summary-label">累计分钟</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">{{historySummary.average_accuracy === null ? '—' : historySummary.average_accuracy + '%'}}</text>
      <text class="summary-label">平均正确率</text>
    </view>
  </view>

  <view class="tabs">
    <view
      class="tab {{activeTab === 'history' ? 'active' : ''}}"
      data-tab="history"
      bindtap="switchTab"
    >
      <text>练习记录</text>
    </view>
    <view
      class="tab {{activeTab === 'dictation' ? 'active' : ''}}"
      data-tab="dictation"
      bindtap="switchTab"
    >
      <text>听写</text>
      <text class="tab-count" wx:if="{{list.length}}">{{list.length}}</text>
    </view>
    <view
      class="tab {{activeTab === 'reading' ? 'active' : ''}}"
      data-tab="reading"
      bindtap="switchTab"
    >
      <text>阅读</text>
      <text class="tab-count" wx:if="{{readingList.length}}">{{readingList.length}}</text>
    </view>
    <view
      class="tab {{activeTab === 'vocab' ? 'active' : ''}}"
      data-tab="vocab"
      bindtap="switchTab"
    >
      <text>生词</text>
      <text class="tab-count" wx:if="{{vocabList.length}}">{{vocabList.length}}</text>
    </view>
  </view>

  <block wx:if="{{activeTab === 'history'}}">
    <view class="loading-card" wx:if="{{historyLoading}}">正在加载练习记录...</view>
    <view class="empty history-empty" wx:elif="{{!historyList.length}}">
      <text class="empty-title">还没有完成记录</text>
      <text class="empty-sub">完成任务后，会自动沉淀到这里供你回顾。</text>
    </view>
    <view class="history-list" wx:else>
      <view
        class="history-card"
        wx:for="{{historyList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="openHistoryTask"
      >
        <view class="history-mark">{{item.moduleMark}}</view>
        <view class="history-main">
          <view class="history-topline">
            <text class="history-category">{{item.category}}</text>
            <text class="history-date">{{item.date}}</text>
          </view>
          <text class="history-title">{{item.title}}</text>
          <view class="history-meta">
            <text>{{item.durationLabel}}</text>
            <text wx:if="{{item.accuracyLabel}}">正确率 {{item.accuracyLabel}}</text>
            <text class="wrong-dot" wx:if="{{item.wrongLabel}}">{{item.wrongLabel}}</text>
            <text class="feedback-dot" wx:if="{{item.has_feedback || item.hasFeedback}}">有老师反馈</text>
          </view>
        </view>
        <view class="history-side">
          <text class="history-state {{item.state}}">{{item.stateLabel}}</text>
          <text class="history-arrow">›</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ═════ Dictation tab ═════ -->
  <block wx:elif="{{activeTab === 'dictation'}}">
    <!-- 上次错词快捷入口 -->
    <view wx:if="{{lastWrongCount > 0}}" class="last-wrong-banner" bindtap="retryLastWrong">
      <view class="banner-left">
        <view class="banner-icon">🔄</view>
        <view class="banner-text">
          <text class="banner-title">上次练习错词</text>
          <text class="banner-desc">{{lastWrongCount}} 个单词待巩固</text>
        </view>
      </view>
      <view class="banner-btn">立即重练</view>
    </view>

    <view wx:if="{{!list.length && !isLoading}}" class="empty">
      <text>还没有错词记录</text>
    </view>

    <scroll-view wx:else scroll-y class="list">
      <view class="card" wx:for="{{list}}" wx:key="entryKey">
        <view class="card-header">
          <view class="word">{{item.word}}</view>
          <view class="phonetic">[{{item.phonetic || '-'}}]</view>
        </view>
        <view class="trans">{{item.translation || '暂无释义'}}</view>
        <view class="card-actions">
          <button size="mini" class="ghost" data-word="{{item.word}}" bindtap="playWord">播放</button>
          <button size="mini" class="danger" data-entrykey="{{item.entryKey}}" bindtap="deleteItem">删除</button>
        </view>
      </view>
    </scroll-view>

    <view class="footer">
      <button wx:if="{{list.length >= 2}}" class="retry-all-btn" bindtap="retryAllNotebook">重练全部错词</button>
      <button wx:if="{{list.length > 0}}" class="clear-btn" bindtap="clearAll">清空错词本</button>
    </view>
  </block>

  <!-- ═════ Reading-vocab tab ═════ -->
  <block wx:elif="{{activeTab === 'reading'}}">
    <view wx:if="{{!readingList.length && !readingLoading}}" class="empty">
      <text>还没有阅读词汇错题</text>
      <text class="empty-sub">云端错题会自动同步到这里，离线时显示上次缓存</text>
    </view>

    <scroll-view wx:else scroll-y class="list">
      <view
        class="card reading-card"
        wx:for="{{readingList}}"
        wx:key="entryKey"
        data-taskid="{{item.taskId}}"
        bindtap="retryReadingItem"
      >
        <view class="card-header">
          <view class="word">{{item.word}}</view>
          <view class="reading-correct-tag {{item.isUncertain ? 'reading-uncertain-tag' : ''}}">
            {{item.isUncertain ? '标记不清楚' : ('正确 ' + item.correctKey)}}
          </view>
        </view>
        <view wx:if="{{item.taskTitle}}" class="reading-task-title">{{item.taskTitle}}</view>
        <view class="reading-row">
          <text class="reading-label">你选：</text>
          <text class="reading-your {{item.isUncertain ? 'reading-your-uncertain' : ''}}">{{item.yourKey ? item.yourKey + '．' : ''}}{{item.yourText || '未作答'}}</text>
        </view>
        <view class="reading-row">
          <text class="reading-label">正确：</text>
          <text class="reading-correct">{{item.correctKey ? item.correctKey + '．' : ''}}{{item.correctText || '-'}}</text>
        </view>
        <view wx:if="{{item.hint}}" class="reading-row">
          <text class="reading-label">释义：</text>
          <text class="reading-hint">{{item.hint}}</text>
        </view>
        <view class="card-actions">
          <button size="mini" class="ghost" catchtap="retryReadingItem" data-taskid="{{item.taskId}}">去重练</button>
          <button size="mini" class="danger" catchtap="deleteReadingItem" data-entrykey="{{item.entryKey}}">删除</button>
        </view>
      </view>
    </scroll-view>

    <view class="footer">
      <button wx:if="{{readingList.length > 0}}" class="clear-btn" bindtap="clearReadingAll">清空本地缓存</button>
    </view>
  </block>

  <!-- ═════ Saved vocabulary tab ═════ -->
  <block wx:else>
    <view wx:if="{{!vocabList.length && !vocabLoading}}" class="empty">
      <text>还没有收藏生词</text>
      <text class="empty-sub">网页复盘划词后点“加入生词本”，会同步到这里</text>
    </view>

    <scroll-view wx:else scroll-y class="list">
      <view class="card vocab-card" wx:for="{{vocabList}}" wx:key="id">
        <view class="card-header">
          <view class="word">{{item.word}}</view>
          <view class="reading-correct-tag">{{item.sourceLabel}}</view>
        </view>
        <view class="trans">{{item.translation || '暂无释义'}}</view>
        <view class="reading-task-title" wx:if="{{item.updatedText}}">加入时间：{{item.updatedText}}</view>
        <view class="card-actions">
          <button size="mini" class="danger" catchtap="deleteVocab" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </scroll-view>
  </block>
</view>
