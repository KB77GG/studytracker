.page {
  min-height: 100vh;
  background: #f4f8f8;
  padding: 34rpx 28rpx 170rpx;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 850;
  color: #0b1830;
}

.header-subtitle {
  margin-top: 8rpx;
  color: #718096;
  font-size: 23rpx;
}

.count {
  font-size: 26rpx;
  color: #20756f;
  font-weight: 700;
}

.history-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.summary-item {
  min-width: 0;
  padding: 22rpx 10rpx;
  border: 1rpx solid #e0ecea;
  border-radius: 20rpx;
  background: #fff;
  text-align: center;
}

.summary-value,
.summary-label {
  display: block;
}

.summary-value {
  color: #0f766e;
  font-family: "DIN Alternate", "Avenir Next", sans-serif;
  font-size: 34rpx;
  font-weight: 850;
}

.summary-label {
  margin-top: 6rpx;
  color: #829097;
  font-size: 20rpx;
}

/* ── 上次错词 banner ── */
.last-wrong-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border: 1px solid #fed7aa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.banner-icon {
  font-size: 40rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #9a3412;
}

.banner-desc {
  font-size: 22rpx;
  color: #c2410c;
  margin-top: 2rpx;
}

.banner-btn {
  background: #ea580c;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

/* ── 空状态 ── */
.empty {
  margin-top: 80rpx;
  text-align: center;
  color: #909399;
}

/* ── 列表 ── */
.list {
  max-height: calc(100vh - 380rpx);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.word {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.phonetic {
  font-size: 24rpx;
  color: #909399;
}

.trans {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #606266;
}

.card-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

button.ghost {
  background: #eaf6f4;
  color: #20756f;
  border: 1px solid #c8e8e3;
}

button.danger {
  background: #fdecea;
  color: #d9534f;
  border: 1px solid #f5c6cb;
}

/* ── 底部按钮 ── */
.footer {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.retry-all-btn {
  width: 100%;
  background: #0f766e;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 600;
  font-size: 30rpx;
}

.clear-btn {
  width: 100%;
  background: #f5f5f5;
  color: #606266;
  border-radius: 12rpx;
}

/* ── Tabs ── */
.tabs {
  display: flex;
  gap: 8rpx;
  background: #fff;
  padding: 8rpx;
  border: 1rpx solid #e0ecea;
  border-radius: 18rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: 10rpx;
  min-width: 0;
  font-size: 24rpx;
  color: #606266;
  font-weight: 500;
  transition: all 0.2s;
}

.tab.active {
  background: #0f766e;
  color: #fff;
  font-weight: 600;
}

.loading-card,
.history-empty {
  padding: 72rpx 28rpx;
  border-radius: 22rpx;
  background: #fff;
  color: #829097;
  text-align: center;
}

.empty-title {
  display: block;
  color: #334155;
  font-size: 28rpx;
  font-weight: 750;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e1eceb;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(23, 58, 64, 0.05);
}

.history-card:active {
  background: #f1f8f7;
}

.history-mark {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #e8f7f4;
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 850;
}

.history-main {
  min-width: 0;
  flex: 1;
}

.history-topline,
.history-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-category {
  color: #20756f;
  font-size: 22rpx;
  font-weight: 750;
}

.history-date {
  color: #94a3b8;
  font-size: 21rpx;
}

.history-title {
  display: -webkit-box;
  margin-top: 7rpx;
  overflow: hidden;
  color: #172033;
  font-size: 27rpx;
  font-weight: 750;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.history-meta {
  margin-top: 10rpx;
  color: #74828f;
  font-size: 21rpx;
}

.feedback-dot {
  color: #9a5b00;
}

.history-side {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.history-state {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e9f8ef;
  color: #17864b;
  font-size: 20rpx;
  font-weight: 750;
}

.history-state.pending_review {
  background: #fff5df;
  color: #aa6200;
}

.history-arrow {
  color: #8aa19f;
  font-size: 36rpx;
  line-height: 1;
}

.tab-count {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.06);
  color: inherit;
}

.tab.active .tab-count {
  background: rgba(255, 255, 255, 0.25);
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #a1a4b0;
}

/* ── Reading-vocab card ── */
.reading-card {
  position: relative;
}

.reading-correct-tag {
  margin-left: auto;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  font-weight: 600;
}

.reading-uncertain-tag {
  background: #fff7ed;
  color: #c2410c;
}

.reading-row {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.reading-label {
  color: #909399;
  flex-shrink: 0;
}

.reading-task-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.reading-your {
  color: #b91c1c;
  text-decoration: line-through;
  flex: 1;
}

.reading-your-uncertain {
  color: #92400e;
  text-decoration: none;
}

.reading-correct {
  color: #047857;
  font-weight: 600;
  flex: 1;
}

.reading-hint {
  color: #4b5563;
  flex: 1;
}
