.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 170rpx;
  background: #f7f8f6;
  color: #1c1c1c;
}

.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.title {
  color: #1c1c1c;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.2;
}

.header-subtitle {
  margin-top: 8rpx;
  color: #888;
  font-size: 25rpx;
  line-height: 1.5;
}

.history-summary {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.summary-item {
  min-width: 0;
  padding: 26rpx 10rpx;
  border: 1rpx solid #efefed;
  border-radius: 28rpx;
  background: #fff;
  text-align: center;
}

.summary-item.primary {
  border-color: #bfe0dd;
  background: #e6f2f1;
}

.summary-value,
.summary-label {
  display: block;
}

.summary-value {
  color: #1c1c1c;
  font-family: "DIN Alternate", "Avenir Next", sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-item.primary .summary-value {
  color: #1b5851;
}

.summary-label {
  margin-top: 10rpx;
  color: #999;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-item.primary .summary-label {
  color: #237069;
}

.tabs {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f2f3f1;
  color: #666;
  font-size: 25rpx;
  font-weight: 650;
  white-space: nowrap;
}

.tab.active {
  background: #237069;
  color: #fff;
  font-weight: 800;
}

.tab-count {
  min-width: 28rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.06);
  color: inherit;
  font-size: 21rpx;
  line-height: 30rpx;
}

.tab.active .tab-count {
  background: rgba(255, 255, 255, 0.24);
}

.loading-card,
.history-empty {
  padding: 76rpx 28rpx;
  border: 1rpx solid #efefed;
  border-radius: 28rpx;
  background: #fff;
  color: #829097;
  text-align: center;
}

.empty-title {
  display: block;
  color: #334155;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  color: #a1a4b0;
  font-size: 24rpx;
  line-height: 1.5;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-card {
  padding: 26rpx;
  border: 1rpx solid #efefed;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(20, 44, 58, 0.04);
}

.history-card:active,
.card:active {
  transform: scale(0.99);
}

.history-card-main {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
}

.history-mark {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #e8f0fb;
  color: #3b82f6;
  font-size: 28rpx;
  font-weight: 900;
}

.history-mark.needs-review {
  background: #e8f0fb;
  color: #3b82f6;
}

.history-main {
  min-width: 0;
  flex: 1;
}

.history-topline,
.history-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-category {
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  background: #e8f0fb;
  color: #3b82f6;
  font-size: 21rpx;
  font-weight: 850;
}

.history-date {
  color: #aaa;
  font-size: 21rpx;
}

.history-title {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #1c1c1c;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.38;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.history-meta {
  margin-top: 12rpx;
  color: #888;
  font-size: 22rpx;
  line-height: 1.4;
}

.feedback-dot {
  color: #9a7b3e;
}

.wrong-dot {
  color: #e0892b;
  font-size: 25rpx;
  font-weight: 850;
}

.history-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f4f4f2;
}

.history-footer.completed {
  opacity: 0.74;
}

.history-cta {
  min-width: 140rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #2e8b87;
  color: #fff;
  font-size: 25rpx;
  font-weight: 850;
}

.history-state {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e9f8ef;
  color: #17864b;
  font-size: 21rpx;
  font-weight: 750;
}

.history-state.pending_review {
  background: #fff5df;
  color: #aa6200;
}

.history-arrow {
  color: #cbcbc9;
  font-size: 42rpx;
  line-height: 1;
}

.last-wrong-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #f3d8b0;
  border-radius: 28rpx;
  background: #fbf4e8;
}

.banner-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.banner-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #fff;
  color: #e0892b;
  font-size: 34rpx;
  font-weight: 900;
}

.banner-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.banner-title {
  color: #9a5b00;
  font-size: 28rpx;
  font-weight: 800;
}

.banner-desc {
  margin-top: 4rpx;
  color: #9a7b3e;
  font-size: 23rpx;
}

.banner-btn {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: #e0892b;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.empty {
  margin-top: 80rpx;
  color: #909399;
  font-size: 26rpx;
  text-align: center;
}

.list {
  max-height: calc(100vh - 420rpx);
}

.card {
  margin-bottom: 18rpx;
  padding: 26rpx;
  border: 1rpx solid #efefed;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(20, 44, 58, 0.04);
}

.card-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.word {
  min-width: 0;
  color: #1c1c1c;
  font-size: 34rpx;
  font-weight: 850;
  word-break: break-word;
}

.phonetic {
  flex-shrink: 0;
  color: #909399;
  font-size: 24rpx;
}

.trans {
  margin-top: 10rpx;
  color: #606266;
  font-size: 27rpx;
  line-height: 1.5;
}

.card-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

button.ghost,
button.danger {
  margin: 0;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 750;
}

button.ghost::after,
button.danger::after,
.retry-all-btn::after,
.clear-btn::after {
  border: none;
}

button.ghost {
  border: 1rpx solid #c8e8e3;
  background: #e6f2f1;
  color: #237069;
}

button.danger {
  border: 1rpx solid #f5c6cb;
  background: #fdecea;
  color: #d9534f;
}

.footer {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.retry-all-btn,
.clear-btn {
  width: 100%;
  border-radius: 18rpx;
  font-size: 29rpx;
  font-weight: 750;
}

.retry-all-btn {
  background: #237069;
  color: #fff;
}

.clear-btn {
  background: #f2f3f1;
  color: #606266;
}

.reading-correct-tag {
  flex-shrink: 0;
  margin-left: auto;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f2f1;
  color: #237069;
  font-size: 22rpx;
  font-weight: 750;
}

.reading-uncertain-tag {
  background: #fbf4e8;
  color: #c2410c;
}

.reading-task-title {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.reading-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.reading-label {
  flex-shrink: 0;
  color: #909399;
}

.reading-your {
  flex: 1;
  color: #b91c1c;
  text-decoration: line-through;
}

.reading-your-uncertain {
  color: #92400e;
  text-decoration: none;
}

.reading-correct {
  flex: 1;
  color: #047857;
  font-weight: 700;
}

.reading-hint {
  flex: 1;
  color: #4b5563;
}
