.spell-page {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: #cfe8f3;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.queue-source-count {
  padding: 12rpx 24rpx 0;
  color: #6b7280;
  font-size: 24rpx;
  text-align: center;
}

.safe-top {
  flex: 0 0 auto;
}

.loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #405466;
  font-size: 30rpx;
}

/* ---------- ready ---------- */
.ready-shell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.ready-title {
  font-size: 34rpx;
  font-weight: 700;
}

.ready-face {
  font-size: 78rpx;
}

.ready-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  width: 100%;
  max-width: 560rpx;
}

.primary-pill,
.ghost-pill {
  height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: 0;
  line-height: 84rpx;
  padding: 0;
}

.primary-pill {
  background: #f45a12;
  color: #fff;
}

.ghost-pill {
  background: rgba(255, 255, 255, 0.5);
  color: #1f2937;
}

.skip-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

/* ---------- drill ---------- */
.top-bar {
  flex: 0 0 auto;
  height: 86rpx;
  padding: 18rpx 28rpx 0;
  display: grid;
  grid-template-columns: 120rpx 1fr 120rpx;
  align-items: center;
  box-sizing: border-box;
}

.count-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #365164;
}

.dots {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 10rpx 10rpx;
  min-width: 0;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(70, 91, 106, 0.22);
  flex: 0 0 auto;
}

.dot.done {
  background: #168f7a;
}

.tools {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 22rpx;
  font-size: 34rpx;
  color: #364b5f;
}

.tool-star {
  font-size: 34rpx;
  line-height: 1;
}

.drill-center {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx 0;
  box-sizing: border-box;
  position: relative;
}

.hidden-input {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  opacity: 0;
  left: 50%;
  top: 50%;
  pointer-events: none;
}

.word-display {
  width: 100%;
  min-height: 138rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.typed-word,
.answer-word {
  font-size: 58rpx;
  line-height: 1.1;
  font-weight: 800;
  letter-spacing: 0;
  color: #111827;
}

.answer-word.success,
.answer-word.answer-small {
  color: #168f7a;
}

.answer-small {
  font-size: 42rpx;
  margin-top: 12rpx;
}

.fake-cursor {
  display: inline-block;
  width: 4rpx;
  height: 62rpx;
  background: #e7671b;
  margin-left: 4rpx;
  vertical-align: -9rpx;
  animation: cursorBlink 1s steps(1) infinite;
}

@keyframes cursorBlink {
  50% { opacity: 0; }
}

.slot-row {
  width: 100%;
  max-width: 620rpx;
  min-height: 78rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: flex-end;
  gap: 12rpx 8rpx;
}

.slot {
  width: 30rpx;
  height: 64rpx;
  border-bottom: 5rpx solid rgba(54, 75, 95, 0.58);
  box-sizing: border-box;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  position: relative;
}

.slot-char {
  min-height: 54rpx;
  line-height: 54rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  text-align: center;
}

.slot.active {
  border-bottom-color: #e7671b;
}

.slot.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 9rpx;
  width: 4rpx;
  height: 48rpx;
  margin-left: -2rpx;
  background: #e7671b;
  animation: cursorBlink 1s steps(1) infinite;
}

.slot.overflow {
  border-bottom-color: #d24b55;
}

.slot.overflow .slot-char {
  color: #d24b55;
}

.slot-space {
  width: 22rpx;
  height: 64rpx;
  flex: 0 0 22rpx;
}

.slot-fixed {
  min-width: 12rpx;
  height: 64rpx;
  line-height: 54rpx;
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  color: #526075;
  font-size: 38rpx;
  font-weight: 800;
}

.translation {
  margin-top: 22rpx;
  max-width: 560rpx;
  font-size: 26rpx;
  line-height: 1.48;
  color: #111827;
  text-align: center;
  white-space: pre-wrap;
}

.spell-appeal-btn {
  width: auto;
  min-height: 58rpx;
  margin: 22rpx 0 0;
  padding: 0 22rpx;
  border: 2rpx solid #d7dde8;
  border-radius: 999rpx;
  background: #fff;
  color: #526075;
  font-size: 24rpx;
  line-height: 56rpx;
}

.spell-appeal-btn::after {
  border: 0;
}

.spell-appeal-btn[disabled] {
  background: #f3f5f8;
  color: #8a94a6;
}

.diff-row {
  min-height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 3rpx;
}

.diff-char {
  min-width: 22rpx;
  height: 54rpx;
  line-height: 54rpx;
  font-size: 44rpx;
  font-weight: 800;
  text-align: center;
}

.diff-char.ok {
  color: #168f7a;
}

.diff-char.bad,
.diff-char.miss {
  color: #d24b55;
  border-bottom: 5rpx solid #d24b55;
}

.bottom-bar {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  pointer-events: none;
  z-index: 20;
}

.round-control {
  pointer-events: auto;
  width: 132rpx;
  min-width: 0;
  height: 72rpx;
  line-height: 1;
  border-radius: 999rpx;
  border: 0;
  background: rgba(255, 255, 255, 0.78);
  color: #1f2937;
  font-size: 34rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.round-control::after {
  border: 0;
}

.round-control .key-hint {
  font-size: 20rpx;
  color: #8a98a8;
  margin-left: 8rpx;
}

.round-control.confirm {
  background: #f45a12;
  color: #fff;
}

.round-control.confirm .key-hint {
  color: rgba(255, 255, 255, 0.7);
}

/* CSS-drawn speaker icon (reliable across all platforms) */
.ic-audio {
  width: 34rpx;
  height: 30rpx;
  position: relative;
  display: block;
  flex: 0 0 auto;
}

.ic-audio::before {
  content: "";
  position: absolute;
  left: 0;
  top: 7rpx;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 6rpx 12rpx 6rpx 0;
  border-color: transparent #2f4250 transparent transparent;
}

.ic-audio::after {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 4rpx;
  width: 12rpx;
  height: 18rpx;
  border: 3rpx solid #2f4250;
  border-left: 0;
  border-top-right-radius: 12rpx;
  border-bottom-right-radius: 12rpx;
}

.phonetic-pill {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  padding: 10rpx 24rpx;
  color: #516172;
  font-size: 22rpx;
  z-index: 20;
}

/* ---------- summary ---------- */
.summary-head {
  flex: 0 0 auto;
  height: 86rpx;
  display: grid;
  grid-template-columns: 90rpx 1fr 90rpx;
  align-items: center;
  padding: 0 20rpx;
}

.back-btn {
  background: transparent;
  border: 0;
  font-size: 48rpx;
  line-height: 70rpx;
  padding: 0;
  text-align: left;
}

.summary-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
}

.tip-strip {
  flex: 0 0 auto;
  margin: 0 44rpx 26rpx;
  min-height: 54rpx;
  line-height: 54rpx;
  border-radius: 8rpx;
  background: rgba(216, 229, 235, 0.88);
  color: #73808a;
  text-align: center;
  font-size: 24rpx;
}

.summary-list {
  flex: 1;
  min-height: 0;
  padding: 0 44rpx;
  box-sizing: border-box;
}

.summary-row {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.summary-word {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.review-time {
  font-size: 26rpx;
  color: #7a8794;
  flex: 0 0 auto;
}

.summary-foot {
  flex: 0 0 auto;
  padding: 18rpx 32rpx calc(22rpx + env(safe-area-inset-bottom));
}

.summary-count {
  text-align: center;
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}

.primary-pill.wide {
  width: 100%;
}
