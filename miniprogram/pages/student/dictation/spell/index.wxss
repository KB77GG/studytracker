.spell-page {
  position: relative;
  width: 100%;
  max-width: 900px;
  height: 100vh;
  min-height: 0;
  margin: 0 auto;
  overflow-x: hidden;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  color: #0b1830;
  background: #fbfdfc;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.growth-path-background {
  position: absolute;
  z-index: 0;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.52;
  pointer-events: none;
}

.safe-top,
.queue-source-count,
.loading,
.ready-shell,
.sage-header,
.growth-progress,
.drill-center,
.strict-keyboard-wrap,
.bottom-bar,
.compat-wrong-actions,
.phonetic-pill,
.summary-head,
.tip-strip,
.server-score,
.mini-btn,
.summary-list,
.summary-foot {
  position: relative;
  z-index: 1;
}

.safe-top {
  flex: 0 0 auto;
}

.queue-source-count {
  flex: 0 0 auto;
  padding: 8rpx 24rpx 0;
  color: #70817f;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: center;
}

.loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #52706d;
  font-size: 30rpx;
}

/* ---------- ready ---------- */
.ready-shell {
  flex: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  box-sizing: border-box;
}

.ready-title {
  color: #0b1830;
  font-size: 34rpx;
  font-weight: 700;
}

.ready-face {
  font-size: 78rpx;
}

.ready-actions {
  width: 100%;
  max-width: 560rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
}

.primary-pill,
.ghost-pill {
  height: 84rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 84rpx;
}

.primary-pill {
  color: #fff;
  background: #087f77;
}

.ghost-pill {
  color: #315b57;
  background: rgba(255, 255, 255, 0.78);
}

.skip-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #6b7c79;
  font-size: 24rpx;
}

/* ---------- Sage Path drill ---------- */
.sage-header {
  flex: 0 0 auto;
  min-height: 78rpx;
  padding: 4rpx 34rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
}

.sage-logo {
  width: 220rpx;
  height: 66rpx;
  border-radius: 4rpx;
  flex: 0 0 auto;
}

.mode-switch-row {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.growth-progress {
  flex: 0 0 auto;
  padding: 4rpx 30rpx 2rpx;
  box-sizing: border-box;
}

.progress-count {
  color: #0b1830;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 500;
  letter-spacing: 0.02em;
  text-align: center;
}

.progress-path {
  width: 100%;
  max-width: 720px;
  min-height: 76rpx;
  margin: 2rpx auto 0;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 64rpx;
  align-items: center;
}

.path-endpoint {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(8, 127, 119, 0.22);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 12rpx rgba(28, 87, 82, 0.1);
  box-sizing: border-box;
}

.path-finish {
  justify-self: end;
}

.path-icon {
  width: 34rpx;
  height: 34rpx;
}

.path-line {
  position: relative;
  min-width: 0;
  height: 44rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4rpx;
  box-sizing: border-box;
}

.path-line::before {
  content: "";
  position: absolute;
  top: 50%;
  right: -4rpx;
  left: -4rpx;
  height: 6rpx;
  margin-top: -3rpx;
  border-radius: 999rpx;
  background: rgba(8, 127, 119, 0.12);
}

.path-dot {
  position: relative;
  z-index: 1;
  width: 22rpx;
  height: 22rpx;
  flex: 0 0 22rpx;
  border: 3rpx solid rgba(8, 127, 119, 0.22);
  border-radius: 50%;
  background: #fbfdfc;
  box-sizing: border-box;
}

.path-dot.done {
  border-color: #48a89d;
  background: #48a89d;
}

.path-dot.current {
  width: 32rpx;
  height: 32rpx;
  flex-basis: 32rpx;
  border: 4rpx solid #f2a30f;
  background: #fff8e7;
  box-shadow: 0 0 0 5rpx rgba(242, 163, 15, 0.12);
}

.drill-center {
  flex: 1 1 auto;
  min-height: 260rpx;
  padding: 8rpx 38rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.translation {
  width: 100%;
  max-width: 680px;
  color: #10213b;
  font-size: clamp(26px, 7.4vw, 40px);
  line-height: 1.35;
  font-weight: 500;
  letter-spacing: 0.02em;
  text-align: center;
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.replay-pill {
  width: auto;
  min-width: 134rpx;
  height: 70rpx;
  margin: 22rpx 0 18rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 2rpx solid rgba(8, 127, 119, 0.12);
  border-radius: 999rpx;
  color: #087f77;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 6rpx 18rpx rgba(28, 87, 82, 0.12);
  font-size: 28rpx;
  line-height: 1;
  font-weight: 650;
  box-sizing: border-box;
}

.replay-pill-pressed {
  transform: translateY(2rpx);
  background: #e9f5f2;
}

.replay-icon {
  width: 34rpx;
  height: 34rpx;
}

.compat-input {
  width: 100%;
  max-width: 560px;
  height: 92rpx;
  margin: 0 0 14rpx;
  padding: 0 24rpx;
  border: 3rpx solid rgba(8, 127, 119, 0.3);
  border-radius: 18rpx;
  color: #0b1830;
  background: rgba(255, 255, 255, 0.9);
  font-size: 38rpx;
  text-align: center;
  box-sizing: border-box;
}

.word-display {
  width: 100%;
  min-height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.answer-word {
  max-width: 100%;
  color: #0b1830;
  font-size: clamp(30px, 8.6vw, 50px);
  line-height: 1.16;
  font-weight: 750;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.answer-word.success {
  color: #168f7a;
}

.answer-word.revealed {
  color: #92520a;
}

.fake-cursor {
  display: inline-block;
  width: 4rpx;
  height: 56rpx;
  margin-left: 5rpx;
  border-radius: 4rpx;
  vertical-align: -7rpx;
  background: #f2a30f;
  animation: cursorBlink 1s steps(1) infinite;
}

@keyframes cursorBlink {
  50% {
    opacity: 0;
  }
}

.slot-row {
  width: 100%;
  max-width: 720px;
  min-height: 90rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.slot {
  position: relative;
  width: 56rpx;
  width: clamp(24px, 7.4vw, 34px);
  height: 82rpx;
  height: clamp(42px, 10.8vw, 52px);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(8, 127, 119, 0.28);
  border-radius: 12rpx;
  color: #087f77;
  background: rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
}

.slot-char {
  color: inherit;
  font-size: clamp(25px, 7vw, 36px);
  line-height: 1;
  font-weight: 650;
  text-align: center;
}

.slot.filled {
  border-color: rgba(8, 127, 119, 0.52);
  background: rgba(255, 255, 255, 0.94);
}

.slot.active {
  border-color: #f2a30f;
  box-shadow: 0 0 0 4rpx rgba(242, 163, 15, 0.1);
}

.slot.overflow {
  border-color: #d24b55;
  color: #d24b55;
}

.slot-space {
  width: 20rpx;
  height: 82rpx;
  flex: 0 0 20rpx;
}

.slot-fixed {
  min-width: 18rpx;
  height: 82rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #52706d;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
}

.wrong-copy {
  max-width: 620rpx;
  margin-top: 10rpx;
  color: #a94728;
  font-size: 25rpx;
  line-height: 1.45;
  text-align: center;
}

.diff-row {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
}

.diff-char {
  min-width: 24rpx;
  height: 58rpx;
  color: #0b1830;
  font-size: 46rpx;
  line-height: 58rpx;
  font-weight: 750;
  text-align: center;
}

.diff-char.ok {
  color: #168f7a;
}

.diff-char.bad,
.diff-char.miss {
  color: #d24b55;
  border-bottom: 4rpx solid #d24b55;
}

.spell-appeal-btn {
  width: auto;
  min-height: 58rpx;
  margin: 14rpx 0 0;
  padding: 0 22rpx;
  border: 2rpx solid rgba(82, 112, 109, 0.22);
  border-radius: 999rpx;
  color: #52706d;
  background: rgba(255, 255, 255, 0.9);
  font-size: 23rpx;
  line-height: 56rpx;
}

.strict-keyboard-wrap {
  flex: 0 0 auto;
  width: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.bottom-bar {
  position: fixed;
  right: max(40rpx, calc((100vw - 820px) / 2));
  left: max(40rpx, calc((100vw - 820px) / 2));
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  pointer-events: none;
}

.round-control {
  width: 132rpx;
  min-width: 0;
  height: 72rpx;
  margin: 0;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999rpx;
  color: #315b57;
  background: rgba(255, 255, 255, 0.9);
  font-size: 34rpx;
  line-height: 1;
  box-sizing: border-box;
  pointer-events: auto;
}

.round-control.confirm {
  color: #fff;
  background: #087f77;
}

.key-hint {
  margin-left: 8rpx;
  color: #8a9b99;
  font-size: 20rpx;
}

.round-control.confirm .key-hint {
  color: rgba(255, 255, 255, 0.72);
}

.compat-wrong-actions {
  width: 100%;
  max-width: 560px;
  margin: 0 auto;
  padding: 0 16rpx calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 12rpx;
  box-sizing: border-box;
}

.compat-skip,
.compat-retry {
  height: 88rpx;
  margin: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.compat-skip {
  border: 2rpx solid rgba(8, 127, 119, 0.42);
  color: #237069;
  background: rgba(255, 255, 255, 0.9);
}

.compat-retry {
  border: 0;
  color: #fff;
  background: #087f77;
}

.phonetic-pill {
  position: fixed;
  left: 50%;
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  color: #52706d;
  background: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  transform: translateX(-50%);
}

/* ---------- summary ---------- */
.summary-head {
  flex: 0 0 auto;
  height: 86rpx;
  padding: 0 20rpx;
  display: grid;
  grid-template-columns: 90rpx 1fr 90rpx;
  align-items: center;
}

.back-btn {
  padding: 0;
  border: 0;
  color: #0b1830;
  background: transparent;
  font-size: 48rpx;
  line-height: 70rpx;
  text-align: left;
}

.summary-title {
  color: #0b1830;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.tip-strip {
  flex: 0 0 auto;
  min-height: 54rpx;
  margin: 0 44rpx 26rpx;
  border-radius: 8rpx;
  color: #73808a;
  background: rgba(216, 229, 235, 0.72);
  font-size: 24rpx;
  line-height: 54rpx;
  text-align: center;
}

.summary-list {
  flex: 1;
  min-height: 0;
  padding: 0 44rpx;
  box-sizing: border-box;
}

.summary-row {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.summary-word {
  color: #0b1830;
  font-size: 28rpx;
  font-weight: 700;
}

.review-time {
  color: #7a8794;
  font-size: 26rpx;
  flex: 0 0 auto;
}

.summary-foot {
  flex: 0 0 auto;
  padding: 18rpx 32rpx calc(22rpx + env(safe-area-inset-bottom));
}

.summary-count {
  margin-bottom: 18rpx;
  color: #6b7280;
  font-size: 24rpx;
  text-align: center;
}

.primary-pill.wide {
  width: 100%;
}

@media (max-width: 360px) {
  .sage-header {
    min-height: 68rpx;
    padding-right: 24rpx;
    padding-left: 24rpx;
  }

  .sage-logo {
    width: 194rpx;
    height: 58rpx;
  }

  .growth-progress {
    padding-right: 20rpx;
    padding-left: 20rpx;
  }

  .drill-center {
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .translation {
    font-size: 25px;
  }

  .replay-pill {
    margin-top: 14rpx;
    margin-bottom: 12rpx;
  }

  .slot-row {
    gap: 8rpx;
  }
}

@media (min-width: 768px) {
  .sage-header {
    padding-right: 54px;
    padding-left: 54px;
  }

  .sage-logo {
    width: 176px;
    height: 54px;
  }

  .growth-progress {
    padding-right: 64px;
    padding-left: 64px;
  }

  .progress-count {
    font-size: 28px;
  }

  .progress-path {
    grid-template-columns: 52px minmax(0, 1fr) 52px;
  }

  .path-endpoint {
    width: 46px;
    height: 46px;
  }

  .path-icon {
    width: 25px;
    height: 25px;
  }

  .path-dot {
    width: 16px;
    height: 16px;
    flex-basis: 16px;
  }

  .path-dot.current {
    width: 22px;
    height: 22px;
    flex-basis: 22px;
  }
}

@media (max-height: 700px) {
  .sage-header {
    min-height: 58rpx;
  }

  .sage-logo {
    width: 184rpx;
    height: 54rpx;
  }

  .growth-progress {
    padding-top: 0;
  }

  .progress-count {
    font-size: 30rpx;
  }

  .progress-path {
    min-height: 58rpx;
  }

  .path-endpoint {
    width: 46rpx;
    height: 46rpx;
  }

  .path-icon {
    width: 28rpx;
    height: 28rpx;
  }

  .drill-center {
    min-height: 190rpx;
    padding-top: 0;
    padding-bottom: 4rpx;
  }

  .translation {
    font-size: clamp(22px, 6.4vw, 30px);
  }

  .replay-pill {
    height: 58rpx;
    margin-top: 10rpx;
    margin-bottom: 8rpx;
    padding-right: 18rpx;
    padding-left: 18rpx;
    font-size: 24rpx;
  }

  .replay-icon {
    width: 28rpx;
    height: 28rpx;
  }

  .word-display {
    min-height: 72rpx;
  }

  .slot {
    height: 38px;
  }

  .slot-char {
    font-size: 24px;
  }
}

@media (orientation: landscape) and (max-height: 560px) {
  .sage-header {
    min-height: 48rpx;
  }

  .growth-progress {
    display: grid;
    grid-template-columns: 110rpx minmax(0, 1fr);
    align-items: center;
    gap: 14rpx;
  }

  .progress-count {
    font-size: 26rpx;
  }

  .progress-path {
    min-height: 48rpx;
    margin: 0;
  }

  .drill-center {
    min-height: 140rpx;
    padding-right: 24rpx;
    padding-left: 24rpx;
  }

  .translation {
    font-size: 22px;
  }

  .replay-pill {
    height: 50rpx;
    margin: 6rpx 0;
  }

  .word-display {
    min-height: 58rpx;
  }
}

@media (prefers-reduced-motion: reduce) {
  .fake-cursor,
  .replay-pill {
    animation: none;
    transition: none;
  }
}
