<view class="spell-page">
  <view class="safe-top" style="height: env(safe-area-inset-top);"></view>
  <view class="queue-source-count" wx:if="{{taskId}}">
    当日布置 {{assignedCount}} 词 + 自动复习 {{reviewCount}} 词
  </view>

  <view class="loading" wx:if="{{stage === 'loading'}}">加载中...</view>

  <block wx:elif="{{stage === 'ready'}}">
    <view class="ready-shell">
      <view class="ready-title">本组单词辨识完成</view>
      <view class="ready-face">😃</view>
      <view class="ready-actions">
        <button class="primary-pill" bindtap="startDrill">强化拼写 ↵</button>
        <button class="ghost-pill" bindtap="goSummary">小结 Esc</button>
      </view>
      <label class="skip-row" wx:if="{{sourceMode === 'review'}}">
        <switch checked="{{skipSpellInReview}}" bindchange="onSkipChange" color="#f45a12"></switch>
        <text>复习时不再拼写</text>
      </label>
    </view>
  </block>

  <block wx:elif="{{stage === 'drill'}}">
    <view class="top-bar">
      <view class="count-text">{{completedCount}}/{{totalWords}}</view>
      <view class="dots">
        <view wx:for="{{progressDots}}" wx:key="index" class="dot {{item.done ? 'done' : ''}}"></view>
      </view>
      <view class="tools">
        <text class="tool-star">☆</text>
      </view>
    </view>
    <view class="mode-switch-row">
      <input-mode-switcher
        value="{{inputMode}}"
        allowed="{{inputPolicy.compatibleAllowed}}"
        bind:change="onInputModeChange"
      />
    </view>

    <view class="drill-center">
      <input wx:if="{{inputMode === 'compatible'}}" class="compat-input"
             value="{{inputValue}}"
             focus="{{!showResult}}"
             confirm-type="done"
             maxlength="-1"
             bindinput="onInput"
             bindconfirm="submitOrNext"/>

      <view class="word-display">
        <block wx:if="{{showResult && resultCorrect}}">
          <text class="answer-word success">{{displayWord}}</text><text class="fake-cursor"></text>
        </block>
        <block wx:elif="{{showResult && !resultCorrect && !resultRevealed}}">
          <view class="diff-row">
            <text wx:for="{{diffTop}}" wx:key="index" class="diff-char {{item.status}}">{{item.char}}</text>
          </view>
          <view class="wrong-copy">拼写不正确，可以重新尝试或暂时跳过</view>
        </block>
        <block wx:elif="{{showResult}}">
          <text class="answer-word {{resultCorrect ? 'success' : 'revealed'}}">{{displayWord}}</text><text class="fake-cursor"></text>
        </block>
        <block wx:else>
          <view class="slot-row">
            <block wx:for="{{spellSlots}}" wx:key="index">
              <view wx:if="{{item.type === 'space'}}" class="slot-space"></view>
              <text wx:elif="{{item.type === 'fixed'}}" class="slot-fixed">{{item.char}}</text>
              <view wx:else class="slot {{item.filled ? 'filled' : ''}} {{item.active ? 'active' : ''}} {{item.overflow ? 'overflow' : ''}}">
                <text class="slot-char">{{item.char}}</text>
              </view>
            </block>
          </view>
        </block>
      </view>

      <view class="translation">{{currentWord.translation || '暂无释义'}}</view>
      <button wx:if="{{showResult && !resultCorrect}}"
              class="spell-appeal-btn"
              disabled="{{appealSubmitted}}"
              catchtap="submitAnswerAppeal">
        {{appealSubmitted ? '已提交人工审核' : '判分有疑问？申诉'}}
      </button>
    </view>

    <view class="strict-keyboard-wrap" wx:if="{{inputMode === 'strict'}}">
      <english-keyboard
        answer="{{currentWord.word}}"
        value="{{inputValue}}"
        status="{{showResult ? (resultCorrect ? 'correct' : (resultRevealed ? 'revealed' : 'wrong')) : 'idle'}}"
        can-confirm="{{!!inputValue && !isCheckingFirstAnswer}}"
        show-wrong-actions="{{showResult && !resultCorrect && !resultRevealed}}"
        show-next="{{showResult && (resultCorrect || resultRevealed)}}"
        disabled="{{isCheckingFirstAnswer || isAdvancingWord}}"
        bind:key="onKeyboardKey"
        bind:backspace="onKeyboardBackspace"
        bind:confirm="checkAnswer"
        bind:retry="retrySpell"
        bind:skip="skipSpell"
        bind:next="nextAfterResult"
      />
    </view>

    <view wx:if="{{inputMode === 'compatible' && !(showResult && !resultCorrect && !resultRevealed)}}" class="bottom-bar" style="bottom: calc(24rpx + env(safe-area-inset-bottom));">
      <button class="round-control exit" bindtap="exitPage">×<text class="key-hint">Esc</text></button>
      <button class="round-control hint" bindtap="replayCurrentWord">
        <text wx:if="{{isLoadingAudio}}">···</text>
        <view wx:else class="ic-audio"></view>
      </button>
      <button class="round-control confirm" loading="{{isCheckingFirstAnswer || isAdvancingWord}}" disabled="{{isCheckingFirstAnswer || isAdvancingWord}}" bindtap="submitOrNext">
        {{showResult ? '→' : '✓'}}<text class="key-hint">↵</text>
      </button>
    </view>
    <view wx:if="{{inputMode === 'compatible' && showResult && !resultCorrect && !resultRevealed}}" class="compat-wrong-actions">
      <button class="compat-skip" bindtap="skipSpell">暂时跳过</button>
      <button class="compat-retry" bindtap="retrySpell">重新拼写</button>
    </view>

    <view class="phonetic-pill" wx:if="{{showResult && resultCorrect && currentWord.phonetic}}">
      {{currentWord.phonetic}}
    </view>
  </block>

  <block wx:elif="{{stage === 'summary'}}">
    <view class="summary-head">
      <button class="back-btn" bindtap="exitPage">‹</button>
      <view class="summary-title">小结</view>
      <view></view>
    </view>
    <view class="tip-strip">💡 快速回顾本组单词吧～</view>

    <view wx:if="{{taskId}}" class="server-score">
      <text wx:if="{{serverSummary}}">合并准确率：{{serverSummary.accuracy}}%（{{serverSummary.correct}} / {{serverSummary.total}}）</text>
      <text wx:else>合并成绩同步中...</text>
    </view>
    <button wx:if="{{taskId && !serverSummary}}" class="mini-btn ghost" bindtap="submitTaskResultIfNeeded">重试提交成绩</button>

    <scroll-view class="summary-list" scroll-y="true">
      <view class="summary-row" wx:for="{{summaryItems}}" wx:key="key">
        <text class="summary-word">{{item.word}}</text>
        <text class="review-time">{{item.reviewLabel}}</text>
      </view>
    </scroll-view>

    <view class="summary-foot">
      <view class="summary-count">已复习 {{completedCount}} 词，还剩 {{remainingCount}} 词</view>
      <button class="primary-pill wide" bindtap="continueReview">继续复习 ↵</button>
    </view>
  </block>
</view>
