<view class="practice-container">
  <view style="height: env(safe-area-inset-top);"></view>
  <view class="queue-source-count" wx:if="{{taskId}}">
    当日布置 {{assignedCount}} 词 + 自动复习 {{reviewCount}} 词
  </view>

  <!-- ========== GROUP PREPARATION ========== -->
  <block wx:if="{{phase === 'group_select'}}">
    <view class="status-bar group-status-bar">
      <view class="book-title">{{bookTitle}}</view>
      <view class="progress-info">共 {{totalWords}} 词</view>
    </view>

    <view class="group-setup-card">
      <text class="group-eyebrow">学习准备</text>
      <text class="group-title">这次想怎么分组？</text>
      <text class="group-desc">每组依次完成熟悉和听写，最后一组结束后统一提交整个任务。</text>

      <view class="group-plan-list">
        <view
          class="group-plan {{selectedGroupPlanKey === item.key ? 'selected' : ''}}"
          wx:for="{{groupPlans}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="selectGroupPlan"
          hover-class="group-plan-pressed"
        >
          <view class="group-plan-main">
            <view class="group-plan-title-row">
              <text class="group-plan-title">{{item.label}} 词</text>
              <text class="group-recommended" wx:if="{{item.recommended}}">推荐</text>
            </view>
            <text class="group-plan-desc">{{item.description}}</text>
          </view>
          <view class="group-radio"><view class="group-radio-dot"></view></view>
        </view>
      </view>

      <button class="submit-btn group-start-btn" bindtap="startSelectedGroupPlan">按此分组开始</button>
    </view>
  </block>

  <!-- ========== FAMILIARIZATION PHASE ========== -->
  <block wx:elif="{{phase === 'familiarize'}}">
    <!-- Header -->
    <view class="status-bar">
      <view class="book-title">{{bookTitle}}</view>
      <view class="header-right">
        <view class="progress-info">第{{currentGroupIndex + 1}}组 · {{famIndex - groupStart + 1}} / {{groupWordCount}}</view>
        <view class="timer-pill fam-timer">{{famTimerDisplay}}</view>
      </view>
    </view>

    <!-- Familiarization Card -->
    <view class="word-card fam-card">
      <!-- Audio -> English -->
      <block wx:if="{{currentMode === 'audio_to_en'}}">
        <view class="play-btn" bindtap="playFamWord" hover-class="btn-hover">
          <view class="play-icon"></view>
        </view>
        <view class="play-hint">听发音，先尝试回忆拼写</view>
        <view class="fam-prompt-label">释义提示</view>
        <view class="fam-translation">{{words[famIndex].translation || '暂无释义'}}</view>
      </block>

      <!-- Chinese -> English -->
      <block wx:elif="{{currentMode === 'zh_to_en'}}">
        <view class="fam-prompt-label">中文提示</view>
        <view class="fam-translation">{{words[famIndex].translation || '暂无释义'}}</view>
        <view class="fam-mode-hint">先在心里回忆英文表达，再点击显示答案</view>
      </block>

      <!-- English -> Chinese -->
      <block wx:else>
        <view class="fam-prompt-label">英文提示</view>
        <view class="fam-word fam-prompt-word">{{words[famIndex].word}}</view>
        <text class="fam-phonetic" wx:if="{{words[famIndex].phonetic}}">[{{words[famIndex].phonetic}}]</text>
        <view class="fam-mode-hint">先在心里回忆中文释义，再点击显示答案</view>
      </block>

      <!-- Revealed answer -->
      <view class="fam-reveal-area" wx:if="{{famRevealed}}">
        <text class="fam-answer-label">参考答案</text>
        <text class="fam-word" wx:if="{{currentMode !== 'en_to_zh'}}">{{words[famIndex].word}}</text>
        <text class="fam-translation fam-answer-translation" wx:else>{{words[famIndex].translation || '暂无释义'}}</text>
        <text class="fam-phonetic" wx:if="{{currentMode !== 'en_to_zh' && words[famIndex].phonetic}}">[{{words[famIndex].phonetic}}]</text>
      </view>

      <!-- Reveal button -->
      <button wx:if="{{!famRevealed}}" class="fam-reveal-btn" bindtap="revealFamWord">
        {{currentMode === 'en_to_zh' ? '显示释义' : '显示英文'}}
      </button>
    </view>

    <!-- Navigation: Prev / Next -->
    <view class="fam-nav">
      <button class="fam-nav-btn" bindtap="prevFamWord">上一个</button>
      <button class="fam-nav-btn" bindtap="nextFamWord">下一个</button>
    </view>

    <!-- Start Test button -->
    <view class="action-bar">
      <button class="submit-btn" bindtap="startTest">
        {{currentMode === 'audio_to_en' ? '跳过熟悉，开始听写' : '跳过熟悉，开始默写'}}
      </button>
    </view>
  </block>

  <!-- ========== BETWEEN GROUPS ========== -->
  <block wx:elif="{{phase === 'group_summary'}}">
    <view class="group-summary-card">
      <text class="group-summary-kicker">第 {{groupSummaryInfo.groupNumber}} / {{groupSummaryInfo.groupCount}} 组完成</text>
      <text class="group-summary-title">先停一下，巩固得更牢</text>
      <view class="group-summary-stats">
        <view class="group-summary-stat">
          <text class="group-summary-num">{{groupSummaryInfo.correct}}/{{groupSummaryInfo.total}}</text>
          <text class="group-summary-label">首次答对</text>
        </view>
        <view class="group-summary-stat">
          <text class="group-summary-num">{{groupSummaryInfo.accuracy}}%</text>
          <text class="group-summary-label">本组准确率</text>
        </view>
        <view class="group-summary-stat">
          <text class="group-summary-num">{{groupSummaryInfo.wrongCount}}</text>
          <text class="group-summary-label">本组错词</text>
        </view>
      </view>
      <text class="group-next-note">下一组 {{groupSummaryInfo.nextCount}} 词，将重新进入熟悉阶段。</text>
      <button class="submit-btn group-continue-btn" bindtap="continueNextGroup">继续下一组</button>
      <button class="group-later-btn" bindtap="leaveBetweenGroups">稍后继续</button>
    </view>
  </block>

  <!-- ========== TEST PHASE (existing UI, unchanged) ========== -->
  <block wx:elif="{{phase === 'test'}}">
    <!-- Header -->
    <view class="status-bar">
      <view class="book-title">{{bookTitle}}</view>
      <view class="header-right">
        <view class="progress-info">第{{currentGroupIndex + 1}}组 · {{currentIndex - groupStart + 1}} / {{groupWordCount}}</view>
        <view class="timer-pill">{{displayTime}}</view>
      </view>
    </view>

    <block wx:if="{{!finished}}">
      <!-- Word Card -->
      <view class="word-card">
        <!-- Chinese -> English -->
        <block wx:if="{{currentMode === 'zh_to_en'}}">
          <view class="translation-prompt">
            <text class="translation-chinese">{{currentWord.translation || ''}}</text>
            <text class="translation-hint">请写出对应的英文表达</text>
          </view>
          <view class="play-controls">
            <button class="mini-btn" size="mini" bindtap="playCurrentWord">重播发音</button>
          </view>
        </block>
        <!-- English -> Chinese -->
        <block wx:elif="{{currentMode === 'en_to_zh'}}">
          <view class="translation-prompt">
            <text class="translation-chinese">{{currentWord.word || ''}}</text>
            <text class="translation-hint" wx:if="{{currentWord.phonetic}}">[{{currentWord.phonetic}}]</text>
            <text class="translation-hint">请写出对应的中文释义</text>
          </view>
          <view class="play-controls" wx:if="{{reviewingWrongWords}}">
            <button class="mini-btn" size="mini" bindtap="playCurrentWord">重播发音</button>
          </view>
        </block>
        <!-- Audio dictation -->
        <block wx:else>
          <view class="play-btn" bindtap="playCurrentWord" hover-class="btn-hover">
            <view class="play-icon"></view>
          </view>
          <view class="play-hint">点击播放单词发音</view>
          <view class="play-controls">
            <button class="mini-btn" size="mini" bindtap="playCurrentWord">重播</button>
            <view class="switch-row">
              <text>连播</text>
              <switch checked="{{autoPlay}}" bindchange="onToggleAutoPlay"></switch>
            </view>
          </view>
        </block>

        <!-- Input Area (Only show when not revealing answer) -->
        <view class="input-area" wx:if="{{!showResult}}">
          <input class="word-input {{inputError ? 'incorrect' : ''}}"
                 placeholder="{{currentMode === 'en_to_zh' ? '输入中文释义' : (currentMode === 'zh_to_en' ? '输入英文表达' : '听音输入单词')}}"
                 focus="{{inputFocus}}"
                 value="{{inputValue}}"
                 disabled="{{isCheckingFirstAnswer}}"
                 maxlength="-1"
                 bindinput="onInput"
                 confirm-type="done"
                 bindconfirm="checkAnswer"/>
          <view class="hint-card" wx:if="{{showHint && currentMode === 'audio_to_en'}}">
            <text class="hint-label">提示</text>
            <text class="hint-text">{{currentWord.translation || '暂无释义'}}</text>
          </view>
        </view>

        <!-- Result Feedback (Show after check) -->
        <view class="result-feedback" wx:else>
          <view class="result-status {{isCorrect ? 'ok' : 'bad'}}">
            {{isCorrect ? '✓ 回答正确' : '✗ 回答错误'}}
          </view>

          <view class="vocab-card">
            <view class="vocab-head">
              <text class="correct-word">{{currentWord.word}}</text>
              <text class="phonetic" wx:if="{{currentWord.phonetic}}">[{{currentWord.phonetic}}]</text>
            </view>
            <view class="core-meaning">
              <text class="vocab-label">核心义：</text>{{currentWord.core_meaning_zh || currentWord.translation || '暂无释义'}}
            </view>
            <view class="usage-chip" wx:if="{{currentWord.usage_pattern}}">
              搭配 / 句型：{{currentWord.usage_pattern}}
            </view>
            <view class="example-block" wx:if="{{currentWord.example_en}}">
              <view class="example-label">例句</view>
              <text class="example-en">{{currentWord.example_en}}</text>
              <text class="example-zh" wx:if="{{currentWord.example_zh}}">{{currentWord.example_zh}}</text>
            </view>
            <view class="usage-note" wx:if="{{currentWord.usage_note}}">
              <text class="vocab-label">用法提示：</text>{{currentWord.usage_note}}
            </view>
            <view class="example-report"
                  wx:if="{{currentWord.id && (currentWord.core_meaning_zh || currentWord.usage_pattern || currentWord.example_en || currentWord.example_zh || currentWord.usage_note)}}"
                  bindtap="reportExample"
                  data-id="{{currentWord.id}}">
              这条内容有问题？
            </view>
          </view>

          <view class="compare-block">
            <view class="answer-row wrong">你的答案：{{userAnswer || '（空）'}}</view>
            <view class="answer-row correct">参考答案：{{currentMode === 'en_to_zh' ? (currentWord.translation || '暂无释义') : currentWord.word}}</view>
            <button wx:if="{{!isCorrect}}"
                    class="answer-appeal-btn"
                    disabled="{{appealSubmitted}}"
                    bindtap="submitAnswerAppeal">
              {{appealSubmitted ? '已提交人工审核' : '判分有疑问？申诉'}}
            </button>
          </view>
        </view>
      </view>

      <!-- Action Bar -->
      <view class="action-bar">
        <button wx:if="{{!showResult}}" class="submit-btn" loading="{{isCheckingFirstAnswer}}" disabled="{{isCheckingFirstAnswer}}" bindtap="checkAnswer">提交</button>
        <button wx:else class="submit-btn next" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="nextWord">
          {{currentIndex + 1 >= groupEnd ? (hasMoreGroups ? '完成本组' : '完成练习') : '下一个'}}
        </button>
      </view>
    </block>

    <!-- Summary & Wrong Words -->
    <view wx:if="{{finished}}" class="summary-panel">
      <view class="summary-title">本轮完成</view>
      <view class="summary-row">准确率：{{summaryInfo.accuracy}}%（{{summaryInfo.correct}} / {{summaryInfo.total}}）</view>
      <view class="summary-row" wx:if="{{summaryInfo.wrongCount > 0}}">
        错词：{{summaryInfo.wrongCount}} 个
      </view>
      <view class="summary-note" wx:if="{{summaryInfo.wrongCount > 0}}">
        已自动收录到错词本（累计 {{notebookCount}} 词）
      </view>

      <view class="wrong-list" wx:if="{{wrongWordsDetail.length > 0}}">
        <view class="list-title">错词列表</view>
        <view class="tag-list">
          <view class="tag" wx:for="{{wrongWordsDetail}}" wx:key="word">
            {{item.word}}
          </view>
        </view>
        <button class="mini-btn ghost" style="margin-top:16rpx" bindtap="restartWrongWords">开始错词重练</button>
      </view>

      <button class="submit-btn" style="margin-top:20rpx" bindtap="returnAfterFinish">返回</button>
    </view>
  </block>
</view>
