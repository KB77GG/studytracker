<view class="page">
  <view class="loading" wx:if="{{loading}}">加载中…</view>

  <view class="error" wx:elif="{{loadError}}">
    <text>{{loadError}}</text>
    <button class="btn" bindtap="fetchReviewQueue">重试</button>
  </view>

  <view class="empty" wx:elif="{{!loading && totalWords === 0}}">
    <view class="empty-emoji">🎉</view>
    <view class="empty-title">今日没有待复习的词</view>
    <view class="empty-desc">继续保持，等下一个复习窗口到来。</view>
    <button class="btn" bindtap="backToHome">返回首页</button>
  </view>

  <block wx:elif="{{!finished}}">
    <view class="header">
      <view class="progress-text">{{currentIndex + 1}} / {{totalWords}}</view>
      <view class="level-tag" wx:if="{{levelLabel}}">{{levelLabel}}</view>
      <button class="spell-link" bindtap="startSpellReview">强化拼写</button>
    </view>

    <view class="card">
      <block wx:if="{{currentMode === 'en_to_zh'}}">
        <view class="prompt-word">{{currentWord.word}}</view>
        <view class="prompt-phonetic" wx:if="{{currentWord.phonetic}}">[{{currentWord.phonetic}}]</view>
        <view class="mode-tag">看英文 → 写中文释义</view>
      </block>

      <block wx:elif="{{currentMode === 'zh_to_en'}}">
        <view class="prompt-chinese">{{currentWord.translation}}</view>
        <view class="mode-tag">看中文 → 写英文表达</view>
      </block>

      <block wx:else>
        <view class="audio-area">
          <view class="play-btn" bindtap="replayAudio">▶</view>
          <view class="play-hint">点击播放发音</view>
        </view>
        <view class="mode-tag">听音 → 写英文单词</view>
      </block>

      <view class="review-input-mode" wx:if="{{isEnglishSpelling && inputPolicy.compatibleAllowed}}">
        <input-mode-switcher
          value="{{inputMode}}"
          allowed="{{inputPolicy.compatibleAllowed}}"
          bind:change="onInputModeChange"
        />
      </view>

      <view class="input-row" wx:if="{{!showResult && (!isEnglishSpelling || inputMode === 'compatible')}}">
        <input class="word-input"
               placeholder="{{modeHint}}"
               value="{{inputValue}}"
               bindinput="onInput"
               confirm-type="done"
               bindconfirm="checkAnswer"/>
      </view>

      <view class="english-wrong-feedback" wx:elif="{{showResult && isEnglishSpelling && !isCorrect && !resultRevealed}}">
        <view class="result-flag bad">✗ 拼写不正确</view>
        <view class="answer-block">
          <view class="answer-row"><text class="label">你的答案：</text>{{userAnswer || '（空）'}}</view>
          <view class="wrong-guidance">可以重新拼写，或暂时跳过后查看正确拼写。</view>
          <button class="answer-appeal-btn"
                  disabled="{{appealSubmitted}}"
                  bindtap="submitAnswerAppeal">
            {{appealSubmitted ? '已提交人工审核' : '判分有疑问？申诉'}}
          </button>
        </view>
      </view>

      <view class="result" wx:elif="{{showResult}}">
        <view class="result-flag {{isCorrect ? 'ok' : 'bad'}}">
          {{isCorrect ? '✓ 答对了' : '✗ 答错了'}}
        </view>
        <view class="vocab-card">
          <view class="vocab-head">
            <text class="vocab-word">{{currentWord.word || '-'}}</text>
            <text class="prompt-phonetic" wx:if="{{currentWord.phonetic}}">[{{currentWord.phonetic}}]</text>
          </view>
          <view class="core-meaning">
            <text class="label">核心义：</text>{{currentWord.core_meaning_zh || currentWord.translation || '-'}}
          </view>
          <view class="usage-chip" wx:if="{{currentWord.usage_pattern}}">
            搭配 / 句型：{{currentWord.usage_pattern}}
          </view>
          <view class="example-block" wx:if="{{currentWord.example_en}}">
            <view class="example-label">例句</view>
            <text class="example-en">{{currentWord.example_en}}</text>
            <text class="example-zh" wx:if="{{currentWord.example_zh}}">{{currentWord.example_zh}}</text>
          </view>
          <view class="usage-note" wx:if="{{currentWord.usage_note}}">
            <text class="label">用法提示：</text>{{currentWord.usage_note}}
          </view>
          <view class="example-report"
                wx:if="{{(currentWord.word_id || currentWord.id) && (currentWord.core_meaning_zh || currentWord.usage_pattern || currentWord.example_en || currentWord.example_zh || currentWord.usage_note)}}"
                bindtap="reportExample"
                data-id="{{currentWord.word_id || currentWord.id}}">
            这条内容有问题？
          </view>
        </view>
        <view class="answer-block">
          <view class="answer-row"><text class="label">你的答案：</text>{{userAnswer || '（空）'}}</view>
          <view class="answer-row"><text class="label">参考答案：</text>{{correctAnswer || '-'}}</view>
          <view class="answer-row" wx:if="{{currentMode !== 'en_to_zh'}}">
            <text class="label">中文释义：</text>{{currentWord.translation || '-'}}
          </view>
          <view class="answer-row" wx:if="{{currentMode === 'en_to_zh'}}">
            <text class="label">英文单词：</text>{{currentWord.word || '-'}}
            <text wx:if="{{currentWord.phonetic}}"> [{{currentWord.phonetic}}]</text>
          </view>
          <button wx:if="{{!isCorrect}}"
                  class="answer-appeal-btn"
                  disabled="{{appealSubmitted}}"
                  bindtap="submitAnswerAppeal">
            {{appealSubmitted ? '已提交人工审核' : '判分有疑问？申诉'}}
          </button>
        </view>
      </view>
    </view>

    <english-keyboard
      wx:if="{{isEnglishSpelling && inputMode === 'strict'}}"
      answer="{{currentWord.word || ''}}"
      value="{{inputValue}}"
      status="{{showResult ? (isCorrect ? 'correct' : (resultRevealed ? 'revealed' : 'wrong')) : 'idle'}}"
      can-confirm="{{!!inputValue}}"
      show-wrong-actions="{{showResult && !isCorrect && !resultRevealed}}"
      show-next="{{showResult && (isCorrect || resultRevealed)}}"
      bind:key="onKeyboardKey"
      bind:backspace="onKeyboardBackspace"
      bind:confirm="checkAnswer"
      bind:retry="retrySpelling"
      bind:skip="skipSpelling"
      bind:next="nextWord"
    />
    <view class="compat-review-actions" wx:if="{{isEnglishSpelling && inputMode === 'compatible' && showResult && !isCorrect && !resultRevealed}}">
      <button class="compat-skip" bindtap="skipSpelling">暂时跳过</button>
      <button class="compat-retry" bindtap="retrySpelling">重新拼写</button>
    </view>
    <view class="action-bar" wx:if="{{!isEnglishSpelling || inputMode !== 'strict'}}">
      <button wx:if="{{!showResult && (!isEnglishSpelling || inputMode !== 'strict')}}" class="btn primary" bindtap="checkAnswer">提交</button>
      <button wx:elif="{{showResult && !(isEnglishSpelling && !isCorrect && !resultRevealed) && (!isEnglishSpelling || inputMode !== 'strict')}}" class="btn primary" bindtap="nextWord">
        {{currentIndex + 1 === totalWords ? '完成本轮' : '下一个'}}
      </button>
    </view>
  </block>

  <view class="summary" wx:elif="{{finished}}">
    <view class="summary-title">本轮复习完成</view>
    <view class="summary-row">共 {{totalWords}} 词</view>
    <view class="summary-row">答对 {{correctCount}} / 答错 {{wrongCount}}</view>
    <view class="summary-tip">
      答对的词会按 1d / 3d / 7d / 14d 节奏自动安排下次复习；答错的词会立即回到第 1 关。
    </view>
    <view class="summary-actions">
      <button class="btn primary" bindtap="restartReview">再来一组</button>
      <button class="btn" bindtap="backToHome">返回首页</button>
    </view>
  </view>
</view>
