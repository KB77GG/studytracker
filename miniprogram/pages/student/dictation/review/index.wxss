.page {
  min-height: 100vh;
  width: 100%;
  max-width: 760px;
  margin: 0 auto;
  padding: 40rpx 32rpx 80rpx;
  background: #f4f6f9;
  box-sizing: border-box;
}

.loading,
.empty,
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 40rpx;
  color: #6b6e74;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2330;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  margin-bottom: 32rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2330;
}

.level-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  background: #ffe9d6;
  color: #c0581a;
  font-weight: 700;
}

.spell-link {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #20756F;
  border: 2rpx solid rgba(32, 117, 111, 0.24);
  font-size: 24rpx;
  font-weight: 700;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 56rpx 36rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 30, 60, 0.08);
}

.prompt-word {
  font-size: 64rpx;
  font-weight: 900;
  text-align: center;
  color: #102043;
  letter-spacing: 2rpx;
}

.prompt-phonetic {
  font-size: 30rpx;
  color: #74798a;
  text-align: center;
  margin-top: 12rpx;
}

.prompt-chinese {
  font-size: 54rpx;
  font-weight: 800;
  text-align: center;
  color: #102043;
  line-height: 1.35;
}

.audio-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 10rpx;
}

.play-btn {
  width: 140rpx;
  height: 140rpx;
  line-height: 140rpx;
  text-align: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #1473e6, #4a93ff);
  color: #fff;
  font-size: 56rpx;
  box-shadow: 0 12rpx 24rpx rgba(20, 115, 230, 0.32);
}

.play-hint {
  font-size: 26rpx;
  color: #6b6e74;
  margin-top: 18rpx;
}

.mode-tag {
  text-align: center;
  font-size: 24rpx;
  color: #8a8f9c;
  margin-top: 28rpx;
}

.review-input-mode {
  margin-top: 26rpx;
}

.english-wrong-feedback {
  margin-top: 36rpx;
}

.wrong-guidance {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.compat-review-actions {
  display: flex;
  gap: 16rpx;
  max-width: 640px;
  margin: 24rpx auto 0;
}

.compat-review-actions button {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.compat-review-actions button::after {
  border: 0;
}

.compat-skip {
  color: #237069;
  background: #eef7f5;
  border: 2rpx solid rgba(8, 127, 119, 0.35);
}

.compat-retry {
  color: #fff;
  background: #087f77;
}

.input-row {
  margin-top: 36rpx;
}

.word-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  border: 2rpx solid #d8dce5;
  border-radius: 16rpx;
  background: #fafbfd;
  box-sizing: border-box;
}

.result {
  margin-top: 36rpx;
}

.result-flag {
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.result-flag.ok {
  color: #2ea043;
}

.result-flag.bad {
  color: #d83a3a;
}

.answer-block {
  background: #f3f5fa;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  margin-top: 20rpx;
}

.answer-row {
  font-size: 28rpx;
  color: #1f2330;
  line-height: 1.6;
}

.answer-row .label {
  color: #74798a;
  font-weight: 600;
  margin-right: 4rpx;
}

.answer-appeal-btn {
  width: auto;
  min-height: 58rpx;
  margin: 16rpx 0 0;
  padding: 0 22rpx;
  border: 2rpx solid #d7dde8;
  border-radius: 999rpx;
  background: #fff;
  color: #526075;
  font-size: 24rpx;
  line-height: 56rpx;
}

.answer-appeal-btn::after {
  border: 0;
}

.answer-appeal-btn[disabled] {
  background: #f3f5f8;
  color: #8a94a6;
}

.vocab-card {
  background: #fff;
  border: 2rpx solid #edf0f5;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.vocab-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.vocab-word {
  max-width: 100%;
  overflow-wrap: anywhere;
  word-break: break-word;
  font-size: 46rpx;
  font-weight: 800;
  color: #102043;
}

.core-meaning {
  font-size: 30rpx;
  color: #1f2330;
  font-weight: 700;
  line-height: 1.55;
}

.usage-chip {
  display: inline-flex;
  max-width: 100%;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  background: #eef2f7;
  border-radius: 999rpx;
  color: #374151;
  font-size: 24rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.example-block {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  background: #f4f7fb;
  border-left: 4rpx solid #1473e6;
  border-radius: 12rpx;
}

.example-label {
  font-size: 22rpx;
  color: #667085;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.example-en {
  display: block;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.55;
}

.example-zh {
  display: block;
  margin-top: 6rpx;
  padding-left: 18rpx;
  font-size: 25rpx;
  color: #667085;
  line-height: 1.5;
}

.usage-note {
  margin-top: 16rpx;
  font-size: 25rpx;
  color: #667085;
  line-height: 1.5;
}

.example-report {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #1473e6;
}

.action-bar {
  margin-top: 40rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #e7eaf2;
  color: #1f2330;
  font-size: 30rpx;
  font-weight: 700;
}

.btn.primary {
  background: linear-gradient(135deg, #1473e6, #4a93ff);
  color: #fff;
}

.summary {
  background: #fff;
  border-radius: 32rpx;
  padding: 56rpx 36rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 30, 60, 0.08);
  text-align: center;
}

.summary-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #102043;
  margin-bottom: 18rpx;
}

.summary-row {
  font-size: 28rpx;
  color: #3a3f4d;
  margin-bottom: 10rpx;
}

.summary-tip {
  font-size: 24rpx;
  color: #74798a;
  margin: 22rpx auto 32rpx;
  line-height: 1.6;
}

.summary-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

@media (max-width: 360px) {
  .page {
    padding-left: 14px;
    padding-right: 14px;
  }
}
