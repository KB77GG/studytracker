<!-- pages/student/dictation/index.wxml -->
<view class="container">
  <view class="header">
    <view class="title">听写词库</view>
    <view class="subtitle">选择词书开始练习</view>
  </view>

  <view class="book-list">
    <view class="book-card" wx:for="{{books}}" wx:key="id" bindtap="startPractice" data-id="{{item.id}}" data-title="{{item.title}}">
      <view class="book-icon">📚</view>
      <view class="book-info">
        <view class="book-name">{{item.title}}</view>
        <view class="book-meta">
          <text class="count">{{item.word_count}} 词</text>
          <text class="divider">|</text>
          <text class="desc">{{item.description || '暂无描述'}}</text>
        </view>
      </view>
      <view class="book-actions">
        <view class="action-btn secondary" catchtap="startSpell" data-id="{{item.id}}" data-title="{{item.title}}">拼写</view>
        <view class="action-btn">练习</view>
      </view>
    </view>
    
    <view wx:if="{{books.length === 0}}" class="empty-state">
      <text>暂无听写词库</text>
    </view>
  </view>
</view>
