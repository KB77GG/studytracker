.container {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 68rpx 36rpx 54rpx;
  overflow: visible;
  color: #0b1830;
  background:
    radial-gradient(circle at 8% 0%, rgba(8, 127, 119, 0.14), transparent 360rpx),
    radial-gradient(circle at 100% 22%, rgba(8, 127, 119, 0.08), transparent 420rpx),
    linear-gradient(180deg, #fbfefe 0%, #f5faf9 55%, #edf7f6 100%);
}

.bg-circle-1,
.bg-circle-2 {
  position: absolute;
  z-index: 0;
  border-radius: 50%;
  pointer-events: none;
}

.bg-circle-1 {
  width: 560rpx;
  height: 560rpx;
  top: -250rpx;
  left: -210rpx;
  background: rgba(8, 127, 119, 0.10);
}

.bg-circle-2 {
  width: 620rpx;
  height: 620rpx;
  top: 300rpx;
  right: -360rpx;
  background: rgba(8, 127, 119, 0.07);
}

.dot-grid {
  position: absolute;
  z-index: 0;
  top: 78rpx;
  right: 78rpx;
  width: 120rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14rpx;
  opacity: 0.46;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #93cfc8;
}

.bottom-flourish {
  position: absolute;
  z-index: 0;
  left: -80rpx;
  bottom: -120rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(8, 127, 119, 0.18);
  background: radial-gradient(circle at 50% 50%, rgba(8, 127, 119, 0.08), transparent 65%);
  pointer-events: none;
}

.hero,
.main-card {
  position: relative;
  z-index: 1;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.app-name {
  color: #087f77;
  font-family: "Avenir Next", "DIN Alternate", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: 0;
  text-shadow: 0 10rpx 24rpx rgba(8, 127, 119, 0.12);
}

.sub-name {
  margin-top: 12rpx;
  color: #26384d;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}

.slogan {
  margin-top: 20rpx;
  color: #78aba6;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-confirm {
  margin-bottom: 30rpx;
}

.hero-confirm .app-name {
  font-size: 56rpx;
}

.hero-confirm .sub-name {
  font-size: 26rpx;
}

.hero-confirm .slogan {
  display: none;
}

.main-card {
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 34rpx 42rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 236, 239, 0.92);
  box-shadow: 0 28rpx 72rpx rgba(20, 44, 58, 0.10);
}

.welcome-card {
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.auth-card {
  animation: cardIn 180ms ease-out both;
}

@keyframes cardIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.intro-content,
.login-section,
.role-section,
.bind-existing-section,
.bind-section {
  display: flex;
  flex-direction: column;
}

.section-title {
  color: #0b1830;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-title {
  display: block;
  text-align: center;
  margin-bottom: 18rpx;
}

.section-subtitle {
  display: block;
  margin-bottom: 34rpx;
  color: #64748b;
  text-align: center;
  font-size: 25rpx;
  line-height: 1.6;
}

.entry-card {
  display: flex;
  flex-direction: column;
  padding: 36rpx 30rpx 30rpx;
  border: 1rpx solid rgba(226, 236, 239, 0.96);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 60rpx rgba(20, 44, 58, 0.10);
}

.guest-access-note {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e7f6f3;
  color: #087f77;
  font-size: 22rpx;
  font-weight: 800;
}

.welcome-title {
  margin-top: 22rpx;
  color: #0b1830;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
}

.welcome-desc {
  margin: 14rpx 0 28rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.6;
}

.role-shortcuts {
  margin-top: 26rpx;
}

.shortcut-label,
.feature-heading {
  display: block;
  color: #7b8da3;
  font-size: 22rpx;
  font-weight: 800;
}

.shortcut-grid {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  gap: 14rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.role-shortcut {
  width: 0;
  flex: 1 1 0;
  min-width: 0;
  min-height: 104rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  margin: 0;
  padding: 18rpx 20rpx;
  border: 1rpx solid #dce9e7;
  border-radius: 20rpx;
  background: #f7fbfa;
  text-align: left;
}

.login-entry::after,
.guest-entry::after,
.auth-back::after {
  border: 0;
}

.role-shortcut-active {
  background: #edf7f5;
  border-color: #aed8d3;
}

.shortcut-title {
  color: #163c3a;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.3;
}

.shortcut-desc {
  margin-top: 6rpx;
  color: #74858f;
  font-size: 21rpx;
  line-height: 1.35;
}

.login-entry {
  min-height: 68rpx;
  margin: 24rpx 0 0;
  padding: 0;
  color: #087f77;
  background: transparent;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
}

.feature-heading {
  margin: 34rpx 4rpx 16rpx;
}

.feature-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.feature-item {
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  min-height: 170rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
  padding: 24rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid #e5edf0;
  border-top: 6rpx solid #68d2c9;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 32rpx rgba(20, 44, 58, 0.06);
}

.feature-item.accent-blue {
  border-top-color: #7cb8ff;
}

.feature-item.accent-amber {
  border-top-color: #ffc56f;
}

.feature-item.accent-violet {
  border-top-color: #a997ff;
}

.feature-icon {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background-color: #e8f7f4;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 34rpx 34rpx;
}

.accent-blue .feature-icon {
  background-color: #eaf4ff;
}

.accent-amber .feature-icon {
  background-color: #fff2dd;
}

.accent-violet .feature-icon {
  background-color: #f1efff;
}

.icon-task {
  background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23087f77' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Crect x='4' y='5' width='16' height='16' rx='2'/%3E%3Cpath d='M8 3v4M16 3v4'/%3E%3Cpath d='M8 13l2.5 2.5L16 10'/%3E%3C/svg%3E");
}

.icon-schedule {
  background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%231d7fe5' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Crect x='3' y='5' width='18' height='16' rx='2'/%3E%3Cpath d='M16 3v4M8 3v4M3 10h18'/%3E%3C/svg%3E");
}

.icon-feedback {
  background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23d97706' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'/%3E%3C/svg%3E");
}

.icon-data {
  background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236d5bd6' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Cline x1='6' y1='20' x2='6' y2='14'/%3E%3Cline x1='12' y1='20' x2='12' y2='10'/%3E%3Cline x1='18' y1='20' x2='18' y2='4'/%3E%3C/svg%3E");
}

.feature-texts {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.feature-title {
  color: #0b1830;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.35;
}

.feature-desc {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.42;
}

.privacy-section {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
}

.cta-stack .privacy-section {
  margin-bottom: 16rpx;
}

.confirm-privacy {
  margin-top: 8rpx;
}

.auth-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 34rpx;
}

.auth-back {
  width: auto;
  min-height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #52637a;
  background: #f2f6f6;
  font-size: 23rpx;
  line-height: 56rpx;
}

.auth-kicker {
  color: #087f77;
  font-size: 23rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.auth-title {
  margin-bottom: 12rpx;
  text-align: left;
  font-size: 46rpx;
}

.auth-subtitle {
  margin-bottom: 26rpx;
  text-align: left;
}

.auth-benefits {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 28rpx;
}

.auth-benefit {
  display: block;
  padding: 13rpx 6rpx;
  border-radius: 14rpx;
  background: #eef8f6;
  color: #28736e;
  text-align: center;
  font-size: 21rpx;
  font-weight: 800;
}

.auth-privacy {
  margin: 0 0 22rpx;
  padding: 20rpx;
  border: 1rpx solid #e5ecee;
  border-radius: 18rpx;
  background: #f8fafb;
}

.guest-entry {
  min-height: 72rpx;
  margin: 14rpx 0 0;
  padding: 0;
  color: #087f77;
  background: transparent;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.auth-footnote {
  display: block;
  margin-top: 12rpx;
  color: #8997a6;
  text-align: center;
  font-size: 21rpx;
  line-height: 1.5;
}

.privacy-label {
  display: flex;
  align-items: flex-start;
  min-height: 48rpx;
}

.privacy-text {
  flex: 1;
  margin-left: 10rpx;
  color: #6b7890;
  font-size: 25rpx;
  line-height: 1.55;
}

.legal-links {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
  padding-left: 56rpx;
}

.legal-link {
  width: auto;
  min-height: 54rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #b9dcd7;
  border-radius: 999rpx;
  background: #ffffff;
  color: #087f77;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.legal-link::after {
  border: none;
}

.btn-start,
.btn-primary,
.btn-ghost,
.btn-back,
.btn-cancel,
.btn-confirm {
  width: 100%;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.btn-start,
.btn-primary,
.btn-confirm {
  color: #fff;
  background: linear-gradient(145deg, #18a99e, #007d76);
  box-shadow: 0 16rpx 34rpx rgba(8, 127, 119, 0.22);
}

.btn-ghost,
.btn-back,
.btn-cancel {
  margin-top: 18rpx;
  color: #087f77;
  background: #fff;
  border: 2rpx solid #087f77;
}

.btn-back,
.btn-cancel {
  color: #64748b;
  border-color: #dbe5e8;
  background: #f8fafb;
}

.btn-start::after,
.btn-primary::after,
.btn-ghost::after,
.btn-back::after,
.btn-cancel::after,
.btn-confirm::after {
  border: none;
}

.btn-disabled {
  background: #d6e2e1 !important;
  color: #ffffff !important;
  box-shadow: none !important;
  opacity: 1;
}

.login-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
  color: #7b8da3;
  font-size: 24rpx;
  line-height: 1.5;
}

.shield-mark {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
  background-color: #e8f7f4;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23087f77' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M12 2 4 5v6c0 5 3.5 9.4 8 11 4.5-1.6 8-6 8-11V5l-8-3z'/%3E%3Cpath d='m9 12 2 2 4-4'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 26rpx 26rpx;
}

.role-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 18rpx;
}

.role-item {
  min-height: 118rpx;
  display: grid;
  grid-template-columns: 74rpx 1fr;
  column-gap: 22rpx;
  align-items: center;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid #e5edf0;
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(20, 44, 58, 0.05);
}

.role-item:active {
  transform: scale(0.985);
}

.role-icon-bg {
  width: 74rpx;
  height: 74rpx;
  grid-row: span 2;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #087f77;
  background: #e8f7f4;
  font-size: 28rpx;
  font-weight: 900;
}

.role-label {
  color: #0b1830;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.role-desc {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.4;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  margin: 0 0 12rpx 6rpx;
  color: #52637a;
  font-size: 24rpx;
  font-weight: 800;
}

.input-field {
  min-height: 86rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e5edf0;
  background: #f8fafb;
  color: #0b1830;
  font-size: 28rpx;
}

.action-buttons {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.preview-role-panel,
.bound-preview {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #d9ece9;
  border-radius: 24rpx;
  background: #f5fbfa;
}

.preview-title {
  display: block;
  color: #0b1830;
  font-size: 28rpx;
  font-weight: 900;
}

.preview-desc,
.bound-preview-text {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.preview-role-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.preview-role-grid.compact {
  margin-top: 16rpx;
}

.preview-role-btn {
  min-width: 0;
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border-radius: 18rpx;
  color: #087f77;
  background: #fff;
  border: 1rpx solid #bfe0dc;
  font-size: 25rpx;
  font-weight: 800;
}

.preview-role-btn::after {
  border: none;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  margin-top: 0;
  font-size: 28rpx;
}

@media (max-width: 340px) {
  .container {
    padding-left: 26rpx;
    padding-right: 26rpx;
  }

  .app-name {
    font-size: 62rpx;
  }

  .sub-name,
  .slogan {
    font-size: 25rpx;
  }

  .main-card {
    padding: 34rpx 26rpx 38rpx;
  }

  .welcome-card {
    padding: 0;
  }

  .feature-title {
    font-size: 28rpx;
  }

  .feature-desc {
    font-size: 22rpx;
  }
}

.container.welcome-mode {
  min-height: 100vh;
  padding: 0 0 54rpx;
  overflow-x: hidden;
  color: #1c1c1c;
  background: #ffffff;
}

.welcome-mode .bg-circle-1,
.welcome-mode .bg-circle-2,
.welcome-mode .bottom-flourish {
  display: none;
}

.welcome-mode .dot-grid {
  z-index: 2;
  top: 64rpx;
  right: 46rpx;
  width: 112rpx;
  gap: 12rpx;
  opacity: 0.64;
}

.welcome-mode .dot {
  width: 14rpx;
  height: 14rpx;
  background: #bfe0dd;
}

.welcome-mode .dot:nth-child(2n),
.welcome-mode .dot:nth-child(7n) {
  background: #7fc4bf;
}

.welcome-mode .dot:nth-child(5n) {
  background: #e6f2f1;
}

.welcome-mode .hero {
  box-sizing: border-box;
  min-height: 352rpx;
  margin: 0;
  padding: 76rpx 48rpx 94rpx;
  align-items: flex-start;
  background: linear-gradient(180deg, #e6f2f1 0%, #ffffff 100%);
}

.welcome-mode .app-name {
  color: #2e8b87;
  font-size: 84rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 0;
  text-shadow: none;
}

.welcome-mode .sub-name {
  margin-top: 20rpx;
  color: #444444;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.welcome-mode .slogan {
  margin-top: 6rpx;
  color: #888888;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.35;
}

.welcome-mode .main-card,
.welcome-mode .welcome-card {
  width: 100%;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.welcome-mode .entry-card {
  margin: -36rpx 32rpx 0;
  padding: 44rpx 40rpx 40rpx;
  border: 0;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.09);
}

.welcome-mode .guest-access-note {
  min-height: 58rpx;
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  align-self: flex-start;
  box-sizing: border-box;
  padding: 0 26rpx 0 14rpx;
  border-radius: 999rpx;
  background: #e6f2f1;
  color: #1b5851;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
}

.welcome-mode .guest-access-note .shield-mark {
  display: block;
  width: 30rpx;
  height: 30rpx;
  border-radius: 10rpx;
  background-color: transparent;
  background-size: 28rpx 28rpx;
}

.welcome-mode .welcome-title {
  display: flex;
  flex-direction: column;
  margin-top: 32rpx;
  color: #1c1c1c;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.3;
  letter-spacing: 0;
}

.welcome-mode .welcome-title-line {
  display: block;
}

.welcome-mode .welcome-desc {
  margin: 16rpx 0 36rpx;
  color: #555555;
  font-size: 28rpx;
