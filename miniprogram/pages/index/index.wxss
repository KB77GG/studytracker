page {
  background: #f4f8f8;
}

.container {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 86rpx 36rpx 54rpx;
  overflow: visible;
  color: #0b1830;
  background:
    radial-gradient(circle at 8% 0%, rgba(8, 127, 119, 0.14), transparent 360rpx),
    radial-gradient(circle at 100% 22%, rgba(8, 127, 119, 0.08), transparent 420rpx),
    linear-gradient(180deg, #fbfefe 0%, #f5faf9 55%, #edf7f6 100%);
}

.bg-circle-1,
.bg-circle-2 {
  position: absolute;
  z-index: 0;
  border-radius: 50%;
  pointer-events: none;
}

.bg-circle-1 {
  width: 560rpx;
  height: 560rpx;
  top: -250rpx;
  left: -210rpx;
  background: rgba(8, 127, 119, 0.10);
}

.bg-circle-2 {
  width: 620rpx;
  height: 620rpx;
  top: 300rpx;
  right: -360rpx;
  background: rgba(8, 127, 119, 0.07);
}

.dot-grid {
  position: absolute;
  z-index: 0;
  top: 78rpx;
  right: 78rpx;
  width: 120rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14rpx;
  opacity: 0.46;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #93cfc8;
}

.hero,
.main-card {
  position: relative;
  z-index: 1;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 42rpx;
}

.app-name {
  color: #087f77;
  font-family: "Avenir Next", "DIN Alternate", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: 0;
  text-shadow: 0 10rpx 24rpx rgba(8, 127, 119, 0.12);
}

.sub-name {
  margin-top: 18rpx;
  color: #26384d;
  font-size: 31rpx;
  font-weight: 500;
  line-height: 1.4;
}

.slogan {
  margin-top: 32rpx;
  color: #78aba6;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-confirm {
  margin-bottom: 30rpx;
}

.hero-confirm .app-name {
  font-size: 56rpx;
}

.hero-confirm .sub-name {
  font-size: 26rpx;
}

.hero-confirm .slogan {
  display: none;
}

.main-card {
  width: 100%;
  box-sizing: border-box;
  padding: 42rpx 36rpx 44rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(226, 236, 239, 0.92);
  box-shadow: 0 28rpx 72rpx rgba(20, 44, 58, 0.10);
}

.intro-content,
.login-section,
.role-section,
.bind-existing-section,
.bind-section {
  display: flex;
  flex-direction: column;
}

.intro-title-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.intro-mark {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #18a99e, #007d76);
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(8, 127, 119, 0.20);
}

.intro-title,
.section-title {
  color: #0b1830;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-title {
  display: block;
  text-align: center;
  margin-bottom: 18rpx;
}

.section-subtitle {
  display: block;
  margin-bottom: 34rpx;
  color: #64748b;
  text-align: center;
  font-size: 25rpx;
  line-height: 1.6;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 40rpx;
}

.feature-item {
  position: relative;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 22rpx 26rpx 22rpx 28rpx;
  border-radius: 26rpx;
  border: 1rpx solid #e5edf0;
  border-left: 8rpx solid #68d2c9;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 32rpx rgba(20, 44, 58, 0.06);
}

.feature-item.accent-blue {
  border-left-color: #7cb8ff;
}

.feature-item.accent-amber {
  border-left-color: #ffc56f;
}

.feature-item.accent-violet {
  border-left-color: #a997ff;
}

.feature-icon {
  width: 74rpx;
  height: 74rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #087f77;
  background: #e8f7f4;
  font-size: 28rpx;
  font-weight: 900;
}

.accent-blue .feature-icon {
  color: #1d7fe5;
  background: #eaf4ff;
}

.accent-amber .feature-icon {
  color: #d97706;
  background: #fff2dd;
}

.accent-violet .feature-icon {
  color: #6d5bd6;
  background: #f1efff;
}

.feature-texts {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.feature-title {
  color: #0b1830;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.feature-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.42;
}

.feature-arrow {
  color: #087f77;
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
}

.privacy-section {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 26rpx;
  padding: 0 4rpx;
}

.confirm-privacy {
  margin-top: 8rpx;
}

.privacy-label {
  display: flex;
  align-items: flex-start;
  min-height: 48rpx;
}

.privacy-text {
  flex: 1;
  margin-left: 10rpx;
  color: #6b7890;
  font-size: 25rpx;
  line-height: 1.55;
}

.link {
  color: #087f77;
  font-weight: 800;
}

.btn-start,
.btn-primary,
.btn-ghost,
.btn-back,
.btn-cancel,
.btn-confirm {
  width: 100%;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.btn-start,
.btn-primary,
.btn-confirm {
  color: #fff;
  background: linear-gradient(145deg, #18a99e, #007d76);
  box-shadow: 0 16rpx 34rpx rgba(8, 127, 119, 0.22);
}

.btn-ghost,
.btn-back,
.btn-cancel {
  margin-top: 18rpx;
  color: #087f77;
  background: #fff;
  border: 2rpx solid #087f77;
}

.btn-back,
.btn-cancel {
  color: #64748b;
  border-color: #dbe5e8;
  background: #f8fafb;
}

.btn-start::after,
.btn-primary::after,
.btn-ghost::after,
.btn-back::after,
.btn-cancel::after,
.btn-confirm::after {
  border: none;
}

.btn-disabled {
  opacity: 0.58;
}

.login-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
  color: #7b8da3;
  font-size: 24rpx;
  line-height: 1.5;
}

.shield-mark {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #087f77;
  background: #e8f7f4;
  font-size: 22rpx;
  font-weight: 900;
}

.role-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 18rpx;
}

.role-item {
  min-height: 118rpx;
  display: grid;
  grid-template-columns: 74rpx 1fr;
  column-gap: 22rpx;
  align-items: center;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid #e5edf0;
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(20, 44, 58, 0.05);
}

.role-item:active {
  transform: scale(0.985);
}

.role-icon-bg {
  width: 74rpx;
  height: 74rpx;
  grid-row: span 2;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #087f77;
  background: #e8f7f4;
  font-size: 28rpx;
  font-weight: 900;
}

.role-label {
  color: #0b1830;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.role-desc {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.4;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  margin: 0 0 12rpx 6rpx;
  color: #52637a;
  font-size: 24rpx;
  font-weight: 800;
}

.input-field {
  min-height: 86rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e5edf0;
  background: #f8fafb;
  color: #0b1830;
  font-size: 28rpx;
}

.action-buttons {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  margin-top: 0;
  font-size: 28rpx;
}

@media (max-width: 340px) {
  .container {
    padding-left: 26rpx;
    padding-right: 26rpx;
  }

  .app-name {
    font-size: 62rpx;
  }

  .sub-name,
  .slogan {
    font-size: 25rpx;
  }

  .main-card {
    padding: 34rpx 26rpx 38rpx;
  }

  .feature-title {
    font-size: 28rpx;
  }

  .feature-desc {
    font-size: 22rpx;
  }
}
