<view class="container {{!hasToken && !showLoginForm ? 'welcome-mode' : ''}} {{showLoginForm ? 'confirm-mode' : ''}}">
  <view class="bg-circle-1"></view>
  <view class="bg-circle-2"></view>
  <view class="dot-grid">
    <view wx:for="{{dotList}}" wx:key="*this" class="dot"></view>
  </view>
  <view class="bottom-flourish"></view>

  <view class="hero {{showLoginForm ? 'hero-confirm' : ''}}">
    <text class="app-name">StudyTracker</text>
    <text class="sub-name">睿然国际教育 · 学习管理系统</text>
    <text class="slogan">让每一次进步都看得见</text>
  </view>

  <view class="main-card {{!hasToken && !showLoginForm ? 'welcome-card' : 'auth-card'}}">
    <view class="welcome-intro" wx:if="{{!hasToken && !showLoginForm}}">
      <view class="intro-content">
        <view class="entry-card">
          <view class="guest-access-note">
            <text class="shield-mark"></text>
            <text>零授权 · 不读手机号 / 头像 / 昵称</text>
          </view>
          <view class="welcome-title">
            <text class="welcome-title-line">先体验，再决定</text>
            <text class="welcome-title-line">是否登录</text>
          </view>
          <text class="welcome-desc">查看示例任务、学习报告与课程安排，体验后再决定是否登录。</text>

          <view class="btn-start" data-role="student" bindtap="enterPreview" hover-class="btn-start-active">
            <text>免登录体验学生端</text>
          </view>

          <view class="role-shortcuts">
            <text class="shortcut-label">也可以体验</text>
            <view class="shortcut-grid">
              <view class="role-shortcut" data-role="parent" bindtap="enterPreview" hover-class="role-shortcut-active">
                <view class="shortcut-copy">
                  <text class="shortcut-title">家长端</text>
                  <text class="shortcut-desc">成长报告与反馈</text>
                </view>
                <text class="shortcut-arrow">›</text>
              </view>
              <view class="role-shortcut" data-role="teacher" bindtap="enterPreview" hover-class="role-shortcut-active">
                <view class="shortcut-copy">
                  <text class="shortcut-title">教师端</text>
                  <text class="shortcut-desc">课表与课堂记录</text>
                </view>
                <text class="shortcut-arrow">›</text>
              </view>
            </view>
          </view>

          <view class="login-entry" bindtap="showLogin" hover-class="login-entry-active">
            <text class="login-muted">已有账号？</text>
            <text class="login-action">登录并同步数据</text>
          </view>
        </view>

        <text class="feature-heading">核心功能</text>
        <view class="feature-list">
          <view class="feature-item accent-teal">
            <view class="feature-icon icon-task"></view>
            <text class="feature-title">学习任务</text>
          </view>
          <view class="feature-item accent-blue">
            <view class="feature-icon icon-schedule"></view>
            <text class="feature-title">课程课表</text>
          </view>
          <view class="feature-item accent-amber">
            <view class="feature-icon icon-feedback"></view>
            <text class="feature-title">学习反馈</text>
          </view>
          <view class="feature-item accent-violet">
            <view class="feature-icon icon-data"></view>
            <text class="feature-title">学习数据</text>
          </view>
        </view>
      </view>
    </view>

    <view class="login-section" wx:if="{{!hasToken && showLoginForm}}">
      <view class="auth-head">
        <button class="auth-back" bindtap="backToWelcome">返回</button>
        <text class="auth-kicker">账号登录</text>
      </view>
      <text class="section-title auth-title">欢迎回来</text>
      <text class="section-subtitle auth-subtitle">登录后自动识别学生、家长或教师身份，并同步个人学习数据。</text>

      <view class="auth-benefits">
        <text class="auth-benefit">同步任务</text>
        <text class="auth-benefit">保存进度</text>
        <text class="auth-benefit">接收反馈</text>
      </view>

      <view class="privacy-section auth-privacy">
        <checkbox-group bindchange="handlePrivacyChange">
          <label class="privacy-label">
            <checkbox value="agree" checked="{{privacyAgreed}}" color="#087f77" style="transform:scale(0.82)" />
            <text class="privacy-text">我已阅读并同意 <text class="link" catchtap="openPrivacyContract">《用户协议》</text> 和 <text class="link" catchtap="openPrivacyContract">《隐私政策》</text></text>
          </label>
        </checkbox-group>
      </view>

      <button class="btn-primary {{!privacyAgreed ? 'btn-disabled' : ''}}" bindtap="handleLogin">微信登录</button>
      <button class="guest-entry" data-role="student" bindtap="enterPreview">暂不登录，继续免登录体验</button>
      <text class="auth-footnote">仅在你主动登录后绑定账号，不强制获取手机号、头像或昵称。</text>
    </view>

    <view class="role-section" wx:if="{{hasToken && isGuest}}">
      <text class="section-title">请选择您的身份</text>
      <view class="role-grid">
        <view class="role-item student" bindtap="selectRole" data-role="student">
          <view class="role-icon-bg">学</view>
          <text class="role-label">我是学生</text>
          <text class="role-desc">查看任务 · 提交打卡</text>
        </view>
        <view class="role-item parent" bindtap="selectRole" data-role="parent">
          <view class="role-icon-bg">家</view>
          <text class="role-label">我是家长</text>
          <text class="role-desc">关注成长 · 查看报告</text>
        </view>
        <view class="role-item teacher" bindtap="selectRole" data-role="teacher">
          <view class="role-icon-bg">师</view>
          <text class="role-label">我是老师</text>
          <text class="role-desc">查看课表 · 课堂记录</text>
        </view>
      </view>
      <view class="bound-preview">
        <text class="bound-preview-text">暂不绑定，也可以先查看功能示例</text>
        <view class="preview-role-grid compact">
          <button class="preview-role-btn" data-role="student" bindtap="enterPreview">学生端</button>
          <button class="preview-role-btn" data-role="parent" bindtap="enterPreview">家长端</button>
          <button class="preview-role-btn" data-role="teacher" bindtap="enterPreview">教师端</button>
        </view>
      </view>
    </view>

    <view class="bind-existing-section" wx:if="{{showExistingBindForm}}">
      <text class="section-title">绑定已有账号</text>
      <text class="section-subtitle">请输入后台创建的老师账号与密码</text>

      <view class="input-group">
        <text class="input-label">用户名</text>
        <input class="input-field" placeholder="后台用户名" model:value="{{existingUsername}}" />
      </view>

      <view class="input-group">
        <text class="input-label">密码</text>
        <input class="input-field" password="true" placeholder="后台密码" model:value="{{existingPassword}}" />
      </view>

      <view class="action-buttons">
        <button class="btn-cancel" bindtap="cancelExistingBind">取消</button>
        <button class="btn-confirm" bindtap="confirmExistingBind" loading="{{existingLoading}}" disabled="{{existingLoading}}">绑定账号</button>
      </view>
    </view>

    <view class="bind-section" wx:if="{{showBindForm}}">
      <text class="section-title">完善信息</text>
      <text class="section-subtitle">绑定{{targetRole === 'student' ? '学生' : '家长'}}身份以开始使用</text>

      <view class="input-group">
        <text class="input-label">姓名</text>
        <input class="input-field" placeholder="请输入真实姓名" model:value="{{bindName}}" />
      </view>

      <view class="input-group" wx:if="{{targetRole === 'parent'}}">
        <text class="input-label">孩子姓名</text>
        <input class="input-field" placeholder="请输入孩子的姓名" model:value="{{bindStudentName}}" />
      </view>

      <view class="input-group" wx:if="{{targetRole === 'parent'}}">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" placeholder="请输入手机号码" model:value="{{bindPhone}}" />
      </view>

      <view class="action-buttons">
        <button class="btn-cancel" bindtap="cancelBind">取消</button>
        <button class="btn-confirm" bindtap="confirmBind">确认绑定</button>
      </view>
    </view>
  </view>
</view>
