<view class="page">
  <view class="page-bg"></view>

  <view wx:if="{{bindRequired}}" class="bind-panel">
    <view class="bind-title">绑定排课老师ID</view>
    <view class="bind-desc">请填写排课系统中的老师ID，绑定后即可查看课表。</view>
    <view class="bind-form">
      <input class="bind-input" type="number" placeholder="排课系统老师ID" model:value="{{schedulerTeacherId}}" />
      <button class="bind-btn" size="mini" loading="{{bindLoading}}" disabled="{{bindLoading}}" bindtap="bindSchedulerTeacher">绑定</button>
    </view>
  </view>

  <scroll-view wx:else scroll-y class="page-scroll" enhanced="true" show-scrollbar="false" scroll-into-view="{{scrollIntoView}}" scroll-with-animation="true">
    <view class="teacher-header">
      <view>
        <text class="teacher-title">上午好，周老师</text>
        <text class="teacher-date">今天是 {{todayDate || '今日'}} · 教师工作台</text>
      </view>
      <view class="header-actions">
        <button class="sub-btn" size="mini" bindtap="requestSubscribe">{{subscribeButtonText}}</button>
      </view>
    </view>

    <view class="kpi-card">
      <view class="kpi-item">
        <view class="kpi-icon">课</view>
        <text class="kpi-label">今日课程</text>
        <text class="kpi-value">{{dashboardStats.todayCourses}}</text>
      </view>
      <view class="kpi-item">
        <view class="kpi-icon orange">作</view>
        <text class="kpi-label">待处理</text>
        <text class="kpi-value">{{dashboardStats.pendingHomework}}</text>
      </view>
      <view class="kpi-item">
        <view class="kpi-icon blue">反</view>
        <text class="kpi-label">待反馈</text>
        <text class="kpi-value">{{dashboardStats.pendingFeedback}}</text>
      </view>
      <view class="kpi-item">
        <view class="kpi-icon green">人</view>
        <text class="kpi-label">学生数</text>
        <text class="kpi-value">{{dashboardStats.studentCount}}</text>
      </view>
    </view>

    <view class="section-head">
      <text>今日课程</text>
      <text class="section-link">查看全部 ›</text>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <block wx:else>
      <view wx:if="{{todayItems.length === 0}}" class="empty-card">今日暂无课程</view>
      <view wx:else class="course-list">
        <view class="course-card" wx:for="{{todayItems}}" wx:key="schedule_uid" style="border-left-color: {{item.accentColor}};">
          <view class="course-main">
            <view class="course-time">{{item.timeRange}} <text class="tag teal">待上课</text></view>
            <view class="course-title">{{item.course_name}}</view>
            <view class="course-meta">学生 {{item.student_name || '—'}} ｜ 老师 {{item.teacher_name || '—'}}</view>
          </view>
          <button
            class="course-action"
            size="mini"
            data-schedule-uid="{{item.schedule_uid}}"
            data-schedule-id="{{item.schedule_id}}"
            data-student-id="{{item.student_id}}"
            data-student-name="{{item.student_name}}"
            data-teacher-id="{{item.teacher_id}}"
            data-course-name="{{item.course_name}}"
            data-start-time="{{item.start_time}}"
            data-end-time="{{item.end_time}}"
            data-teacher-name="{{item.teacher_name}}"
            data-schedule-date="{{item.schedule_date}}"
            data-feedback-text="{{item.feedback ? item.feedback.text : ''}}"
            data-feedback-image="{{item.feedback ? item.feedback.image : ''}}"
            bindtap="openFeedback"
          >课堂记录</button>
        </view>
      </view>

      <view id="calendar-section" class="section-head calendar-title">
        <text>课程表</text>
        <text class="section-link">左右滑动切换月份</text>
      </view>

      <view class="calendar-card" bindtouchstart="onCalendarTouchStart" bindtouchend="onCalendarTouchEnd">
        <view class="month-header">
          <view class="month-arrow" bindtap="prevMonth">‹</view>
          <view class="month-center">
            <text class="month-title">{{monthLabel}}</text>
            <text class="month-sub">点选日期查看当天课程</text>
          </view>
          <view class="month-arrow" bindtap="nextMonth">›</view>
        </view>

        <view class="week-header">
          <text class="week-cell" wx:for="{{weekHeaders}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="month-grid">
          <view
            class="month-cell {{item.isPlaceholder ? 'placeholder' : ''}} {{item.date === selectedDate ? 'active' : ''}} {{item.isToday ? 'today' : ''}}"
            wx:for="{{monthDays}}"
            wx:key="index"
            wx:for-item="item"
            data-date="{{item.date}}"
            bindtap="selectDay"
          >
            <text class="cell-date">{{item.dayNum}}</text>
            <view class="calendar-dots" wx:if="{{item.dots && item.dots.length}}">
              <view class="calendar-dot" wx:for="{{item.dots}}" wx:key="*this" wx:for-item="dot" style="background: {{item.date === selectedDate ? '#fff' : dot}};"></view>
            </view>
          </view>
        </view>
      </view>

      <view class="selected-bar">
        <text>{{selectedDate}}</text>
        <text>{{selectedItems.length}} 节课</text>
      </view>

      <view wx:if="{{selectedItems.length === 0}}" class="empty-card">当天暂无课程</view>
      <view wx:else class="schedule-list">
        <view class="schedule-card" wx:for="{{selectedItems}}" wx:key="schedule_uid" style="border-left-color: {{item.accentColor}};">
          <view class="schedule-info">
            <view class="course-time">{{item.timeRange}} <text class="tag {{item.feedback ? 'green' : 'blue'}}">{{item.feedback ? '已记录' : '待记录'}}</text></view>
            <view class="course-title">{{item.course_name}}</view>
            <view class="course-meta">学生 {{item.student_name || '—'}} ｜ 老师 {{item.teacher_name || '—'}}</view>
          </view>
          <button
            class="course-action ghost"
            size="mini"
            data-schedule-uid="{{item.schedule_uid}}"
            data-schedule-id="{{item.schedule_id}}"
            data-student-id="{{item.student_id}}"
            data-student-name="{{item.student_name}}"
            data-teacher-id="{{item.teacher_id}}"
            data-course-name="{{item.course_name}}"
            data-start-time="{{item.start_time}}"
            data-end-time="{{item.end_time}}"
            data-teacher-name="{{item.teacher_name}}"
            data-schedule-date="{{item.schedule_date}}"
            data-feedback-text="{{item.feedback ? item.feedback.text : ''}}"
            data-feedback-image="{{item.feedback ? item.feedback.image : ''}}"
            bindtap="openFeedback"
          >{{item.feedback ? '修改记录' : '课堂记录'}}</button>
        </view>
      </view>

      <view class="section-head">
        <text>快捷操作</text>
      </view>
      <view class="quick-grid">
        <view class="quick-card primary" bindtap="openClassRecord">
          <text class="quick-icon">记</text>
          <text>课堂记录</text>
          <text class="quick-sub">可用</text>
        </view>
        <view class="quick-card muted" data-name="布置作业" bindtap="showUnavailable">
          <text class="quick-icon">作</text>
          <text>布置作业</text>
          <text class="quick-sub">保留入口</text>
        </view>
        <view class="quick-card muted" data-name="发送通知" bindtap="showUnavailable">
          <text class="quick-icon">通</text>
          <text>发送通知</text>
          <text class="quick-sub">保留入口</text>
        </view>
        <view class="quick-card muted" data-name="导出报告" bindtap="showUnavailable">
          <text class="quick-icon">报</text>
          <text>导出报告</text>
          <text class="quick-sub">保留入口</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="bottom-nav">
    <view class="nav-item active">首页</view>
    <view class="nav-item" bindtap="goCalendar">课程</view>
    <view class="nav-item" bindtap="goStats">统计</view>
  </view>
</view>
