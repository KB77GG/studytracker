page {
  background: #f4f8f8;
}

.page {
  position: relative;
  min-height: 100vh;
  color: #0b1830;
  overflow: hidden;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(8, 127, 119, 0.14), transparent 390rpx),
    linear-gradient(135deg, #eef7fb 0%, #fbfffd 56%, #eef8f6 100%);
  z-index: 0;
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
  padding: 52rpx 24rpx 156rpx;
}

.teacher-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.teacher-title {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
}

.teacher-date {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.4;
}

.header-actions {
  flex-shrink: 0;
}

.sub-btn {
  min-width: 116rpx;
  height: 60rpx;
  line-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d6e9e6;
  background: rgba(255, 255, 255, 0.9);
  color: #087f77;
  font-size: 23rpx;
  font-weight: 800;
}

.sub-btn::after,
.bind-btn::after,
.course-action::after {
  border: none;
}

.kpi-card {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0;
  padding: 22rpx 10rpx;
  margin-bottom: 28rpx;
  border: 8rpx solid #087f77;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(20, 44, 58, 0.08);
}

.kpi-item {
  min-width: 0;
  text-align: center;
  border-right: 1rpx solid #e5edf0;
}

.kpi-item:last-child {
  border-right: 0;
}

.kpi-icon {
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #087f77;
  background: #e8f7f4;
  font-size: 22rpx;
  font-weight: 900;
}

.kpi-icon.orange {
  color: #d97706;
  background: #fff2dd;
}

.kpi-icon.blue {
  color: #1d7fe5;
  background: #eaf4ff;
}

.kpi-icon.green {
  color: #10a05f;
  background: #e8f8ef;
}

.kpi-label {
  display: block;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.2;
}

.kpi-value {
  display: block;
  margin-top: 8rpx;
  color: #0b1830;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 4rpx 16rpx;
  color: #0b1830;
  font-size: 31rpx;
  font-weight: 900;
}

.section-link {
  color: #087f77;
  font-size: 23rpx;
  font-weight: 800;
}

.calendar-title {
  margin-top: 28rpx;
}

.scope-toggle {
  display: flex;
  gap: 8rpx;
  margin: 0 4rpx 16rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #eef4f3;
}

.scope-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  color: #5b6b76;
  font-size: 26rpx;
  font-weight: 700;
}

.scope-tab.active {
  background: #3A8C82;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(58, 140, 130, 0.28);
}

.loading,
.empty-card {
  padding: 42rpx 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #e5edf0;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #94a3b8;
  text-align: center;
  font-size: 26rpx;
}

.course-list,
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-card,
.schedule-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 18rpx;
  padding: 24rpx 22rpx 24rpx 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid #e5edf0;
  border-left: 8rpx solid #087f77;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(20, 44, 58, 0.06);
}

.course-main,
.schedule-info {
  min-width: 0;
  flex: 1;
}

.course-time {
  color: #334155;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.3;
}

.course-title {
  margin-top: 8rpx;
  color: #0b1830;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-word;
}

.course-meta {
  margin-top: 7rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  margin-left: 8rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 850;
  vertical-align: 2rpx;
}

.tag.teal {
  color: #087f77;
  background: #e8f7f4;
}

.tag.blue {
  color: #1669b8;
  background: #eaf4ff;
}

.tag.green {
  color: #087a47;
  background: #e8f8ef;
}

.course-action {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 64rpx;
  line-height: 62rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(145deg, #18a99e, #007d76);
  font-size: 23rpx;
  font-weight: 850;
}

.course-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.course-action.ghost {
  color: #087f77;
  background: #f5fbfa;
  border: 1rpx solid #cfe9e5;
}

/* 学生概况(只读，可展开)，整行铺到课次卡片底部 */
.profile-block {
  order: 1;
  width: 100%;
  margin-top: 2rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #eef2f5;
}

.profile-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0;
}

.profile-toggle-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #087f77;
}

.profile-toggle-arrow {
  font-size: 22rpx;
  color: #94a3b8;
}

.profile-detail {
  margin-top: 10rpx;
  background: #f7fbfa;
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
}

.profile-student {
  padding: 2rpx 0;
}

.profile-student + .profile-student {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #d8e6e3;
}

.profile-student-name {
  margin-bottom: 6rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #0b1830;
}

.profile-line {
  display: flex;
  gap: 12rpx;
  padding: 5rpx 0;
}

.pl-label {
  flex-shrink: 0;
  width: 156rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.pl-value {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  line-height: 1.5;
  color: #1f2d3d;
  word-break: break-word;
}

.profile-updated {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #aab4c0;
  text-align: right;
}

.calendar-card {
  padding: 24rpx 20rpx 22rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
  border: 1rpx solid #e5edf0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 36rpx rgba(20, 44, 58, 0.08);
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.month-arrow {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1rpx solid #d9ece9;
  color: #087f77;
  background: #fff;
  font-size: 36rpx;
  font-weight: 900;
}

.month-center {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.month-title {
  display: block;
  color: #0b1830;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.2;
}

.month-sub {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 21rpx;
}

.week-header,
.month-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
}

.week-header {
  margin-bottom: 8rpx;
}

.week-cell {
  text-align: center;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 850;
}

.month-cell {
  position: relative;
  min-height: 74rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid #edf2f4;
  background: #fbfefd;
  color: #334155;
  font-size: 23rpx;
  font-weight: 850;
  box-sizing: border-box;
}

.month-cell.placeholder {
  opacity: 0.36;
}

.month-cell.placeholder .cell-date,
.month-cell.placeholder .calendar-dots {
  visibility: hidden;
}

.month-cell.today {
  color: #087f77;
  border-color: #bfe5df;
  background: #effaf7;
}

.month-cell.active {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(180deg, #18a99e, #007d76);
  box-shadow: 0 10rpx 24rpx rgba(8, 127, 119, 0.22);
}

.cell-date {
  line-height: 1;
}

.calendar-dots {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 10rpx;
  display: flex;
  justify-content: center;
  gap: 5rpx;
}

.calendar-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.selected-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 6rpx;
  margin: 8rpx 0 14rpx;
  color: #087f77;
  font-size: 24rpx;
  font-weight: 850;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.quick-card {
  min-height: 142rpx;
  padding: 16rpx 8rpx;
  border-radius: 24rpx;
  border: 1rpx solid #e5edf0;
  background: rgba(255, 255, 255, 0.96);
  color: #0b1830;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 22rpx;
  font-weight: 850;
  box-shadow: 0 10rpx 24rpx rgba(20, 44, 58, 0.05);
}

.quick-card.primary {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(145deg, #18a99e, #007d76);
  box-shadow: 0 14rpx 28rpx rgba(8, 127, 119, 0.22);
}

.quick-card.muted {
  color: #94a3b8;
  background: #f8fafb;
}

.quick-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #e8f7f4;
  color: #087f77;
  font-size: 22rpx;
  font-weight: 900;
}

.primary .quick-icon {
  color: #087f77;
  background: rgba(255, 255, 255, 0.9);
}

.quick-sub {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 750;
  opacity: 0.78;
  line-height: 1.2;
}

.bottom-nav {
  position: fixed;
  z-index: 10;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  border: 1rpx solid #e5edf0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(20, 44, 58, 0.10);
}

.nav-item {
  flex: 1;
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 850;
}

.nav-item.active {
  color: #fff;
  background: #087f77;
}

.bind-panel {
  position: relative;
  z-index: 1;
  margin: 52rpx 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid #e5edf0;
  background: #fff;
  box-shadow: 0 14rpx 36rpx rgba(20, 44, 58, 0.08);
}

.bind-title {
  color: #0b1830;
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.bind-desc {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
  margin-bottom: 18rpx;
}

.bind-form {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.bind-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e5edf0;
  background: #f8fafb;
  font-size: 26rpx;
}

.bind-btn {
  min-width: 120rpx;
  height: 72rpx;
  line-height: 70rpx;
  border-radius: 18rpx;
  background: #087f77;
  color: #fff;
  font-weight: 850;
}

.grading-entry-btn {
  margin-top: 18rpx;
  height: 72rpx;
  line-height: 70rpx;
  border-radius: 18rpx;
  border: 1rpx solid #cfe9e5;
  background: #f5fbfa;
  color: #087f77;
  font-size: 24rpx;
  font-weight: 850;
}

.grading-entry-btn::after {
  border: none;
}

@media (max-width: 340px) {
  .teacher-title {
    font-size: 36rpx;
  }

  .kpi-card,
  .quick-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .kpi-item:nth-child(2) {
    border-right: 0;
  }

  .course-card,
  .schedule-card {
    align-items: stretch;
    flex-direction: column;
  }

  .course-actions {
    flex-direction: row;
  }

  .course-action {
    width: 100%;
  }

  .month-cell {
    min-height: 64rpx;
    border-radius: 14rpx;
  }
}

.guest-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 0 24rpx 20rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(32, 117, 111, 0.08);
  border: 1rpx solid rgba(32, 117, 111, 0.18);
  font-size: 24rpx;
  color: #20756F;
}

.guest-banner-btn {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  background: #20756F;
  color: #fff;
  font-size: 24rpx;
}
