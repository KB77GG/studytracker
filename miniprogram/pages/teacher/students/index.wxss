.page {
  min-height: 100vh;
  padding: 20px 16px 32px;
  box-sizing: border-box;
  background: #f6f8fa;
}

.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
}

.title {
  display: block;
  color: #0f766e;
  font-size: 22px;
  font-weight: 700;
}

.subtitle,
.month-label,
.student-id,
.subject-meta {
  display: block;
  color: #64748b;
  font-size: 12px;
}

.subtitle {
  margin-top: 5px;
}

.month-label {
  padding-top: 4px;
  white-space: nowrap;
}

.search,
.student-card,
.state-card,
.guest-card {
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  background: #fff;
  box-sizing: border-box;
}

.search {
  width: 100%;
  height: 42px;
  margin-bottom: 14px;
  padding: 0 14px;
  color: #0f172a;
  font-size: 14px;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.05);
}

.state-card,
.guest-card {
  padding: 24px 16px;
  color: #64748b;
  font-size: 14px;
  line-height: 1.6;
  text-align: center;
}

.state-card.error {
  color: #b45309;
}

.student-card {
  margin-bottom: 12px;
  padding: 14px;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.06);
}

.student-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
}

.student-head-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.student-name {
  display: block;
  color: #0f172a;
  font-size: 17px;
  font-weight: 700;
}

.student-id {
  margin-top: 4px;
}

.subject-count {
  color: #0f766e;
  font-size: 12px;
  white-space: nowrap;
}

.input-grant-button {
  min-width: 92px;
  height: 32px;
  margin: 0;
  padding: 0 9px;
  border: 1px solid rgba(15, 118, 110, 0.35);
  border-radius: 999px;
  background: #f0fdfa;
  color: #0f766e;
  font-size: 12px;
  line-height: 30px;
}

.input-grant-button::after {
  border: 0;
}

.subject-list {
  display: flex;
  flex-direction: column;
  gap: 9px;
}

.subject-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin: 0;
  padding: 11px 12px;
  border: 1px solid #99f6e4;
  border-radius: 10px;
  background: #f0fdfa;
  color: #115e59;
  font-size: 14px;
  line-height: 1.4;
  text-align: left;
}

.subject-button.reading {
  border-color: #bfdbfe;
  background: #eff6ff;
  color: #1d4ed8;
}

.subject-meta {
  margin-left: 8px;
  color: inherit;
  opacity: 0.75;
  text-align: right;
}
