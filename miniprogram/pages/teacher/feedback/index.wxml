<view class="container">
  <view class="header">
    <text class="title">上课反馈</text>
    <text class="subtitle">{{schedule.schedule_date || ''}}</text>
  </view>

  <view class="card">
    <view class="info-row">
      <text class="label">课程</text>
      <text class="value">{{schedule.course_name || '—'}}</text>
    </view>
    <view class="info-row">
      <text class="label">时间</text>
      <text class="value">{{schedule.start_time || '—'}} {{schedule.end_time ? ('- ' + schedule.end_time) : ''}}</text>
    </view>
    <view class="info-row">
      <text class="label">学生</text>
      <text class="value">{{schedule.student_name || '—'}}</text>
    </view>
    <view class="info-row">
      <text class="label">老师</text>
      <text class="value">{{schedule.teacher_name || '—'}}</text>
    </view>
  </view>

  <view class="profile-section">
    <view class="profile-section-head">
      <text class="profile-section-title">学生概况</text>
    </view>

    <view wx:if="{{!hasStudentInfo}}" class="profile-empty">暂无学生信息</view>

    <view wx:for="{{studentProfiles}}" wx:key="index" class="profile-card">
      <view class="profile-card-head">
        <text class="profile-name">{{item.name}}</text>
        <text
          wx:if="{{editingIndex !== index}}"
          class="profile-edit-btn"
          data-index="{{index}}"
          bindtap="startEditProfile"
        >编辑</text>
      </view>

      <block wx:if="{{editingIndex !== index}}">
        <view class="profile-row">
          <text class="profile-label">年级/阶段</text>
          <text class="profile-value">{{item.gradeLevelText}}</text>
        </view>
        <view class="profile-row">
          <text class="profile-label">学生概况</text>
          <text class="profile-value">{{item.summaryText}}</text>
        </view>
        <view class="profile-row">
          <text class="profile-label">学习目标</text>
          <text class="profile-value">{{item.goalsText}}</text>
        </view>
        <view class="profile-row">
          <text class="profile-label">上课注意事项</text>
          <text class="profile-value">{{item.notesText}}</text>
        </view>
        <view wx:if="{{item.updatedText}}" class="profile-updated">更新时间：{{item.updatedText}}</view>
      </block>

      <block wx:else>
        <view class="profile-edit-field">
          <text class="profile-edit-label">年级/阶段</text>
          <input
            class="profile-input"
            placeholder="如 G8 / 高一"
            value="{{profileForm.grade_level}}"
            data-field="grade_level"
            bindinput="handleProfileInput"
          />
        </view>
        <view class="profile-edit-field">
          <text class="profile-edit-label">学生概况</text>
          <textarea
            class="profile-textarea"
            placeholder="基础水平、优势与短板"
            maxlength="500"
            value="{{profileForm.profile_summary}}"
            data-field="profile_summary"
            bindinput="handleProfileInput"
          ></textarea>
        </view>
        <view class="profile-edit-field">
          <text class="profile-edit-label">学习目标</text>
          <textarea
            class="profile-textarea"
            placeholder="阶段性目标与时间节点"
            maxlength="500"
            value="{{profileForm.learning_goals}}"
            data-field="learning_goals"
            bindinput="handleProfileInput"
          ></textarea>
        </view>
        <view class="profile-edit-field">
          <text class="profile-edit-label">上课注意事项</text>
          <textarea
            class="profile-textarea"
            placeholder="课前准备、课后跟进等"
            maxlength="500"
            value="{{profileForm.class_notes}}"
            data-field="class_notes"
            bindinput="handleProfileInput"
          ></textarea>
        </view>
        <view class="profile-edit-actions">
          <button class="profile-cancel-btn" size="mini" bindtap="cancelEditProfile" disabled="{{savingProfile}}">取消</button>
          <button class="profile-save-btn" size="mini" bindtap="saveProfile" loading="{{savingProfile}}" disabled="{{savingProfile}}">保存</button>
        </view>
      </block>
    </view>
  </view>

  <view class="form">
    <text class="form-label">作业完成情况</text>
    <textarea
      class="textarea section-textarea"
      placeholder="填写作业完成度、准确率、存在的问题"
      maxlength="200"
      value="{{feedbackForm.homeworkStatus}}"
      data-field="homeworkStatus"
      bindinput="handleSectionInput"
    ></textarea>
    <view class="counter">{{feedbackForm.homeworkStatus.length}}/200</view>
  </view>

  <view class="form">
    <text class="form-label">课堂表现及问题</text>
    <textarea
      class="textarea section-textarea"
      placeholder="填写课堂专注度、互动表现、关键问题"
      maxlength="240"
      value="{{feedbackForm.classPerformance}}"
      data-field="classPerformance"
      bindinput="handleSectionInput"
    ></textarea>
    <view class="counter">{{feedbackForm.classPerformance.length}}/240</view>
  </view>

  <view class="form">
    <text class="form-label">建议及作业</text>
    <textarea
      class="textarea section-textarea"
      placeholder="填写课后建议与下次课前作业安排"
      maxlength="200"
      value="{{feedbackForm.suggestionHomework}}"
      data-field="suggestionHomework"
      bindinput="handleSectionInput"
    ></textarea>
    <view class="counter">{{feedbackForm.suggestionHomework.length}}/200</view>
  </view>

  <view class="form">
    <view class="image-header">
      <text class="form-label">反馈图片</text>
      <text class="image-tip">可选</text>
    </view>
    <view class="image-uploader">
      <view class="image-preview" wx:if="{{feedbackImage}}">
        <image class="preview-img" src="{{imagePreviewUrl}}" mode="aspectFill" bindtap="previewImage"></image>
        <button class="remove-btn" size="mini" bindtap="removeImage">删除</button>
      </view>
      <button class="upload-btn" size="mini" loading="{{uploadingImage}}" disabled="{{uploadingImage}}" bindtap="chooseImage">
        {{feedbackImage ? '更换图片' : '添加图片'}}
      </button>
    </view>
  </view>

  <button class="submit-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="submitFeedback">
    提交反馈
  </button>
</view>
