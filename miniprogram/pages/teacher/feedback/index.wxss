.container {
  min-height: 100vh;
  padding: 20px 16px 32px;
  background: #f6f8fa;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 16px;
}

.title {
  font-size: 20px;
  font-weight: 700;
  color: #0f766e;
}

.subtitle {
  font-size: 12px;
  color: #64748b;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.08);
  border: 1px solid #e2e8f0;
  margin-bottom: 16px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px dashed #e2e8f0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 12px;
  color: #64748b;
}

.value {
  font-size: 13px;
  color: #0f172a;
  font-weight: 600;
  text-align: right;
}

.profile-section {
  margin-bottom: 16px;
}

.profile-section-head {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.profile-section-title {
  font-size: 15px;
  font-weight: 700;
  color: #0f172a;
}

.profile-empty {
  background: #fff;
  border-radius: 12px;
  padding: 18px 14px;
  border: 1px dashed #cbd5e1;
  text-align: center;
  font-size: 13px;
  color: #94a3b8;
}

.profile-card {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  border: 1px solid #e2e8f0;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.08);
  margin-bottom: 12px;
}

.profile-card:last-child {
  margin-bottom: 0;
}

.profile-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.profile-name {
  font-size: 15px;
  font-weight: 700;
  color: #0f766e;
}

.profile-edit-btn {
  font-size: 13px;
  color: #0f766e;
  padding: 2px 12px;
  border: 1px solid #0f766e;
  border-radius: 14px;
}

.profile-row {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 7px 0;
  border-bottom: 1px dashed #eef2f7;
}

.profile-row:last-of-type {
  border-bottom: none;
}

.profile-label {
  font-size: 12px;
  color: #94a3b8;
}

.profile-value {
  font-size: 13px;
  color: #0f172a;
  line-height: 1.5;
}

.profile-updated {
  margin-top: 8px;
  font-size: 11px;
  color: #94a3b8;
  text-align: right;
}

.profile-edit-field {
  margin-bottom: 10px;
}

.profile-edit-label {
  display: block;
  font-size: 12px;
  color: #64748b;
  margin-bottom: 6px;
}

.profile-input {
  width: 100%;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 8px;
  padding: 8px 10px;
  font-size: 13px;
  color: #0f172a;
}

.profile-textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 64px;
  background: #f8fafc;
  border-radius: 8px;
  padding: 8px 10px;
  font-size: 13px;
  color: #0f172a;
}

.profile-edit-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 4px;
}

.profile-cancel-btn {
  background: #f1f5f9;
  color: #475569;
  border-radius: 12px;
}

.profile-save-btn {
  background: #0f766e;
  color: #fff;
  border-radius: 12px;
}

.form {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  border: 1px solid #e2e8f0;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.08);
  margin-bottom: 14px;
}

.form-label {
  font-size: 14px;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8px;
  display: block;
}

.textarea {
  width: 100%;
  min-height: 160px;
  background: #f8fafc;
  border-radius: 10px;
  padding: 10px;
  box-sizing: border-box;
  font-size: 14px;
  color: #0f172a;
}

.section-textarea {
  min-height: 100px;
}

.counter {
  text-align: right;
  font-size: 11px;
  color: #94a3b8;
  margin-top: 6px;
}

.image-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.image-tip {
  font-size: 11px;
  color: #94a3b8;
}

.image-uploader {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.image-preview {
  display: flex;
  align-items: center;
  gap: 10px;
}

.preview-img {
  width: 96px;
  height: 96px;
  border-radius: 10px;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
}

.remove-btn {
  background: #fee2e2;
  color: #b91c1c;
  border-radius: 12px;
}

.upload-btn {
  background: #0f766e;
  color: #fff;
  border-radius: 12px;
  align-self: flex-start;
}

.submit-btn {
  background: #0f766e;
  color: #fff;
  border-radius: 16px;
}
