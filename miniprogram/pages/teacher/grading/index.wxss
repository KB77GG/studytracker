page {
  background: #f4f8f8;
}

.page {
  min-height: 100vh;
  padding: 44rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  color: #0b1830;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
}

.state-card {
  padding: 72rpx 24rpx;
  border: 1rpx solid #e4ecee;
  border-radius: 28rpx;
  background: #fff;
  color: #94a3b8;
  text-align: center;
}

.empty-title,
.empty-sub {
  display: block;
}

.empty-title {
  color: #334155;
  font-size: 30rpx;
  font-weight: 850;
}

.empty-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.task-card {
  overflow: hidden;
  border: 1rpx solid #e4ecee;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 14rpx 34rpx rgba(20, 44, 58, 0.07);
}

.task-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #edf2f4;
}

.student-badge {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #e8f7f4;
  color: #087f77;
  font-size: 28rpx;
  font-weight: 900;
}

.task-head-main {
  min-width: 0;
  flex: 1;
}

.student-name,
.task-meta {
  display: block;
}

.student-name {
  font-size: 30rpx;
  font-weight: 900;
}

.task-meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 21rpx;
}

.status-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff2dd;
  color: #b45309;
  font-size: 21rpx;
  font-weight: 850;
}

.task-body,
.evidence-section,
.grading-form {
  padding: 22rpx 24rpx;
}

.task-body,
.evidence-section {
  border-bottom: 1rpx solid #edf2f4;
}

.category,
.detail,
.student-note,
.section-label,
.field-label {
  display: block;
}

.category {
  color: #087f77;
  font-size: 22rpx;
  font-weight: 850;
}

.detail {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.45;
}

.student-note {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafb;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.5;
}

.section-label,
.field-label {
  margin-bottom: 12rpx;
  color: #334155;
  font-size: 23rpx;
  font-weight: 850;
}

.audio-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.audio-button {
  width: auto;
  min-width: 166rpx;
  height: 64rpx;
  line-height: 62rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #cfe9e5;
  background: #f5fbfa;
  color: #087f77;
  font-size: 23rpx;
  font-weight: 850;
}

.audio-button::after,
.submit-button::after {
  border: none;
}

.audio-button.playing {
  background: #087f77;
  color: #fff;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.evidence-image {
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  background: #eef2f4;
}

.score-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.field {
  margin-bottom: 18rpx;
}

.score-input,
.feedback-input {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #dce7e9;
  border-radius: 18rpx;
  background: #f8fafb;
  font-size: 26rpx;
}

.score-input {
  height: 74rpx;
  padding: 0 18rpx;
}

.feedback-input {
  min-height: 176rpx;
  padding: 18rpx;
  line-height: 1.5;
}

.submit-button {
  height: 78rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #18a99e, #007d76);
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
}
