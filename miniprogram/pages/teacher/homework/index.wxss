.container {
  min-height: 100vh;
  padding: 20px 16px 32px;
  background: #f6f8fa;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 16px;
}

.title {
  font-size: 20px;
  font-weight: 700;
  color: #0f766e;
}

.subtitle {
  font-size: 12px;
  color: #64748b;
}

.card,
.form {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.08);
  border: 1px solid #e2e8f0;
  margin-bottom: 14px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px dashed #e2e8f0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 12px;
  color: #64748b;
}

.value {
  font-size: 13px;
  color: #0f172a;
  font-weight: 600;
  text-align: right;
}

.form-label {
  font-size: 14px;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8px;
  display: block;
}

.picker-field,
.input,
.textarea {
  width: 100%;
  background: #f8fafc;
  border-radius: 10px;
  padding: 10px;
  box-sizing: border-box;
  font-size: 14px;
  color: #0f172a;
  border: 1px solid #e2e8f0;
}

.source-card {
  border-color: rgba(15, 118, 110, 0.18);
}

.practice-picker-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 12px;
}

.practice-picker-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.picker-field.compact {
  text-align: center;
}

.practice-summary {
  margin-top: 10px;
  padding: 10px;
  border-radius: 10px;
  background: #ecfdf5;
  color: #0f766e;
  font-size: 12px;
  line-height: 1.5;
}

.practice-summary.muted {
  background: #f8fafc;
  color: #64748b;
}

.practice-actions {
  display: flex;
  gap: 8px;
  margin-top: 10px;
}

.queue-btn,
.remove-btn {
  margin: 0;
  border-radius: 8px;
  font-size: 12px;
  line-height: 2.4;
}

.queue-btn {
  flex: 1;
  background: #0f766e;
  color: #fff;
}

.queue-btn.ghost,
.remove-btn {
  background: #f8fafc;
  color: #475569;
  border: 1px solid #e2e8f0;
}

.queue-panel {
  margin-top: 12px;
  padding: 10px;
  border-radius: 10px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.section-title {
  font-size: 14px;
  font-weight: 700;
  color: #0f172a;
}

.section-count {
  font-size: 12px;
  color: #64748b;
  white-space: nowrap;
}

.queue-item,
.assigned-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0;
  border-top: 1px solid #e2e8f0;
}

.queue-main,
.assigned-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.queue-title,
.assigned-title {
  font-size: 13px;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
}

.queue-meta,
.assigned-meta {
  font-size: 11px;
  color: #64748b;
  line-height: 1.4;
}

.practice-result {
  display: flex;
  flex-direction: column;
  gap: 3px;
  margin-top: 3px;
  padding: 7px 9px;
  border-radius: 8px;
  background: #f0fdfa;
  border: 1px solid #ccfbf1;
}

.practice-result-main {
  color: #0f766e;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.45;
}

.practice-result-wrong {
  color: #15803d;
  font-size: 11px;
  line-height: 1.45;
}

.practice-result-wrong.has-wrong {
  color: #b45309;
}

.result-detail-toggle {
  width: 100%;
  margin: 3px 0 0;
  padding: 0 10px;
  border-radius: 7px;
  background: #fff;
  color: #0f766e;
  border: 1px solid #99f6e4;
  font-size: 11px;
  line-height: 2.35;
}

.result-detail-toggle::after {
  border: none;
}

.wrong-detail-list {
  display: flex;
  flex-direction: column;
  gap: 7px;
  margin-top: 4px;
}

.wrong-detail-card {
  padding: 8px;
  border-radius: 8px;
  background: #fff;
  border: 1px solid #fde7c3;
}

.wrong-detail-head,
.answer-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.wrong-question-label {
  color: #92400e;
  font-size: 12px;
  font-weight: 800;
}

.wrong-score {
  color: #94a3b8;
  font-size: 10px;
}

.wrong-question-title {
  display: block;
  margin-top: 5px;
  color: #334155;
  font-size: 11px;
  line-height: 1.45;
}

.answer-line {
  margin-top: 6px;
  justify-content: flex-start;
}

.answer-label {
  width: 52px;
  flex-shrink: 0;
  color: #64748b;
  font-size: 10px;
}

.answer-value {
  flex: 1;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.student-answer .answer-value {
  color: #b91c1c;
}

.correct-answer .answer-value {
  color: #047857;
}

.wrong-analysis {
  margin-top: 7px;
  padding-top: 7px;
  border-top: 1px dashed #e2e8f0;
}

.analysis-label {
  display: block;
  margin-bottom: 3px;
  color: #64748b;
  font-size: 10px;
  font-weight: 700;
}

.analysis-text {
  display: block;
  color: #475569;
  font-size: 10px;
  line-height: 1.55;
}

.remove-btn {
  width: 58px;
  flex-shrink: 0;
}

.assigned-card {
  border-color: rgba(14, 165, 233, 0.18);
}

.assigned-item {
  align-items: flex-start;
}

.assigned-list {
  display: flex;
  flex-direction: column;
}

.assigned-side {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
}

.assigned-actions {
  display: flex;
  gap: 6px;
}

.mini-action {
  margin: 0;
  min-width: 48px;
  padding: 0 8px;
  border-radius: 8px;
  background: #f8fafc;
  color: #0f766e;
  border: 1px solid #ccfbf1;
  font-size: 11px;
  line-height: 2.2;
}

.mini-action.danger {
  background: #fef2f2;
  color: #dc2626;
  border-color: #fecaca;
}

.empty-hint {
  padding: 10px;
  border-radius: 10px;
  background: #f8fafc;
  color: #94a3b8;
  font-size: 12px;
  text-align: center;
}

.status-pill {
  flex-shrink: 0;
  min-width: 48px;
  padding: 4px 8px;
  border-radius: 999px;
  background: #ecfdf5;
  color: #0f766e;
  font-size: 11px;
  text-align: center;
}

.edit-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  margin-bottom: 14px;
  border-radius: 10px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
}

.edit-banner-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.edit-banner-title {
  font-size: 13px;
  font-weight: 700;
  color: #1d4ed8;
}

.edit-banner-desc {
  font-size: 12px;
  color: #475569;
  line-height: 1.4;
}

.cancel-edit-btn {
  flex-shrink: 0;
  margin: 0;
  border-radius: 8px;
  background: #fff;
  color: #2563eb;
  border: 1px solid #bfdbfe;
  font-size: 12px;
  line-height: 2.3;
}

.textarea {
  min-height: 120px;
}

.short-textarea {
  min-height: 96px;
}

.counter {
  text-align: right;
  font-size: 11px;
  color: #94a3b8;
  margin-top: 6px;
}

.submit-btn {
  background: #0f766e;
  color: #fff;
  border-radius: 16px;
}
