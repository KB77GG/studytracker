.container {
  min-height: 100vh;
  padding: 20px 16px 32px;
  background: #f6f8fa;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 16px;
}

.title {
  font-size: 20px;
  font-weight: 700;
  color: #0f766e;
}

.subtitle {
  font-size: 12px;
  color: #64748b;
}

.card,
.form {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  box-shadow: 0 4px 10px rgba(15, 118, 110, 0.08);
  border: 1px solid #e2e8f0;
  margin-bottom: 14px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px dashed #e2e8f0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 12px;
  color: #64748b;
}

.value {
  font-size: 13px;
  color: #0f172a;
  font-weight: 600;
  text-align: right;
}

.form-label {
  font-size: 14px;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8px;
  display: block;
}

.picker-field,
.input,
.textarea {
  width: 100%;
  background: #f8fafc;
  border-radius: 10px;
  padding: 10px;
  box-sizing: border-box;
  font-size: 14px;
  color: #0f172a;
  border: 1px solid #e2e8f0;
}

.source-card {
  border-color: rgba(15, 118, 110, 0.18);
}

.practice-picker-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 12px;
}

.practice-picker-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.picker-field.compact {
  text-align: center;
}

.practice-summary {
  margin-top: 10px;
  padding: 10px;
  border-radius: 10px;
  background: #ecfdf5;
  color: #0f766e;
  font-size: 12px;
  line-height: 1.5;
}

.practice-summary.muted {
  background: #f8fafc;
  color: #64748b;
}

.textarea {
  min-height: 120px;
}

.short-textarea {
  min-height: 96px;
}

.counter {
  text-align: right;
  font-size: 11px;
  color: #94a3b8;
  margin-top: 6px;
}

.submit-btn {
  background: #0f766e;
  color: #fff;
  border-radius: 16px;
}
