<view class="container">
  <view class="header">
    <text class="title">布置作业</text>
    <text class="subtitle">保存后会尝试把任务提醒推送给学生</text>
  </view>

  <view class="card">
    <view class="info-row">
      <text class="label">学生</text>
      <text class="value">{{schedule.student_name || '—'}}</text>
    </view>
    <view class="info-row">
      <text class="label">课程</text>
      <text class="value">{{schedule.course_name || '—'}}</text>
    </view>
    <view class="info-row">
      <text class="label">上课时间</text>
      <text class="value">{{schedule.start_time || '—'}}{{schedule.end_time ? (' - ' + schedule.end_time) : ''}}</text>
    </view>
  </view>

  <view class="form">
    <text class="form-label">任务日期</text>
    <picker mode="date" value="{{form.date}}" bindchange="handleDateChange">
      <view class="picker-field">{{form.date}}</view>
    </picker>
  </view>

  <view class="form source-card">
    <text class="form-label">作业来源</text>
    <view wx:if="{{quickPracticeInvalid}}" class="locked-source invalid">
      <text>快捷入口参数无效，请返回“我的学生”重新进入</text>
    </view>
    <view wx:elif="{{quickPractice}}" class="locked-source">
      <text>{{quickSubjectLabel}}（已锁定）</text>
    </view>
    <picker wx:else range="{{sourceLabels}}" value="{{sourceIndex}}" bindchange="handleSourceChange">
      <view class="picker-field">{{sourceLabels[sourceIndex]}}</view>
    </picker>
    <view wx:if="{{quickPractice && sourceLabels.length > 1}}" class="quick-source-mode">
      <text class="quick-source-label">练习类型</text>
      <picker range="{{sourceLabels}}" value="{{sourceIndex}}" bindchange="handleSourceChange">
        <view class="picker-field">{{sourceLabels[sourceIndex]}}</view>
      </picker>
    </view>

    <view wx:if="{{isCambridgeListeningSource}}" class="practice-picker-stack">
      <view class="practice-picker-row">
        <picker range="{{listeningBookLabels}}" value="{{listeningBookIndex}}" bindchange="handleListeningBookChange">
          <view class="picker-field compact">{{listeningBookLabels[listeningBookIndex] || '选择书册'}}</view>
        </picker>
        <picker range="{{listeningTestLabels}}" value="{{listeningTestIndex}}" bindchange="handleListeningTestChange">
          <view class="picker-field compact">{{listeningTestLabels[listeningTestIndex] || '选择 Test'}}</view>
        </picker>
      </view>
      <picker range="{{listeningScopeLabels}}" value="{{listeningScopeIndex}}" bindchange="handleListeningScopeChange">
        <view class="picker-field">{{listeningScopeLabels[listeningScopeIndex] || '选择范围'}}</view>
      </picker>
    </view>

    <view wx:elif="{{isIntensiveListeningSource}}" class="practice-picker-stack">
      <view class="mode-hint">精听每项对应一个现成的 Part 素材，学生进入后逐句完成。</view>
      <view class="practice-picker-row">
        <picker range="{{intensiveBookLabels}}" value="{{intensiveBookIndex}}" bindchange="handleIntensiveBookChange">
          <view class="picker-field compact">{{intensiveBookLabels[intensiveBookIndex] || '选择书册'}}</view>
        </picker>
        <picker range="{{intensiveTestLabels}}" value="{{intensiveTestIndex}}" bindchange="handleIntensiveTestChange">
          <view class="picker-field compact">{{intensiveTestLabels[intensiveTestIndex] || '选择 Test'}}</view>
        </picker>
      </view>
      <picker range="{{intensivePartLabels}}" value="{{intensivePartIndex}}" bindchange="handleIntensivePartChange">
        <view class="picker-field">{{intensivePartLabels[intensivePartIndex] || '选择 Part'}}</view>
      </picker>
    </view>

    <view wx:if="{{isReadingSource}}" class="practice-picker-stack">
      <view class="practice-picker-row">
        <picker range="{{readingBookLabels}}" value="{{readingBookIndex}}" bindchange="handleReadingBookChange">
          <view class="picker-field compact">{{readingBookLabels[readingBookIndex] || '选择书册'}}</view>
        </picker>
        <picker range="{{readingTestLabels}}" value="{{readingTestIndex}}" bindchange="handleReadingTestChange">
          <view class="picker-field compact">{{readingTestLabels[readingTestIndex] || '选择 Test'}}</view>
        </picker>
      </view>
      <picker range="{{readingScopeLabels}}" value="{{readingScopeIndex}}" bindchange="handleReadingScopeChange">
        <view class="picker-field">{{readingScopeLabels[readingScopeIndex] || '选择范围'}}</view>
      </picker>
    </view>

    <view class="practice-summary" wx:if="{{selectedPracticeSummary}}">
      <text>{{selectedPracticeSummary}}</text>
    </view>
    <view class="practice-actions" wx:if="{{(isCambridgeSource || isIntensiveListeningSource) && !editingTaskId}}">
      <button class="queue-btn" size="mini" bindtap="addSelectedPracticeToQueue">加入清单</button>
      <button wx:if="{{selectedPracticeList.length}}" class="queue-btn ghost" size="mini" bindtap="clearPracticeQueue">清空</button>
    </view>
    <view id="practice-queue" class="queue-panel" wx:if="{{selectedPracticeList.length}}">
      <view class="section-title-row">
        <text class="section-title">待布置清单</text>
        <text class="section-count">{{selectedPracticeList.length}} 项</text>
      </view>
      <view class="queue-item" wx:for="{{selectedPracticeList}}" wx:key="key">
        <view class="queue-main">
          <text class="queue-title">{{item.detail}}</text>
          <text class="queue-meta">{{item.summary}} ｜ {{item.plannedMinutes}} 分钟</text>
        </view>
        <button class="remove-btn" size="mini" data-key="{{item.key}}" bindtap="removePracticeFromQueue">移除</button>
      </view>
    </view>
    <view class="practice-summary muted" wx:if="{{catalogLoading}}">
      <text>正在加载练习目录...</text>
    </view>
  </view>

  <view class="form assigned-card">
    <view class="section-title-row">
      <text class="section-title">该学生已布置作业</text>
      <text class="section-count">{{existingTasks.length}} 项</text>
    </view>
    <view class="practice-summary muted" wx:if="{{existingLoading}}">
      <text>正在加载已布置作业...</text>
    </view>
    <view class="empty-hint" wx:elif="{{!existingTasks.length}}">
      <text>暂无已布置作业</text>
    </view>
    <view class="assigned-list" wx:else>
      <view class="assigned-item" wx:for="{{existingTasks}}" wx:key="id" wx:for-index="taskIndex">
        <view class="assigned-main">
          <text class="assigned-title">{{item.detail}}</text>
          <text class="assigned-meta">{{item.date}} ｜ {{item.category || '课后作业'}} ｜ {{item.planned_minutes || 0}} 分钟</text>
          <view class="practice-result" wx:if="{{item.practiceResultSummary}}">
            <text class="practice-result-main">{{item.practiceResultSummary}}</text>
            <text class="practice-result-wrong {{item.practice_result.wrong_count > 0 ? 'has-wrong' : ''}}">{{item.practiceWrongSummary}}</text>
            <button
              wx:if="{{item.practice_result.wrong_count > 0}}"
              class="result-detail-toggle"
              size="mini"
              data-index="{{taskIndex}}"
              loading="{{resultLoadingId == item.id}}"
              bindtap="togglePracticeResult"
            >{{expandedResultId == item.id ? '收起错题明细' : '查看具体错题'}}</button>
            <view class="wrong-detail-list" wx:if="{{expandedResultId == item.id}}">
              <view class="wrong-detail-card" wx:for="{{item.practiceWrongDetails}}" wx:key="question_label" wx:for-item="detail">
                <view class="wrong-detail-head">
                  <text class="wrong-question-label">{{detail.question_label}}</text>
                  <text class="wrong-score">{{detail.awarded}} / {{detail.marks}} 分</text>
                </view>
                <text class="wrong-question-title" wx:if="{{detail.question_title}}">{{detail.question_title}}</text>
                <view class="answer-line student-answer">
                  <text class="answer-label">学生答案</text>
                  <text class="answer-value">{{detail.studentAnswerText}}</text>
                </view>
                <view class="answer-line correct-answer">
                  <text class="answer-label">正确答案</text>
                  <text class="answer-value">{{detail.correctAnswerText}}</text>
                </view>
                <view class="wrong-analysis" wx:if="{{detail.analysis}}">
                  <text class="analysis-label">解析</text>
                  <text class="analysis-text">{{detail.analysis}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="assigned-side">
          <text class="status-pill">{{item.status_label}}</text>
          <view class="assigned-actions">
            <button
              wx:if="{{item.can_append_intensive && !editingTaskId}}"
              class="mini-action intensive"
              size="mini"
              data-index="{{taskIndex}}"
              bindtap="addIntensiveForTask"
            >加布精听</button>
            <button wx:if="{{item.can_edit}}" class="mini-action" size="mini" data-id="{{item.id}}" bindtap="startEditExistingTask">修改</button>
            <button
              wx:if="{{item.can_delete}}"
              class="mini-action danger"
              size="mini"
              loading="{{deletingTaskId == item.id}}"
              disabled="{{saving || deletingTaskId == item.id}}"
              data-id="{{item.id}}"
              bindtap="deleteExistingTask"
            >删除</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="edit-banner" wx:if="{{editingTaskId}}">
    <view class="edit-banner-main">
      <text class="edit-banner-title">正在修改已布置作业</text>
      <text class="edit-banner-desc">{{editingTaskSummary}}</text>
    </view>
    <button class="cancel-edit-btn" size="mini" bindtap="cancelEditExistingTask">取消</button>
  </view>

  <view class="form">
    <text class="form-label">任务分类</text>
    <input
      class="input"
      placeholder="如：雅思听力、课后作业"
      maxlength="32"
      value="{{form.category}}"
      data-field="category"
      bindinput="handleInput"
    />
  </view>

  <view class="form">
    <text class="form-label">作业内容</text>
    <textarea
      class="textarea"
      placeholder="填写学生需要完成的具体任务"
      maxlength="200"
      value="{{form.detail}}"
      data-field="detail"
      bindinput="handleInput"
    ></textarea>
    <view class="counter">{{form.detail.length}}/200</view>
  </view>

  <view class="form">
    <text class="form-label">预计时长（分钟）</text>
    <input
      class="input"
      type="number"
      placeholder="30"
      value="{{form.plannedMinutes}}"
      data-field="plannedMinutes"
      bindinput="handleInput"
    />
  </view>

  <view class="form">
    <text class="form-label">备注说明</text>
    <textarea
      class="textarea short-textarea"
      placeholder="可填写提交要求、参考材料、截止说明"
      maxlength="200"
      value="{{form.note}}"
      data-field="note"
      bindinput="handleInput"
    ></textarea>
    <view class="counter">{{form.note.length}}/200</view>
  </view>

  <button class="submit-btn" loading="{{saving}}" disabled="{{saving || quickPracticeInvalid}}" bindtap="submitHomework">{{editingTaskId ? '保存修改' : '保存并提醒学生'}}</button>
</view>
