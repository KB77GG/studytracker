.english-keyboard {
  width: 100%;
  max-width: 640px;
  margin: 0 auto;
  padding: 9px 7px calc(9px + env(safe-area-inset-bottom));
  border: 1px solid rgba(8, 127, 119, 0.12);
  border-radius: 14px 14px 0 0;
  background: rgba(231, 246, 243, 0.96);
  box-shadow: 0 -5px 14px rgba(35, 112, 105, 0.1);
  box-sizing: border-box;
}

.growth-line {
  width: 62%;
  max-width: 360px;
  height: 3px;
  margin: 0 auto 7px;
  overflow: hidden;
  border-radius: 999px;
  background: #c5e0db;
}

.growth-line-fill {
  width: 36%;
  height: 100%;
  border-radius: inherit;
  background: #087f77;
}

.key-row,
.separator-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  margin-bottom: 5px;
}

.key-row:nth-of-type(4) {
  padding: 0 14px;
}

.letter-key,
.separator-key {
  min-width: 0;
  height: 52px;
  margin: 0;
  padding: 0;
  border: 1px solid rgba(8, 127, 119, 0.08);
  border-radius: 7px;
  color: #0b1830;
  background: #fff;
  box-shadow: 0 3px 6px rgba(11, 24, 48, 0.12);
  font-family: ui-rounded, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 22px;
  line-height: 1;
  font-weight: 650;
  flex: 1 1 0;
  -webkit-tap-highlight-color: transparent;
}

.letter-key::after,
.separator-key::after,
.action-button::after {
  border: 0;
}

.letter-key:active:not([disabled]),
.separator-key:active:not([disabled]) {
  transform: translateY(2px);
  background: #d6efea;
  box-shadow: 0 1px 2px rgba(11, 24, 48, 0.14);
}

.letter-key[disabled],
.separator-key[disabled] {
  opacity: 0.55;
}

.backspace-key {
  flex: 0 0 50px;
  color: #fff;
  background: #7daaa5;
  font-size: 24px;
}

.separator-row {
  flex-wrap: wrap;
  margin-top: 1px;
}

.separator-key {
  flex: 0 0 72px;
  height: 31px;
  font-size: 14px;
}

.keyboard-actions {
  display: grid;
  grid-template-columns: 1fr 1.28fr;
  gap: 6px;
}

.action-button {
  width: 100%;
  height: 52px;
  margin: 3px 0 0;
  padding: 0 8px;
  border: 0;
  border-radius: 9px;
  font-size: 18px;
  line-height: 1;
  font-weight: 700;
}

.confirm-button,
.retry-button {
  color: #fff;
  background: #087f77;
  box-shadow: 0 4px 8px rgba(8, 127, 119, 0.22);
}

@media (max-width: 360px) {
  .english-keyboard {
    padding-left: 4px;
    padding-right: 4px;
  }

  .key-row,
  .separator-row {
    gap: 2px;
  }

  .letter-key {
    height: 48px;
    font-size: 20px;
  }

  .key-row:nth-of-type(4) {
    padding: 0 7px;
  }

  .backspace-key {
    flex-basis: 44px;
  }

  .action-button {
    height: 48px;
    font-size: 17px;
  }
}

@media (min-width: 768px) {
  .english-keyboard {
    max-width: 600px;
  }
}

.skip-button {
  border: 1px solid rgba(8, 127, 119, 0.5);
  color: #237069;
  background: rgba(255, 255, 255, 0.85);
}

.confirm-button[disabled] {
  opacity: 0.42;
  box-shadow: none;
}

@media (prefers-reduced-motion: reduce) {
  .letter-key,
  .separator-key,
  .action-button {
    transition: none;
  }
}
