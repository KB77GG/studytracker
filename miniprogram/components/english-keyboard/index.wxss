.english-keyboard {
  width: 100%;
  max-width: 560px;
  margin: 0 auto;
  padding: 6px 5px calc(6px + env(safe-area-inset-bottom));
  border: 1px solid rgba(8, 127, 119, 0.12);
  border-radius: 16px 16px 0 0;
  background: rgba(231, 246, 243, 0.96);
  box-shadow: 0 -4px 12px rgba(35, 112, 105, 0.09);
  box-sizing: border-box;
}

.typed-answer {
  min-height: 48px;
  margin-bottom: 6px;
  padding: 6px 12px;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: center;
  column-gap: 10px;
  border: 1px solid rgba(8, 127, 119, 0.2);
  border-radius: 11px;
  background: rgba(255, 255, 255, 0.94);
  box-sizing: border-box;
}

.typed-answer.status-wrong {
  border-color: rgba(210, 75, 85, 0.42);
  background: #fff8f8;
}

.typed-answer.status-correct {
  border-color: rgba(22, 143, 122, 0.42);
  background: #f5fffc;
}

.typed-answer.status-revealed {
  border-color: rgba(146, 82, 10, 0.32);
  background: #fffaf3;
}

.typed-answer-label {
  color: #52706d;
  font-size: 12px;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
}

.typed-answer-value {
  min-width: 0;
  min-height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  overflow-wrap: anywhere;
  word-break: break-word;
  color: #0b1830;
  font-family: ui-rounded, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 24px;
  line-height: 1.15;
  font-weight: 750;
  letter-spacing: 0.02em;
  text-align: center;
}

.typed-answer-text {
  max-width: 100%;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.typed-answer-placeholder {
  color: #8a9b99;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0;
}

.typed-answer-cursor {
  width: 2px;
  height: 24px;
  margin-left: 3px;
  border-radius: 2px;
  background: #087f77;
  animation: typedCursorBlink 1s steps(1) infinite;
}

@keyframes typedCursorBlink {
  50% {
    opacity: 0;
  }
}

.key-row,
.separator-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3px;
  margin-bottom: 4px;
}

.key-row-1 {
  padding: 0 4%;
}

.key-row-2 {
  padding: 0 7%;
}

.letter-key,
.separator-key {
  min-width: 0;
  height: 42px;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(8, 127, 119, 0.08);
  border-radius: 8px;
  color: #0b1830;
  background: #fff;
  box-shadow: 0 2px 5px rgba(11, 24, 48, 0.12);
  font-family: ui-rounded, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 20px;
  line-height: 1;
  font-weight: 700;
  flex: 1 1 0;
  text-align: center;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

.key-label {
  display: block;
  line-height: 1;
  transform: translateY(1px);
}

.separator-label {
  transform: translateY(1px);
}

.letter-key-pressed {
  transform: translateY(2px);
  background: #d6efea;
  box-shadow: 0 1px 2px rgba(11, 24, 48, 0.14);
}

.letter-key.is-disabled,
.separator-key.is-disabled {
  opacity: 0.55;
}

.backspace-key {
  flex: 0 0 44px;
  color: #fff;
  background: #7daaa5;
}

.backspace-icon {
  width: 24px;
  height: 24px;
}

.separator-row {
  flex-wrap: wrap;
  margin-top: 1px;
}

.separator-key {
  flex: 0 0 68px;
  height: 30px;
  font-size: 14px;
}

.keyboard-actions {
  width: 100%;
  display: flex;
  align-items: stretch;
  gap: 6px;
}

.keyboard-actions.wrong-actions .skip-button {
  flex: 0.9 1 0;
}

.keyboard-actions.wrong-actions .retry-button {
  flex: 1.2 1 0;
}

.action-button {
  width: 100%;
  min-width: 0;
  max-width: none;
  height: 44px;
  margin: 2px 0 0;
  padding: 0 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 10px;
  font-size: 17px;
  line-height: 1;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
  flex: 1 1 0;
}

.action-button-pressed {
  transform: translateY(1px);
  opacity: 0.88;
}

.action-button-label {
  display: block;
  line-height: 1;
  transform: translateY(2px);
}

.confirm-button,
.retry-button {
  color: #fff;
  background: #087f77;
  box-shadow: 0 4px 8px rgba(8, 127, 119, 0.22);
}

@media (max-width: 360px) {
  .english-keyboard {
    padding-left: 3px;
    padding-right: 3px;
  }

  .typed-answer {
    min-height: 44px;
    margin-bottom: 4px;
    padding: 5px 9px;
    column-gap: 7px;
  }

  .typed-answer-label {
    font-size: 11px;
  }

  .typed-answer-value {
    min-height: 28px;
    font-size: 21px;
  }

  .typed-answer-placeholder {
    font-size: 13px;
  }

  .key-row,
  .separator-row {
    gap: 2px;
  }

  .letter-key {
    height: 38px;
    font-size: 17px;
  }

  .key-row-1 {
    padding: 0 3.5%;
  }

  .key-row-2 {
    padding: 0 5.5%;
  }

  .backspace-key {
    flex-basis: 40px;
  }

  .action-button {
    height: 42px;
    padding: 0 4px;
    font-size: 15px;
  }

}

@media (min-width: 768px) {
  .english-keyboard {
    max-width: 560px;
  }

  .letter-key {
    height: 46px;
  }

  .action-button {
    height: 46px;
  }
}

@media (max-height: 700px) {
  .english-keyboard {
    padding-top: 4px;
    padding-bottom: calc(4px + env(safe-area-inset-bottom));
  }

  .key-row,
  .separator-row {
    margin-bottom: 3px;
  }

  .typed-answer {
    min-height: 42px;
    margin-bottom: 4px;
    padding-top: 4px;
    padding-bottom: 4px;
  }

  .typed-answer-value {
    min-height: 26px;
    font-size: 21px;
  }

  .typed-answer-cursor {
    height: 21px;
  }

  .letter-key {
    height: 38px;
    font-size: 17px;
  }

  .action-button {
    height: 40px;
  }
}

.skip-button {
  border: 1px solid rgba(8, 127, 119, 0.5);
  color: #237069;
  background: rgba(255, 255, 255, 0.85);
}

.confirm-button.is-disabled {
  opacity: 0.58;
  box-shadow: none;
}

@media (prefers-reduced-motion: reduce) {
  .typed-answer-cursor,
  .letter-key,
  .separator-key,
  .action-button {
    transition: none;
    animation: none;
  }
}
