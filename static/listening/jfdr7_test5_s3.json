  "parts": [
    {
      "name": "Part 3",
      "segments": [
        {
          "id": 1,
          "start": 55.7,
          "end": 57.14,
          "text": "Sally: Excuse me, Professor.",
          "translation": "打扰一下，教授。",
          "source_order": 0,
          "source_start_time": 55700,
          "source_end_time": 57140
        },
        {
          "id": 2,
          "start": 57.9,
          "end": 59.56,
          "text": "Sally: Can I talk to you for a minute?",
          "translation": "我能和您谈一会儿吗？",
          "source_order": 1,
          "source_start_time": 57900,
          "source_end_time": 59560
        },
        {
          "id": 3,
          "start": 60.38,
          "end": 61.72,
          "text": "Tutor: Yes, do come in.",
          "translation": "可以，请进。",
          "source_order": 2,
          "source_start_time": 60380,
          "source_end_time": 61720
        },
        {
          "id": 4,
          "start": 62.3,
          "end": 63.92,
          "text": "Tutor: So you're Sally Layman?",
          "translation": "你是Sally Layman，对吗？",
          "source_order": 3,
          "source_start_time": 62300,
          "source_end_time": 63920
        },
        {
          "id": 5,
          "start": 64.38,
          "end": 65.22,
          "text": "Sally: That's it.",
          "translation": "是的。",
          "source_order": 4,
          "source_start_time": 64380,
          "source_end_time": 65220
        },
        {
          "id": 6,
          "start": 65.78,
          "end": 68.68,
          "text": "Tutor: You want to discuss with me changing courses, right?",
          "translation": "你想和我讨论转专业的事，对吗？",
          "source_order": 5,
          "source_start_time": 65780,
          "source_end_time": 68680
        },
        {
          "id": 7,
          "start": 69.36,
          "end": 69.78,
          "text": "Sally: Yes.",
          "translation": "是的。",
          "source_order": 6,
          "source_start_time": 69360,
          "source_end_time": 69780
        },
        {
          "id": 8,
          "start": 70.7,
          "end": 71.62,
          "text": "Tutor: All right.",
          "translation": "好的。",
          "source_order": 7,
          "source_start_time": 70700,
          "source_end_time": 71620
        },
        {
          "id": 9,
          "start": 71.62,
          "end": 73.82,
          "text": "Tutor: What course are you doing at present, Sally?",
          "translation": "Sally，你目前读的是什么专业？",
          "source_order": 8,
          "source_start_time": 71620,
          "source_end_time": 73820
        },
        {
          "id": 10,
          "start": 74.4,
          "end": 76.0,
          "text": "Sally: It's Economic History.",
          "translation": "经济史。",
          "source_order": 9,
          "source_start_time": 74400,
          "source_end_time": 76000
        },
        {
          "id": 11,
          "start": 76.78,
          "end": 77.56,
          "text": "Tutor: OK.",
          "translation": "好的。",
          "source_order": 10,
          "source_start_time": 76780,
          "source_end_time": 77560
        },
        {
          "id": 12,
          "start": 77.56,
          "end": 79.34,
          "text": "Tutor: And when did you begin this course?",
          "translation": "你是什么时候开始读这个专业的？",
          "source_order": 11,
          "source_start_time": 77560,
          "source_end_time": 79340
        },
        {
          "id": 13,
          "start": 80.07,
          "end": 81.06,
          "text": "Sally: Let me think.",
          "translation": "让我想想。",
          "source_order": 12,
          "source_start_time": 80070,
          "source_end_time": 81060
        },
        {
          "id": 14,
          "start": 81.64,
          "end": 83.92,
          "text": "Sally: Erm ... it was last September.",
          "translation": "嗯……是去年九月。",
          "source_order": 13,
          "source_start_time": 81640,
          "source_end_time": 83920
        },
        {
          "id": 15,
          "start": 84.9,
          "end": 85.18,
          "text": "Tutor: Right.",
          "translation": "好。",
          "source_order": 14,
          "source_start_time": 84900,
          "source_end_time": 85180
        },
        {
          "id": 16,
          "start": 85.62,
          "end": 85.82,
          "text": "Tutor: Good.",
          "translation": "很好。",
          "source_order": 15,
          "source_start_time": 85620,
          "source_end_time": 85820
        },
        {
          "id": 17,
          "start": 86.6,
          "end": 92.46,
          "text": "Tutor: Before we talk through all your problems with the course, I want to know what courses you'd like to change to.",
          "translation": "在详细讨论你在这门专业中遇到的所有问题之前，我想知道你希望转到什么专业。",
          "source_order": 16,
          "source_start_time": 86600,
          "source_end_time": 92460
        },
        {
          "id": 18,
          "start": 93.4,
          "end": 99.26,
          "text": "Sally: Well, there're several courses that I've thought about, but my first choice would be Politics.",
          "translation": "嗯，我考虑过几个专业，但我的第一选择是政治学。",
          "source_order": 17,
          "source_start_time": 93400,
          "source_end_time": 99260
        },
        {
          "id": 19,
          "start": 100.22,
          "end": 103.6,
          "text": "Tutor: Oh, it's one of the most popular courses in our college.",
          "translation": "哦，那是我们学院最热门的专业之一。",
          "source_order": 18,
          "source_start_time": 100220,
          "source_end_time": 103600
        },
        {
          "id": 20,
          "start": 104.16,
          "end": 105.28,
          "text": "Sally: Yes, I know.",
          "translation": "是的，我知道。",
          "source_order": 19,
          "source_start_time": 104160,
          "source_end_time": 105280
        },
        {
          "id": 21,
          "start": 105.78,
          "end": 108.38,
          "text": "Sally: So it means there might not be places available?",
          "translation": "所以这意味着可能没有名额了？",
          "source_order": 20,
          "source_start_time": 105780,
          "source_end_time": 108380
        },
        {
          "id": 22,
          "start": 109.36,
          "end": 109.84,
          "text": "Tutor: That's right.",
          "translation": "没错。",
          "source_order": 21,
          "source_start_time": 109360,
          "source_end_time": 109840
        },
        {
          "id": 23,
          "start": 110.5,
          "end": 111.84,
          "text": "Tutor: I'll still make a note of that.",
          "translation": "我还是会把它记下来。",
          "source_order": 22,
          "source_start_time": 110500,
          "source_end_time": 111840
        },
        {
          "id": 24,
          "start": 112.32,
          "end": 114.3,
          "text": "Tutor: But it's better to give another option.",
          "translation": "不过，最好再提供一个备选方案。",
          "source_order": 23,
          "source_start_time": 112320,
          "source_end_time": 114300
        },
        {
          "id": 25,
          "start": 115.0,
          "end": 125.6,
          "text": "Sally: Well, I've thought of changing the course entirely to Business Studies, but then I realize it is new to me, so I think Philosophy might be a better choice.",
          "translation": "嗯，我曾想彻底转去读商业研究，但后来意识到这个领域对我来说很陌生，所以我觉得哲学可能是更好的选择。",
          "source_order": 24,
          "source_start_time": 115000,
          "source_end_time": 125600
        },
        {
          "id": 26,
          "start": 174.24,
          "end": 175.48,
          "text": "Tutor: OK, that's useful to know.",
          "translation": "好的，知道这一点很有用。",
          "source_order": 25,
          "source_start_time": 174240,
          "source_end_time": 175480
        },
        {
          "id": 27,
          "start": 176.16,
          "end": 183.54,
          "text": "Tutor: Then let's talk through any problems you've been having at the moment and see if there is any possibility for us to offer help.",
          "translation": "那么，我们来详细谈谈你目前遇到的问题，看看我们是否有可能提供帮助。",
          "source_order": 26,
          "source_start_time": 176160,
          "source_end_time": 183540
        },
        {
          "id": 28,
          "start": 184.16,
          "end": 190.84,
          "text": "Tutor: After all, with all the efforts that you've made already, it'll be a pity to give up the present course and completely start a new one.",
          "translation": "毕竟，你已经付出了这么多努力，如果放弃目前的专业，完全从头开始读一个新专业，那就太可惜了。",
          "source_order": 27,
          "source_start_time": 184160,
          "source_end_time": 190840
        },
        {
          "id": 29,
          "start": 192.68,
          "end": 194.9,
          "text": "Sally: Yes, I agree with that.",
          "translation": "是的，我也这么认为。",
          "source_order": 28,
          "source_start_time": 192680,
          "source_end_time": 194900
        },
        {
          "id": 30,
          "start": 195.42,
          "end": 198.96,
          "text": "Sally: I've learnt something valuable about Economic History.",
          "translation": "我从经济史中学到了一些有价值的东西。",
          "source_order": 29,
          "source_start_time": 195420,
          "source_end_time": 198960
        },
        {
          "id": 31,
          "start": 199.64,
          "end": 199.98,
          "text": "Tutor: Good.",
          "translation": "很好。",
          "source_order": 30,
          "source_start_time": 199640,
          "source_end_time": 199980
        },
        {
          "id": 32,
          "start": 200.58,
          "end": 202.58,
          "text": "Tutor: Well, let's talk about your problems.",
          "translation": "好，我们来谈谈你的问题。",
          "source_order": 31,
          "source_start_time": 200580,
          "source_end_time": 202580
        },
        {
          "id": 33,
          "start": 203.42,
          "end": 206.72,
          "text": "Tutor: What do you think is your significant difficulty in the course?",
          "translation": "你认为自己在这门专业中面临的主要困难是什么？",
          "source_order": 32,
          "source_start_time": 203420,
          "source_end_time": 206720
        },
        {
          "id": 34,
          "start": 207.56,
          "end": 212.32,
          "text": "Sally: Well, I have to say the biggest problem is that the lectures are difficult.",
          "translation": "嗯，我得说，最大的问题是课程讲座很难听懂。",
          "source_order": 33,
          "source_start_time": 207560,
          "source_end_time": 212320
        },
        {
          "id": 35,
          "start": 213.28,
          "end": 214.24,
          "text": "Tutor: OK.",
          "translation": "好的。",
          "source_order": 34,
          "source_start_time": 213280,
          "source_end_time": 214240
        },
        {
          "id": 36,
          "start": 214.24,
          "end": 216.94,
          "text": "Tutor: And have you tried something to overcome this problem?",
          "translation": "你尝试过什么方法来克服这个问题吗？",
          "source_order": 35,
          "source_start_time": 214240,
          "source_end_time": 216940
        },
        {
          "id": 37,
          "start": 216.94,
          "end": 218.62,
          "text": "Sally: Yes, I have.",
          "translation": "是的，尝试过。",
          "source_order": 36,
          "source_start_time": 216940,
          "source_end_time": 218620
        },
        {
          "id": 38,
          "start": 219.12,
          "end": 224.26,
          "text": "Sally: I tried recording the lectures because I couldn't follow what the lecturer said.",
          "translation": "因为我跟不上讲师讲的内容，所以我试着把讲座录下来。",
          "source_order": 37,
          "source_start_time": 219120,
          "source_end_time": 224260
        },
        {
          "id": 39,
          "start": 224.9,
          "end": 226.26,
          "text": "Tutor: Yes, that's a good idea.",
          "translation": "是的，这是个好主意。",
          "source_order": 38,
          "source_start_time": 224900,
          "source_end_time": 226260
        },
        {
          "id": 40,
          "start": 226.78,
          "end": 228.24,
          "text": "Tutor: And did you find it helped?",
          "translation": "你觉得有帮助吗？",
          "source_order": 39,
          "source_start_time": 226780,
          "source_end_time": 228240
        },
        {
          "id": 41,
          "start": 228.9,
          "end": 231.14,
          "text": "Sally: To a certain extent, but ...",
          "translation": "在一定程度上有帮助，但是……",
          "source_order": 40,
          "source_start_time": 228900,
          "source_end_time": 231140
        },
        {
          "id": 42,
          "start": 231.8,
          "end": 243.52,
          "text": "Tutor: Well, recording is a good strategy, but I also advise you to take part in the discussion group with other fellow students to discuss the lectures and exchange ideas with them.",
          "translation": "嗯，录音是个好办法，不过我也建议你参加同学们的讨论小组，一起讨论讲座内容并交流想法。",
          "source_order": 41,
          "source_start_time": 231800,
          "source_end_time": 243520
        },
        {
          "id": 43,
          "start": 243.52,
          "end": 247.54,
          "text": "Sally: Yes, I've seen some of my classmates doing that.",
          "translation": "是的，我见过一些同学这样做。",
          "source_order": 42,
          "source_start_time": 243520,
          "source_end_time": 247540
        },
        {
          "id": 44,
          "start": 248.06,
          "end": 249.94,
          "text": "Sally: I'll ask them if I can join.",
          "translation": "我会问问他们自己能否加入。",
          "source_order": 43,
          "source_start_time": 248060,
          "source_end_time": 249940
        },
        {
          "id": 45,
          "start": 250.76,
          "end": 252.94,
          "text": "Tutor: Good, I'm sure you'll find it helps.",
          "translation": "很好，我相信你会发现这很有帮助。",
          "source_order": 44,
          "source_start_time": 250760,
          "source_end_time": 252940
        },
        {
          "id": 46,
          "start": 253.44,
          "end": 254.76,
          "text": "Tutor: And any other problems?",
          "translation": "还有其他问题吗？",
          "source_order": 45,
          "source_start_time": 253440,
          "source_end_time": 254760
        },
        {
          "id": 47,
          "start": 255.5,
          "end": 261.38,
          "text": "Sally: Yes, the second problem is, I think there aren't enough tutorials for this course.",
          "translation": "有，第二个问题是，我觉得这个专业的辅导课不够多。",
          "source_order": 46,
          "source_start_time": 255500,
          "source_end_time": 261380
        },
        {
          "id": 48,
          "start": 262.27,
          "end": 263.16,
          "text": "Tutor: OK.",
          "translation": "好的。",
          "source_order": 47,
          "source_start_time": 262270,
          "source_end_time": 263160
        },
        {
          "id": 49,
          "start": 263.16,
          "end": 265.68,
          "text": "Tutor: I think you can talk to your tutor about this.",
          "translation": "我觉得你可以和你的导师谈谈这件事。",
          "source_order": 48,
          "source_start_time": 263160,
          "source_end_time": 265680
        },
        {
          "id": 50,
          "start": 266.3,
          "end": 267.82,
          "text": "Sally: Yes, I did that.",
          "translation": "是的，我谈过了。",
          "source_order": 49,
          "source_start_time": 266300,
          "source_end_time": 267820
        },
        {
          "id": 51,
          "start": 268.2,
          "end": 272.5,
          "text": "Sally: But the tutor is so busy that I must wait until she is available.",
          "translation": "但导师太忙了，我必须等到她有空才行。",
          "source_order": 50,
          "source_start_time": 268200,
          "source_end_time": 272500
        },
        {
          "id": 52,
          "start": 272.5,
          "end": 275.84,
          "text": "Tutor: Why don't you try arranging meetings ahead of time?",
          "translation": "你为什么不试试提前预约呢？",
          "source_order": 51,
          "source_start_time": 272500,
          "source_end_time": 275840
        },
        {
          "id": 53,
          "start": 276.54,
          "end": 278.6,
          "text": "Sally: Well, I can try this way.",
          "translation": "嗯，我可以试试这个办法。",
          "source_order": 52,
          "source_start_time": 276540,
          "source_end_time": 278600
        },
        {
          "id": 54,
          "start": 279.26,
          "end": 279.58,
          "text": "Tutor: Good.",
          "translation": "很好。",
          "source_order": 53,
          "source_start_time": 279260,
          "source_end_time": 279580
        },
        {
          "id": 55,
          "start": 280.28,
          "end": 285.54,
          "text": "Sally: But I suppose the thing that made me upset recently is my poor assignment grade.",
          "translation": "不过，我想最近最让我沮丧的是作业成绩很差。",
          "source_order": 54,
          "source_start_time": 280280,
          "source_end_time": 285540
        },
        {
          "id": 56,
          "start": 286.36,
          "end": 288.6,
          "text": "Tutor: Oh, the grade is an important issue.",
          "translation": "哦，成绩确实是个重要问题。",
          "source_order": 55,
          "source_start_time": 286360,
          "source_end_time": 288600
        },
        {
          "id": 57,
          "start": 289.32,
          "end": 293.06,
          "text": "Sally: Well, I think I've tried my best to achieve a good score.",
          "translation": "嗯，我觉得自己已经尽了最大努力去取得好成绩。",
          "source_order": 56,
          "source_start_time": 289320,
          "source_end_time": 293060
        },
        {
          "id": 58,
          "start": 293.66,
          "end": 298.94,
          "text": "Sally: I did more background reading than before for the last assignment we just submitted.",
          "translation": "对于我们刚提交的上一次作业，我比以前做了更多的背景阅读。",
          "source_order": 57,
          "source_start_time": 293660,
          "source_end_time": 298940
        },
        {
          "id": 59,
          "start": 299.68,
          "end": 302.14,
          "text": "Tutor: Good, and did you feel that helped?",
          "translation": "很好，你觉得这样有帮助吗？",
          "source_order": 58,
          "source_start_time": 299680,
          "source_end_time": 302140
        },
        {
          "id": 60,
          "start": 302.14,
          "end": 304.72,
          "text": "Sally: Oh yes, I think so.",
          "translation": "哦，有的，我觉得有帮助。",
          "source_order": 59,
          "source_start_time": 302140,
          "source_end_time": 304720
        },
        {
          "id": 61,
          "start": 305.44,
          "end": 314.32,
          "text": "Tutor: Well, I think you can try another strategy, which is to visit student services, which offer a lot of helpful advice on assignment preparation.",
          "translation": "嗯，我觉得你可以尝试另一个办法，就是去学生服务中心，那里会提供许多有关作业准备的实用建议。",
          "source_order": 60,
          "source_start_time": 305440,
          "source_end_time": 314320
        },
        {
          "id": 62,
          "start": 314.88,
          "end": 317.34,
          "text": "Sally: Oh, I've never heard about that.",
          "translation": "哦，我从来没听说过。",
          "source_order": 61,
          "source_start_time": 314880,
          "source_end_time": 317340
        },
        {
          "id": 63,
          "start": 317.94,
          "end": 320.44,
          "text": "Tutor: I'll give you a booklet with details on this.",
          "translation": "我会给你一本介绍详情的小册子。",
          "source_order": 62,
          "source_start_time": 317940,
          "source_end_time": 320440
        },
        {
          "id": 64,
          "start": 321.06,
          "end": 322.78,
          "text": "Tutor: You'll find it well worth trying.",
          "translation": "你会发现这非常值得一试。",
          "source_order": 63,
          "source_start_time": 321060,
          "source_end_time": 322780
        },
        {
          "id": 65,
          "start": 324.42,
          "end": 326.06,
          "text": "Sally: OK, I'll certainly try it.",
          "translation": "好的，我一定会试试。",
          "source_order": 64,
          "source_start_time": 324420,
          "source_end_time": 326060
        },
        {
          "id": 66,
          "start": 327.46,
          "end": 328.66,
          "text": "Tutor: OK, that's all the problem.",
          "translation": "好的，问题就这些。",
          "source_order": 65,
          "source_start_time": 327460,
          "source_end_time": 328660
        },
        {
          "id": 67,
          "start": 328.66,
          "end": 333.22,
          "text": "Tutor: Well, I've made a record of our discussions and suggested strategies.",
          "translation": "嗯，我已经记录了我们讨论的内容和建议采用的方法。",
          "source_order": 66,
          "source_start_time": 328660,
          "source_end_time": 333220
        },
        {
          "id": 68,
          "start": 334.02,
          "end": 343.42,
          "text": "Tutor: Typically, we advise you to try out these suggestions for a short period and then come back to discuss the situation to see whether it is improved.",
          "translation": "通常，我们会建议你先在短期内尝试这些办法，然后再回来讨论情况，看看是否有所改善。",
          "source_order": 67,
          "source_start_time": 334020,
          "source_end_time": 343420
        },
        {
          "id": 69,
          "start": 344.18,
          "end": 347.56,
          "text": "Tutor: If not, we will start considering alternative courses.",
          "translation": "如果没有改善，我们就会开始考虑其他专业。",
          "source_order": 68,
          "source_start_time": 344180,
          "source_end_time": 347560
        },
        {
          "id": 70,
          "start": 349.28,
          "end": 350.46,
          "text": "Sally: OK, when shall I come back?",
          "translation": "好的，我什么时候再来？",
          "source_order": 69,
          "source_start_time": 349280,
          "source_end_time": 350460
        },
        {
          "id": 71,
          "start": 351.34,
          "end": 352.86,
          "text": "Tutor: How about in a-month time?",
          "translation": "一个月后怎么样？",
          "source_order": 70,
          "source_start_time": 351340,
          "source_end_time": 352860
        },
        {
          "id": 72,
          "start": 353.74,
          "end": 354.62,
          "text": "Sally: OK.",
          "translation": "好的。",
          "source_order": 71,
          "source_start_time": 353740,
          "source_end_time": 354620
        },
        {
          "id": 73,
          "start": 354.62,
          "end": 356.9,
          "text": "Tutor: That will be on the 17th of February.",
          "translation": "那就是2月17日。",
          "source_order": 72,
          "source_start_time": 354620,
          "source_end_time": 356900
        },
        {
          "id": 74,
          "start": 356.9,
          "end": 360.1,
          "text": "Tutor: How about half past three in the afternoon?",
          "translation": "下午三点半怎么样？",
          "source_order": 73,
          "source_start_time": 356900,
          "source_end_time": 360100
        },
        {
          "id": 75,
          "start": 360.72,
          "end": 361.72,
          "text": "Tutor: Is that all right for you?",
          "translation": "这个时间你方便吗？",
          "source_order": 74,
          "source_start_time": 360720,
          "source_end_time": 361720
        },
        {
          "id": 76,
          "start": 362.3,
          "end": 363.44,
          "text": "Sally: Yes, sure.",
          "translation": "是的，当然。",
          "source_order": 75,
          "source_start_time": 362300,
          "source_end_time": 363440
        },
        {
          "id": 77,
          "start": 363.98,
          "end": 365.34,
          "text": "Sally: And where shall I meet you?",
          "translation": "我应该在哪里和您见面？",
          "source_order": 76,
          "source_start_time": 363980,
          "source_end_time": 365340
        },
        {
          "id": 78,
          "start": 365.88,
          "end": 368.32,
          "text": "Tutor: I'm afraid I will be on leave at that time.",
          "translation": "恐怕那时我正在休假。",
          "source_order": 77,
          "source_start_time": 365880,
          "source_end_time": 368320
        },
        {
          "id": 79,
          "start": 368.9,
          "end": 374.38,
          "text": "Tutor: But I'll leave this record to our senior adviser, and you will meet with him then in this office.",
          "translation": "不过，我会把这份记录交给我们的高级顾问，到时你会在这间办公室和他见面。",
          "source_order": 78,
          "source_start_time": 368900,
          "source_end_time": 374380
        },
        {
          "id": 80,
          "start": 375.28,
          "end": 376.18,
          "text": "Sally: OK.",
          "translation": "好的。",
          "source_order": 79,
          "source_start_time": 375280,
          "source_end_time": 376180
        },
        {
          "id": 81,
          "start": 376.18,
          "end": 377.5,
          "text": "Tutor: Good, that's it!",
          "translation": "很好，就这样！",
          "source_order": 80,
          "source_start_time": 376180,
          "source_end_time": 377500
        },
        {
          "id": 82,
          "start": 377.94,
          "end": 380.08,
          "text": "Tutor: Let's see whether things can improve, Sally.",
          "translation": "Sally，让我们看看情况能否有所改善。",
          "source_order": 81,
          "source_start_time": 377940,
          "source_end_time": 380080
        },
        {
          "id": 83,
          "start": 380.9,
          "end": 381.72,
          "text": "Sally: OK.",
          "translation": "好的。",
          "source_order": 82,
          "source_start_time": 380900,
          "source_end_time": 381720
        },
        {
          "id": 84,
          "start": 381.72,
          "end": 382.74,
          "text": "Sally: Thanks very much!",
          "translation": "非常感谢！",
          "source_order": 83,
          "source_start_time": 381720,
          "source_end_time": 382740
        },
        {
          "id": 85,
          "start": 383.46,
          "end": 384.12,
          "text": "Tutor: My pleasure.",
          "translation": "不客气。",
          "source_order": 84,
          "source_start_time": 383460,
          "source_end_time": 384120
        },
        {
          "id": 86,
          "start": 384.7,
          "end": 384.98,
          "text": "Tutor: Bye!",
          "translation": "再见！",
          "source_order": 85,
