  "parts": [
    {
      "name": "Part 1",
      "segments": [
        {
          "id": 1,
          "start": 99.74,
          "end": 100.88,
          "text": "Director: Good morning.",
          "translation": "早上好。",
          "source_order": 0,
          "source_start_time": 99740,
          "source_end_time": 100880
        },
        {
          "id": 2,
          "start": 101.3,
          "end": 104.44,
          "text": "Director: Welcome to the Early Learning Childcare Centre.",
          "translation": "欢迎来到早期学习儿童保育中心。",
          "source_order": 1,
          "source_start_time": 101300,
          "source_end_time": 104440
        },
        {
          "id": 3,
          "start": 104.98,
          "end": 106.16,
          "text": "Director: How can I help you?",
          "translation": "有什么可以帮您的吗？",
          "source_order": 2,
          "source_start_time": 104980,
          "source_end_time": 106160
        },
        {
          "id": 4,
          "start": 106.66,
          "end": 107.24,
          "text": "Man: Good morning.",
          "translation": "早上好。",
          "source_order": 3,
          "source_start_time": 106660,
          "source_end_time": 107240
        },
        {
          "id": 5,
          "start": 107.68,
          "end": 113.88,
          "text": "Man: I came across the advertisement for your childcare centre last week, and I'm calling to get some details.",
          "translation": "我上周偶然看到了你们儿童保育中心的广告，打电话来是想了解一些详情。",
          "source_order": 4,
          "source_start_time": 107680,
          "source_end_time": 113880
        },
        {
          "id": 6,
          "start": 114.8,
          "end": 116.52,
          "text": "Man: I'm thinking of enrolling my daughter.",
          "translation": "我正考虑让女儿报名。",
          "source_order": 5,
          "source_start_time": 114800,
          "source_end_time": 116520
        },
        {
          "id": 7,
          "start": 117.39,
          "end": 118.26,
          "text": "Director: OK.",
          "translation": "好的。",
          "source_order": 6,
          "source_start_time": 117390,
          "source_end_time": 118260
        },
        {
          "id": 8,
          "start": 118.26,
          "end": 119.72,
          "text": "Director: What do you want to know, sir?",
          "translation": "先生，您想了解什么？",
          "source_order": 7,
          "source_start_time": 118260,
          "source_end_time": 119720
        },
        {
          "id": 9,
          "start": 120.54,
          "end": 127.38,
          "text": "Man: Well, I've learnt from the brochure that there are different types of caring, and I'm interested in the short-day one.",
          "translation": "嗯，我从宣传册上了解到你们有不同类型的托管服务，我对短日托管感兴趣。",
          "source_order": 8,
          "source_start_time": 120540,
          "source_end_time": 127380
        },
        {
          "id": 10,
          "start": 127.94,
          "end": 128.98,
          "text": "Man: How much is the cost?",
          "translation": "费用是多少？",
          "source_order": 9,
          "source_start_time": 127940,
          "source_end_time": 128980
        },
        {
          "id": 11,
          "start": 129.64,
          "end": 132.34,
          "text": "Director: Well, it depends on the age of your child.",
          "translation": "这个要看您孩子的年龄。",
          "source_order": 10,
          "source_start_time": 129640,
          "source_end_time": 132340
        },
        {
          "id": 12,
          "start": 132.88,
          "end": 143.42,
          "text": "Director: For children over the age of two, we charge 30 dollars a day, and for those younger than two, you have to pay 37.50 dollars.",
          "translation": "两岁以上的儿童每天收费30美元，两岁以下则需支付37.50美元。",
          "source_order": 11,
          "source_start_time": 132880,
          "source_end_time": 143420
        },
        {
          "id": 13,
          "start": 144.3,
          "end": 145.88,
          "text": "Man: Does it include meals?",
          "translation": "费用包括餐食吗？",
          "source_order": 12,
          "source_start_time": 144300,
          "source_end_time": 145880
        },
        {
          "id": 14,
          "start": 146.72,
          "end": 148.12,
          "text": "Director: Well, I'm afraid not.",
          "translation": "恐怕不包括。",
          "source_order": 13,
          "source_start_time": 146720,
          "source_end_time": 148120
        },
        {
          "id": 15,
          "start": 148.88,
          "end": 150.68,
          "text": "Director: You have to pay extra for them.",
          "translation": "餐食需要另外付费。",
          "source_order": 14,
          "source_start_time": 148880,
          "source_end_time": 150680
        },
        {
          "id": 16,
          "start": 150.68,
          "end": 154.54,
          "text": "Director: But we offer you free care for 20 hours weekly.",
          "translation": "不过，我们每周提供20小时的免费托管。",
          "source_order": 15,
          "source_start_time": 150680,
          "source_end_time": 154540
        },
        {
          "id": 17,
          "start": 155.24,
          "end": 162.9,
          "text": "Director: It used to be 10 hours, but this month, we extended the length of time as a special offer for our clients.",
          "translation": "以前是10小时，但本月我们为客户推出特别优惠，延长了免费托管时间。",
          "source_order": 16,
          "source_start_time": 155240,
          "source_end_time": 162900
        },
        {
          "id": 18,
          "start": 163.74,
          "end": 165.76,
          "text": "Man: Oh, that will be of great help.",
          "translation": "哦，那可太有帮助了。",
          "source_order": 17,
          "source_start_time": 163740,
          "source_end_time": 165760
        },
        {
          "id": 19,
          "start": 167.18,
          "end": 168.26,
          "text": "Man: OK, that's about the fee.",
          "translation": "好的，费用方面就这些。",
          "source_order": 18,
          "source_start_time": 167180,
          "source_end_time": 168260
        },
        {
          "id": 20,
          "start": 168.86,
          "end": 175.64,
          "text": "Man: Then may I know more about your centre, something about the children's activities, the staff etc.?",
          "translation": "那我可以再了解一下你们中心吗，比如孩子们的活动、工作人员之类的？",
          "source_order": 19,
          "source_start_time": 168860,
          "source_end_time": 175640
        },
        {
          "id": 21,
          "start": 176.48,
          "end": 177.32,
          "text": "Director: OK.",
          "translation": "好的。",
          "source_order": 20,
          "source_start_time": 176480,
          "source_end_time": 177320
        },
        {
          "id": 22,
          "start": 177.32,
          "end": 190.24,
          "text": "Director: We offer a diversity of indoor activities, which cater for children of different ages, for example, paintings with watercolours, singing, dancing, games etc.",
          "translation": "我们提供丰富多样的室内活动，以满足不同年龄儿童的需求，例如水彩画、唱歌、跳舞和游戏等。",
          "source_order": 21,
          "source_start_time": 177320,
          "source_end_time": 190240
        },
        {
          "id": 23,
          "start": 191.14,
          "end": 199.82,
          "text": "Director: Moreover, when the weather is good, we always take children to our playground and organize different programmes in the open air.",
          "translation": "此外，天气好的时候，我们总会带孩子们去游乐场，组织各种户外活动。",
          "source_order": 22,
          "source_start_time": 191140,
          "source_end_time": 199820
        },
        {
          "id": 24,
          "start": 200.5,
          "end": 201.08,
          "text": "Man: That's great!",
          "translation": "太好了！",
          "source_order": 23,
          "source_start_time": 200500,
          "source_end_time": 201080
        },
        {
          "id": 25,
          "start": 201.76,
          "end": 204.58,
          "text": "Man: Outdoor activities are essential for children.",
          "translation": "户外活动对孩子来说非常重要。",
          "source_order": 24,
          "source_start_time": 201760,
          "source_end_time": 204580
        },
        {
          "id": 26,
          "start": 205.38,
          "end": 206.46,
          "text": "Man: What about the teachers?",
          "translation": "老师们怎么样？",
          "source_order": 25,
          "source_start_time": 205380,
          "source_end_time": 206460
        },
        {
          "id": 27,
          "start": 207.3,
          "end": 208.32,
          "text": "Man: Are they experienced?",
          "translation": "他们有经验吗？",
          "source_order": 26,
          "source_start_time": 207300,
          "source_end_time": 208320
        },
        {
          "id": 28,
          "start": 209.2,
          "end": 209.7,
          "text": "Director: Of course!",
          "translation": "当然！",
          "source_order": 27,
          "source_start_time": 209200,
          "source_end_time": 209700
        },
        {
          "id": 29,
          "start": 210.3,
          "end": 219.22,
          "text": "Director: All teachers in our centre have relevant working experience of at least three years and specialize in primary school education.",
          "translation": "我们中心的所有老师都至少有三年相关工作经验，并且专长是小学教育。",
          "source_order": 28,
          "source_start_time": 210300,
          "source_end_time": 219220
        },
        {
          "id": 30,
          "start": 220.04,
          "end": 220.38,
          "text": "Man: Great!",
          "translation": "太好了！",
          "source_order": 29,
          "source_start_time": 220040,
          "source_end_time": 220380
        },
        {
          "id": 31,
          "start": 220.98,
          "end": 223.82,
          "text": "Man: Then they must be professional in dealing with children.",
          "translation": "那他们在照顾孩子方面一定很专业。",
          "source_order": 30,
          "source_start_time": 220980,
          "source_end_time": 223820
        },
        {
          "id": 32,
          "start": 224.6,
          "end": 238.84,
          "text": "Man: Another thing is, I've heard from other parents that they can receive a report from their caring centres every weekend about how their children perform during that week, and I wonder, is there anything like that in your centre?",
          "translation": "还有一件事，我听其他家长说，他们每个周末都会收到托管中心出具的报告，介绍孩子当周的表现。我想知道，你们中心也有这样的报告吗？",
          "source_order": 31,
          "source_start_time": 224600,
          "source_end_time": 238840
        },
        {
          "id": 33,
          "start": 239.48,
          "end": 241.5,
          "text": "Director: Yes, we provide that too.",
          "translation": "有的，我们也提供。",
          "source_order": 32,
          "source_start_time": 239480,
          "source_end_time": 241500
        },
        {
          "id": 34,
          "start": 242.22,
          "end": 242.56,
          "text": "Man: Great!",
          "translation": "太好了！",
          "source_order": 33,
          "source_start_time": 242220,
          "source_end_time": 242560
        },
        {
          "id": 35,
          "start": 243.06,
          "end": 246.08,
          "text": "Man: Then I want to enrol my daughter as soon as possible.",
          "translation": "那我想尽快给女儿报名。",
          "source_order": 34,
          "source_start_time": 243060,
          "source_end_time": 246080
        },
        {
          "id": 36,
          "start": 246.74,
          "end": 258.04,
          "text": "Director: Well, I'm afraid we have no vacancy at the moment, and you can't join until the beginning of September because one child will finish caring at the end of August.",
          "translation": "恐怕我们目前没有空位，您要到9月初才能入托，因为有一个孩子会在8月底结束托管。",
          "source_order": 35,
          "source_start_time": 246740,
          "source_end_time": 258040
        },
        {
          "id": 37,
          "start": 258.92,
          "end": 259.4,
          "text": "Man: I see.",
          "translation": "我明白了。",
          "source_order": 36,
          "source_start_time": 258920,
          "source_end_time": 259400
        },
        {
          "id": 38,
          "start": 305.88,
          "end": 308.42,
          "text": "Director: Then I will talk about our staff.",
          "translation": "接下来我介绍一下我们的工作人员。",
          "source_order": 37,
          "source_start_time": 305880,
          "source_end_time": 308420
        },
        {
          "id": 39,
          "start": 309.2,
          "end": 316.06,
          "text": "Director: All of our centre's members are well trained so that they will take care of your children in every aspect.",
          "translation": "我们中心的所有工作人员都训练有素，能够全方位照顾您的孩子。",
          "source_order": 38,
          "source_start_time": 309200,
          "source_end_time": 316060
        },
        {
          "id": 40,
          "start": 316.84,
          "end": 333.32,
          "text": "Director: For example, when doing activities with special needs, our staff will prepare all the necessities for children, like aprons in the painting class, sunglasses and sun cream when playing outside in a sunny day.",
          "translation": "例如，开展有特殊用品需求的活动时，我们的工作人员会为孩子准备好所有必需品，比如绘画课用的围裙，以及晴天在户外玩耍时需要的太阳镜和防晒霜。",
          "source_order": 39,
          "source_start_time": 316840,
          "source_end_time": 333320
        },
        {
          "id": 41,
          "start": 333.88,
          "end": 335.92,
          "text": "Man: It's great that you can consider that.",
          "translation": "你们能考虑到这些，真是太好了。",
          "source_order": 40,
          "source_start_time": 333880,
          "source_end_time": 335920
        },
        {
          "id": 42,
          "start": 336.52,
          "end": 339.24,
          "text": "Man: I thought we had to prepare for these by ourselves.",
          "translation": "我原以为这些得由我们自己准备。",
          "source_order": 41,
          "source_start_time": 336520,
          "source_end_time": 339240
        },
        {
          "id": 43,
          "start": 339.98,
          "end": 343.28,
          "text": "Director: You must provide something - a family photo.",
          "translation": "有一样东西必须由您提供，那就是一张全家福。",
          "source_order": 42,
          "source_start_time": 339980,
          "source_end_time": 343280
        },
        {
          "id": 44,
          "start": 344.14,
          "end": 354.44,
          "text": "Director: Many children may miss their parents, especially during the first week, so our staff will take photos of every child in case they need them.",
          "translation": "很多孩子可能会想念父母，尤其是在第一周，所以我们的工作人员会给每个孩子拍照，以备他们需要时使用。",
          "source_order": 43,
          "source_start_time": 344140,
          "source_end_time": 354440
        },
        {
          "id": 45,
          "start": 355.06,
          "end": 355.4,
          "text": "Man: Right.",
          "translation": "好的。",
          "source_order": 44,
          "source_start_time": 355060,
          "source_end_time": 355400
        },
        {
          "id": 46,
          "start": 355.92,
          "end": 361.3,
          "text": "Man: Apart from the professional knowledge of caring, are there any other requirements for your staff?",
          "translation": "除了专业的保育知识，你们对工作人员还有其他要求吗？",
          "source_order": 45,
          "source_start_time": 355920,
          "source_end_time": 361300
        },
        {
          "id": 47,
          "start": 362.06,
          "end": 374.48,
          "text": "Director: Well, actually, when we do the recruitment, the priority we consider is the general health of the staff, so each applicant must provide a health certificate from the doctor.",
          "translation": "其实，我们招聘时优先考虑的是工作人员的整体健康状况，因此每位申请人都必须提供医生开具的健康证明。",
          "source_order": 46,
          "source_start_time": 362060,
          "source_end_time": 374480
        },
        {
          "id": 48,
          "start": 375.18,
          "end": 377.08,
          "text": "Man: Yes, I agree it's essential.",
          "translation": "是的，我也认为这非常重要。",
          "source_order": 47,
          "source_start_time": 375180,
          "source_end_time": 377080
        },
        {
          "id": 49,
          "start": 377.56,
          "end": 380.88,
          "text": "Man: I've learned about your centre and am pretty interested.",
          "translation": "我已经了解了你们中心，确实很感兴趣。",
          "source_order": 48,
          "source_start_time": 377560,
          "source_end_time": 380880
        },
        {
          "id": 50,
          "start": 381.5,
          "end": 383.94,
          "text": "Man: But I still have to discuss it with my wife.",
          "translation": "不过，我还得和妻子商量一下。",
          "source_order": 49,
          "source_start_time": 381500,
          "source_end_time": 383940
        },
        {
          "id": 51,
          "start": 384.62,
          "end": 385.16,
          "text": "Director: Of course.",
          "translation": "当然可以。",
          "source_order": 50,
          "source_start_time": 384620,
          "source_end_time": 385160
        },
        {
          "id": 52,
          "start": 385.84,
          "end": 394.0,
          "text": "Director: Then I'll give you the contact detail of our centre, and if you want to register, you can call us or even have a visit if you like.",
          "translation": "那我把我们中心的联系方式给您。如果您想报名，可以给我们打电话，也可以过来参观。",
          "source_order": 51,
          "source_start_time": 385840,
          "source_end_time": 394000
        },
        {
          "id": 53,
          "start": 394.78,
          "end": 395.56,
          "text": "Man: OK.",
          "translation": "好的。",
          "source_order": 52,
          "source_start_time": 394780,
          "source_end_time": 395560
        },
        {
          "id": 54,
          "start": 395.56,
          "end": 396.5,
          "text": "Man: What's your address?",
          "translation": "你们的地址是什么？",
          "source_order": 53,
          "source_start_time": 395560,
          "source_end_time": 396500
        },
        {
          "id": 55,
          "start": 397.0,
          "end": 406.9,
          "text": "Director: It's NO.75, Calliope Avenue, that's C-A-double L-I-O-P-E, Walkley.",
          "translation": "地址是沃克利卡利奥佩大道75号，卡利奥佩拼作C-A-L-L-I-O-P-E。",
          "source_order": 54,
          "source_start_time": 397000,
          "source_end_time": 406900
        },
        {
          "id": 56,
          "start": 409.88,
          "end": 412.08,
          "text": "Man: OK, NO.75, Calliope Avenue.",
          "translation": "好的，卡利奥佩大道75号。",
          "source_order": 55,
          "source_start_time": 409880,
          "source_end_time": 412080
        },
        {
          "id": 57,
          "start": 412.78,
          "end": 414.78,
          "text": "Director: And the telephone number is 4789 6354.",
          "translation": "电话号码是4789 6354。",
          "source_order": 56,
          "source_start_time": 412780,
          "source_end_time": 414780
        },
        {
          "id": 58,
          "start": 418.29,
          "end": 421.8,
          "text": "Man: OK.",
          "translation": "好的。",
          "source_order": 57,
          "source_start_time": 418290,
          "source_end_time": 421800
        },
        {
          "id": 59,
          "start": 421.8,
          "end": 423.44,
          "text": "Man: That's everything I want to know.",
          "translation": "我想了解的就是这些。",
          "source_order": 58,
          "source_start_time": 421800,
          "source_end_time": 423440
        },
        {
          "id": 60,
          "start": 423.88,
          "end": 425.06,
          "text": "Man: Thank you very much.",
          "translation": "非常感谢。",
          "source_order": 59,
          "source_start_time": 423880,
          "source_end_time": 425060
        },
        {
          "id": 61,
          "start": 425.64,
          "end": 426.56,
          "text": "Director: You are welcome!",
          "translation": "不客气！",
          "source_order": 60,
          "source_start_time": 425640,
          "source_end_time": 426560
        },
        {
          "id": 62,
          "start": 426.96,
          "end": 427.26,
          "text": "Director: Bye!",
          "translation": "再见！",
          "source_order": 61,
          "source_start_time": 426960,
          "source_end_time": 427260
        },
        {
          "id": 63,
          "start": 427.96,
          "end": 428.34,
          "text": "Man: Bye!",
          "translation": "再见！",
          "source_order": 62,
          "source_start_time": 427960,
          "source_end_time": 428340
        }
      ]
    }
  ]
}