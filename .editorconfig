# 统一基础编码风格，编辑器自动遵守。https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{js,wxml,wxss,json,wxs}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown 行尾两空格是换行语义
